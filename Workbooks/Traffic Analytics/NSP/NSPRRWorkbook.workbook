      "name": "NSP Tab"
    },
    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "items": [
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "NTANspRuleRecommendation\r\n| where iff('{NSPResourceNameId}' == '\"//*\"', true, (NspResourceId in~ ({NSPResourceNameId})))\r\n| where RuleType == \"ServiceTag\"\r\n    and ResultDirection == \"Inbound\"\r\n    and ResultAction == \"Allowed\"\r\n| extend ParsedIPs = todynamic(SourceIPs)\r\n| mv-expand IP = ParsedIPs\r\n| summarize SourceIPs = make_set(tostring(IP))\r\n    by TrafficType, NspProfile, NspResourceId, RuleType, RuleValue\r\n| extend IPCount = array_length(SourceIPs)\r\n| extend SourceIPs = strcat_array(SourceIPs, \", \")\r\n| project TrafficType,  NspResourceId = strcat(\"/subscriptions/\", split(NspResourceId, \"/\")[0], \"/resourceGroups/\", split(NspResourceId, \"/\")[1], \"/providers/Microsoft.Network/networkSecurityPerimeters/\", split(NspResourceId, \"/\")[2]), NspProfile, SourceIPs, RuleType, RuleValue",
              "size": 0,
              "showAnalytics": true,
              "title": "[Inbound] ServiceTag Recommendations",
              "timeContextFromParameter": "timeInterval",
              "showRefreshButton": true,
              "showExportToExcel": true,
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "crossComponentResources": [
                "{workspace}"
              ],
              "visualization": "table",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "PreviewIPs",
                    "formatter": 1,
                    "formatOptions": {
                      "linkTarget": "CellDetails",
                      "linkIsContextBlade": true
                    }
                  },
                  {
                    "columnMatch": "SourceIPs",
                    "formatter": 1,
                    "formatOptions": {
                      "linkTarget": "CellDetails",
                      "linkIsContextBlade": true
                    }
                  },
                  {
                    "columnMatch": "Url",
                    "formatter": 7,
                    "formatOptions": {
                      "linkTarget": "Url"
                    }
                  },
                  {
                    "columnMatch": "counterValue",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "greenRed"
                    }
                  }
                ],
                "rowLimit": 10000
              }
            },
            "conditionalVisibilities": [
              {
                "parameterName": "Info",
                "comparison": "isEqualTo",
                "value": "Allowed"
              },
              {
                "parameterName": "Tab",
                "comparison": "isEqualTo",
                "value": "NSP"
              }
            ],
            "name": "[Inbound] ServiceTag Recommendations"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "let Notes = \"Service Endpoint traffic found. Add 'MicrosoftPublicIPSpace' tag or follow Network Identifier TSG to allow the traffic via Service Tag (https://eng.ms/docs/cloud-ai-platform/azure-core/azure-networking/sdn-dbansal/azure-virtual-network-manager/nsp-dataplane-library/articles/ns22tsg/ns22serviceendpoint)\";\r\nNTANspRuleRecommendation\r\n| where iff('{NSPResourceNameId}' == '\"//*\"', true, (NspResourceId in~ ({NSPResourceNameId})))\r\n| where isnotempty(ServiceEndpoints) and ServiceEndpoints!= \"[]\" and ResultDirection == \"Inbound\" and RuleType != \"ServiceEndpoint\" and ResultAction == \"Allowed\"\r\n| extend ParsedIPs = todynamic(ServiceEndpoints)\r\n| mv-expand IP = ParsedIPs\r\n| summarize ServiceEndpoints = make_set(IP) by TrafficType, NspProfile, NspResourceId, RuleType, RuleValue\r\n| extend Count = array_length(ServiceEndpoints), ServiceEndpoints = strcat_array(ServiceEndpoints, \", \")\r\n//| project TrafficType, NspProfile, NspResourceId, Count, RuleType, Notes\r\n| project TrafficType,  NspResourceId = strcat(\"/subscriptions/\", split(NspResourceId, \"/\")[0], \"/resourceGroups/\", split(NspResourceId, \"/\")[1], \"/providers/Microsoft.Network/networkSecurityPerimeters/\", split(NspResourceId, \"/\")[2]), NspProfile, RuleType, RuleValue, ServiceEndpoints",
              "size": 0,
              "showAnalytics": true,
              "title": "[Inbound] Microsoft Traffic - Service Endpoint/SNAT bypass ",
              "timeContextFromParameter": "timeInterval",
              "showRefreshButton": true,
              "showExportToExcel": true,
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "crossComponentResources": [
                "{workspace}"
              ],
              "visualization": "table",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "ServiceEndpoints",
                    "formatter": 1,
                    "formatOptions": {
                      "linkTarget": "CellDetails",
                      "linkIsContextBlade": true
                    }
                  },
                  {
                    "columnMatch": "Notes",
                    "formatter": 1,
                    "formatOptions": {
                      "linkTarget": "CellDetails",
                      "linkIsContextBlade": true
                    }
                  },
                  {
                    "columnMatch": "Url",
                    "formatter": 7,
                    "formatOptions": {
                      "linkTarget": "Url"
                    }
                  },
                  {
                    "columnMatch": "counterValue",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "greenRed"
                    }
                  }
                ],
                "rowLimit": 10000
              }
            },
            "name": "[Inbound] Microsoft Traffic - Service Endpoint/SNAT bypass "
          },
          {
            "type": 9,
            "content": {
              "version": "KqlParameterItem/1.0",
              "crossComponentResources": [
                "{workspace}"
              ],
              "parameters": [
                {
                  "id": "bee03ea0-a7a9-4050-85d4-32b38992b06b",
                  "version": "KqlParameterItem/1.0",
                  "name": "ServiceEndpoint_SNAT_InfoTab",
                  "type": 1,
                  "query": "NTANspRuleRecommendation\r\n| where iff('{NSPResourceNameId}' == '\"//*\"', true, (NspResourceId in~ ({NSPResourceNameId})))\r\n| where isnotempty(ServiceEndpoints)\r\n    and ServiceEndpoints != \"[]\"\r\n    and ResultDirection == \"Inbound\"\r\n    and RuleType != \"ServiceEndpoint\"\r\n    and ResultAction == \"Allowed\"\r\n| summarize Count = count()\r\n| project HasServiceEndpointTraffic = Count > 0",
                  "crossComponentResources": [
                    "{workspace}"
                  ],
                  "isHiddenWhenLocked": true,
                  "timeContext": {
                    "durationMs": 86400000
                  },
                  "queryType": 0,
                  "resourceType": "microsoft.operationalinsights/workspaces"
                }
              ],
              "style": "pills",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces"
            },
            "name": "parameters - 2"
          },
          {
            "type": 1,
            "content": {
              "json": "**Above Service Endpoint traffic found**. Add 'MicrosoftPublicIPSpace' tag or follow Network Identifier TSG to allow the traffic via Service Tag (https://eng.ms/docs/cloud-ai-platform/azure-core/azure-networking/sdn-dbansal/azure-virtual-network-manager/nsp-dataplane-library/articles/ns22tsg/ns22serviceendpoint)",
              "style": "info"
            },
            "conditionalVisibility": {
              "parameterName": "ServiceEndpoint_SNAT_InfoTab",
              "comparison": "isEqualTo",
              "value": "true"
            },
            "name": "InfoTab_SNAT_Text"
