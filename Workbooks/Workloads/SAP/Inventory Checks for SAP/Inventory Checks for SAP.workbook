          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\r\n| where type =~ \"microsoft.compute/virtualmachines\"\r\n| where resourceGroup in ({Resource_Group}) or '*' in ({Resource_Group})\r\n| extend vmSize = tostring(properties.hardwareProfile.vmSize)\r\n| where vmSize startswith \"Standard_M\"\r\n// Exclude any M-series SKU that is explicitly v2 or v3\r\n| where not(vmSize matches regex @\"_v(2|3)$\")\r\n| extend vmVersionNum = coalesce(toint(extract(@\"_v(\\d+)$\", 1, vmSize)), 1)  // no _v# suffix => v1\r\n| where vmVersionNum in (1, 4, 5)\r\n| project Name=id,  Powerstate = tostring(properties.extended.instanceView.powerState.displayStatus), vmsize = tostring(properties.hardwareProfile.vmSize), \r\n os_type = tostring(properties.storageProfile.osDisk.osType), imagesku= tostring(properties.storageProfile.imageReference.sku), location, avZone = tostring(zones), resourceGroup",
              "size": 0,
