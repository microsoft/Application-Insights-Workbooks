                },
                {
                  "type": 3,
                  "content": {
                    "version": "KqlItem/1.0",
                    "query": "Resources\r\n| where type =~ \"microsoft.storage/storageaccounts\"\r\n| where resourceGroup in~ ({Resource_Group}) or '*' in~ ({Resource_Group})\r\n| mv-expand privatepoint = properties.privateEndpointConnections\r\n| extend PrivateEndpointId = tostring(privatepoint.properties.privateEndpoint.id)\r\n| mv-expand groupId = privatepoint.properties.groupIds\r\n| extend Subresource = tostring(groupId)\r\n// Join to Private Endpoint → subnet + NICs\r\n| join kind=leftouter (\r\n    Resources\r\n    | where type =~ \"microsoft.network/privateendpoints\"\r\n    | extend PeSubnetId = tostring(properties.subnet.id),\r\n             NicArray = todynamic(properties.networkInterfaces)\r\n    | mv-expand NicArray\r\n    | extend NicId = tostring(NicArray.id)\r\n    | project peId = id, PeSubnetId, NicId\r\n) on $left.PrivateEndpointId == $right.peId\r\n// Join to NIC → private IP + (NIC) subnet\r\n| join kind=leftouter (\r\n    Resources\r\n    | where type =~ \"microsoft.network/networkinterfaces\"\r\n    | mv-expand ipc = properties.ipConfigurations\r\n    | extend PrivateIp = tostring(ipc.properties.privateIPAddress),\r\n             NicSubnetId = tostring(ipc.properties.subnet.id)\r\n    | project NicId = id, PrivateIp, NicSubnetId\r\n) on NicId\r\n// Roll subresources back up to one row per PE connection\r\n| summarize PrivateLinkSubresources = make_set(Subresource),\r\n            PrivateEndpointIP = any(PrivateIp),\r\n            PrivateEndpointSubnetId = any(coalesce(NicSubnetId, PeSubnetId))\r\n  by id, name,\r\n     sku = tostring(sku.name), Tier = tostring(sku.tier),\r\n     status = tostring(properties.provisioningState),\r\n     Create_Time = tostring(properties.creationTime),\r\n     supportsHttpsTrafficOnly = tostring(properties.supportsHttpsTrafficOnly),\r\n     allowBlobPublicAccess = tostring(properties.allowBlobPublicAccess),\r\n     minimumTlsVersion = tostring(properties.minimumTlsVersion),\r\n     Primary_Region = tostring(properties.primaryLocation),\r\n     statusOfPrimary = tostring(properties.statusOfPrimary),\r\n     accessTier = tostring(properties.accessTier),\r\n     Secondary_Available = tostring(properties.secondaryLocation),\r\n     Secondary_Status = tostring(properties.statusOfSecondary),\r\n     PrivateEndPoint = tostring(privatepoint.name),\r\n     PrivateEndpointId = tostring(PrivateEndpointId)\r\n| extend PrivateEndpointName = tostring(split(PrivateEndpointId, \"/\")[8]),\r\n         PrivateEndpointSubnetName = iff(isempty(PrivateEndpointSubnetId), \"\", tostring(split(PrivateEndpointSubnetId, \"/\")[10]))\r\n// Reorder columns: make IP and Subnet 3rd & 4th\r\n| project\r\n    id,\r\n    name,\r\n    PrivateEndpointIP,\r\n    PrivateEndpointSubnetName,\r\n    sku,\r\n    Tier,\r\n    status,\r\n    Create_Time,\r\n    supportsHttpsTrafficOnly,\r\n    allowBlobPublicAccess,\r\n    minimumTlsVersion,\r\n    Primary_Region,\r\n    statusOfPrimary,\r\n    accessTier,\r\n    Secondary_Available,\r\n    Secondary_Status,\r\n    PrivateEndPoint,\r\n    PrivateLinkSubresources,\r\n    PrivateEndpointName,\r\n    PrivateEndpointId,\r\n    PrivateEndpointSubnetId\r\n| order by name asc\r\n",
                    "size": 2,
                    "title": "Standard Storage Account with PvtEndPoint",
                    "noDataMessage": "No Standard Storage Account with PvtEndPoint found in the selected Subscription.",
                    "showExportToExcel": true,
                    "exportToExcelOptions": "all",
                    "queryType": 1,
                    "resourceType": "microsoft.resourcegraph/resources",
                    "crossComponentResources": [
                      "{Subscriptions}"
                    ],
                    "gridSettings": {
                      "formatters": [
                        {
                          "columnMatch": "id",
                          "formatter": 13,
                          "formatOptions": {
                            "linkTarget": "Resource",
                            "linkIsContextBlade": true,
