          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "// LB probes\r\nresources\r\n| where type == \"microsoft.network/loadbalancers\"\r\n| where resourceGroup in ({Resource_Group}) or '*' in ({Resource_Group})\r\n| project id, subscriptionId, lbName=name, lbSku=sku.name, location, lbProbes=properties.probes, resourceGroup\r\n| mv-expand lbProbes\r\n| project id, probeName=tostring(lbProbes.name), probePort=toint(lbProbes.properties.port), \r\n         probeThreshold=lbProbes.properties.probeThreshold,\r\n          lbSku, location, probeProtocol=lbProbes.properties.protocol, resourceGroup\r\n| where probeThreshold !contains \"2\"\r\n| order by id asc, probePort asc",
