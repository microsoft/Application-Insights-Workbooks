                {
                  "type": 3,
                  "content": {
                    "version": "KqlItem/1.0",
                    "query": "resources\r\n| where type == \"microsoft.network/applicationgateways\"\r\n| extend probes = properties.probes,\r\n         backendPools = properties.backendAddressPools,\r\n         backendHttpSettings = properties.backendHttpSettingsCollection\r\n| mv-expand backendPools\r\n| mv-expand probes\r\n| mv-expand addresses = backendPools.properties.backendAddresses\r\n| project \r\n    subscriptionId,\r\n    resourceGroup,\r\n    appGatewayName = name,\r\n    backendPoolName = backendPools.name,\r\n    backendIP = tostring(addresses.ipAddress)\r\n| join kind=inner (\r\n    resources\r\n    | where type == \"microsoft.network/applicationgateways\"\r\n    | mv-expand backendHttpSettings = properties.backendHttpSettingsCollection\r\n    | project \r\n        appGatewayName = name,\r\n        backendHttpSettingName = backendHttpSettings.name,\r\n        port = tostring(backendHttpSettings.properties.port),\r\n        protocol = tostring(backendHttpSettings.properties.protocol)\r\n) on appGatewayName\r\n| project \r\n    [\"Server (backend pool)\"] = strcat(backendIP, \" (\", backendPoolName, \")\"),\r\n    Status = \"Check the Metric\", // Placeholder, cannot get real-time health from ARG\r\n    [\"Port (Backend setting)\"] = strcat(port, \" (\", backendHttpSettingName, \"-\", port, \")\"),\r\n    Protocol = protocol\r\n",
                    "size": 0,
                    "title": "AppGW Probe Configuration",
                    "showExportToExcel": true,
                    "exportToExcelOptions": "all",
