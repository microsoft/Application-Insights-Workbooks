          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\r\n| where type == \"microsoft.compute/disks\"\r\n| where resourceGroup in ({Resource_Group}) or '*' in ({Resource_Group})\r\n| extend\r\n    diskName   = name,\r\n    skuName    = tostring(sku.name),\r\n    tier       = tostring(sku.tier),\r\n    diskSizeGB = tostring(properties.diskSizeGB),\r\n    avZone     = iff(isempty(zones), \"\", tostring(zones[0])),\r\n    osType     = tostring(properties.osType)\r\n// Exclude OS disks: only data disks have osType == null/empty\r\n| where isnull(osType) or osType == \"\"\r\n// Exclude PremiumV2 and Ultra\r\n| where skuName !startswith \"PremiumV2\"\r\n      and skuName !startswith \"Ultra\"\r\n| project\r\n    id,\r\n    skuName,\r\n    tier,\r\n    diskSizeGB,\r\n    avZone,\r\n    resourceGroup,\r\n    location\r\n",
              "size": 0,
