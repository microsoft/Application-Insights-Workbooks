                  "value": "0"
                },
                {
                  "version": "KqlParameterItem/1.0",
                  "name": "p_AppGWv2Percent",
                  "type": 1,
                  "query": "resources\r\n| where type =~ \"microsoft.network/applicationgateways\"\r\n| where resourceGroup in~ ({Resource_Group}) or '*' in ({Resource_Group})\r\n| extend skuTier = tostring(properties.sku.tier)\r\n| extend Version = iif(tolower(skuTier) contains \"_v2\", \"v2\", \"v1\")\r\n| summarize\r\n    TotalAppGWs  = count(),\r\n    AppGWv2Count = countif(Version == \"v2\"),\r\n    AppGWv1Count = countif(Version == \"v1\")\r\n| extend\r\n    AppGWv2Percent = iff(TotalAppGWs > 0, round(100.0 * todouble(AppGWv2Count) / todouble(TotalAppGWs), 2), 0.0),\r\n    AppGWv1Percent = iff(TotalAppGWs > 0, round(100.0 * todouble(AppGWv1Count) / todouble(TotalAppGWs), 2), 0.0)\r\n| extend\r\n    p_AppGWv2Percent = strcat(tostring(AppGWv2Percent), \"%\"),\r\n    p_AppGWv1Percent = strcat(tostring(AppGWv1Percent), \"%\"),\r\n    p_AppGWTotal     = tostring(TotalAppGWs)\r\n| project TotalAppGWs, AppGWv1Count, AppGWv2Count, p_AppGWv1Percent, p_AppGWv2Percent, p_AppGWTotal\r\n| project Message = strcat(p_AppGWv2Percent)\r\n",
                  "crossComponentResources": [
                    "{Subscriptions}"
                  ],
                  "isHiddenWhenLocked": true,
                  "timeContext": {
                    "durationMs": 86400000
                  },
                  "queryType": 1,
                  "resourceType": "microsoft.resourcegraph/resources",
                  "id": "4770fdf6-041f-4cfb-b877-6aaa08a33929"
                },
                {
                  "id": "b976b651-d6e7-41d8-a420-4d19bc970b0e",
                  "version": "KqlParameterItem/1.0",
                  "name": "p_VMSSPercent",
                  "type": 1,
                  "query": "resources\r\n| where type =~ \"microsoft.compute/virtualmachines\"\r\n| where resourceGroup in~ ({Resource_Group}) or '*' in ({Resource_Group})\r\n| extend inVMSS = isnotempty(tostring(properties.virtualMachineScaleSet.id))\r\n| summarize TotalVMs = count(), VMSSVMs = countif(inVMSS)\r\n| extend VMSSPercent = iff(TotalVMs > 0, round(100.0 * VMSSVMs / TotalVMs, 2), 0.0)\r\n| project Message = strcat(tostring(VMSSPercent), \"%\")\r\n",
                  "crossComponentResources": [
                    "{Subscriptions}"
                  ],
                  "isHiddenWhenLocked": true,
                  "timeContext": {
                    "durationMs": 86400000
                  },
                  "queryType": 1,
                  "resourceType": "microsoft.resourcegraph/resources"
                },
                {
                  "version": "KqlParameterItem/1.0",
                  "name": "p_AvSetPercent",
                  "type": 1,
                  "query": "resources\r\n| where type =~ \"microsoft.compute/virtualmachines\"\r\n| where resourceGroup in~ ({Resource_Group}) or '*' in ({Resource_Group})\r\n| summarize\r\n    TotalVMs   = count(),\r\n    AvSetVMs   = countif(isnotempty(tostring(properties.availabilitySet.id)))\r\n| extend AvSetPercent = iff(TotalVMs > 0, round(100.0 * AvSetVMs / TotalVMs, 2), 0.0)\r\n| project p_AvSetPercent = strcat(tostring(AvSetPercent), \"%\")\r\n",
                  "crossComponentResources": [
                    "{Subscriptions}"
                  ],
                  "isHiddenWhenLocked": true,
                  "queryType": 1,
                  "resourceType": "microsoft.resourcegraph/resources",
                  "id": "ce0f0547-4323-441d-a90b-c362de1d9b48"
                },
                {
                  "version": "KqlParameterItem/1.0",
                  "name": "p_Genv2Percentage",
                  "type": 1,
                  "query": "resources\r\n| where type =~ \"microsoft.compute/virtualmachines\"\r\n| where '*' in ({Resource_Group}) or resourceGroup in~ ({Resource_Group})\r\n| extend osDiskId = tolower(tostring(properties.storageProfile.osDisk.managedDisk.id))\r\n| join kind=leftouter (\r\n    resources\r\n    | where type =~ \"microsoft.compute/disks\"\r\n    | extend osDiskId = tolower(id)\r\n    | project osDiskId, hyperVGeneration = tostring(properties.hyperVGeneration)\r\n) on $left.osDiskId == $right.osDiskId\r\n| extend vmGeneration = case(\r\n    tolower(hyperVGeneration) == \"v2\",\"Gen2\",\r\n    tolower(hyperVGeneration) == \"v1\",\"Gen1\",\r\n    \"Unknown\"\r\n)\r\n| summarize\r\n    TotalVMs = count(),\r\n    Gen1VMs  = countif(vmGeneration == \"Gen1\"),\r\n    Gen2VMs  = countif(vmGeneration == \"Gen2\"),\r\n    UnknownVMs = countif(vmGeneration == \"Unknown\")\r\n| extend Gen2VMsPercent = iff(TotalVMs == 0, 0.0, 100.0 * todouble(Gen2VMs) / todouble(TotalVMs))\r\n| project p_Gen2VMsPercentage = strcat(tostring(round(Gen2VMsPercent, 2)), \"%\")\r\n",
                  "crossComponentResources": [
                    "{Subscriptions}"
                  ],
                  "isHiddenWhenLocked": true,
                  "timeContext": {
                    "durationMs": 86400000
                  },
                  "queryType": 1,
                  "resourceType": "microsoft.resourcegraph/resources",
                  "id": "b172271a-83cb-44fe-b7c1-859ddef689ec",
                  "value": null
                },
                {
                  "id": "ce1ae0a8-89e3-466a-aa49-6656ff30557a",
                  "version": "KqlParameterItem/1.0",
                  "name": "VMsInCRG",
                  "type": 1,
                  "query": "resources\r\n| where type =~ \"microsoft.compute/capacityreservationgroups\"\r\n| where resourceGroup in~ ({Resource_Group}) or '*' in ({Resource_Group})\r\n| summarize TotalAssociatedVMs = sum(\r\n    array_length(iif(isnull(properties.virtualMachinesAssociated), dynamic([]), todynamic(properties.virtualMachinesAssociated)))\r\n)\r\n| project Message = strcat(TotalAssociatedVMs)",
                  "crossComponentResources": [
                    "{Subscriptions}"
                  ],
                  "isHiddenWhenLocked": true,
