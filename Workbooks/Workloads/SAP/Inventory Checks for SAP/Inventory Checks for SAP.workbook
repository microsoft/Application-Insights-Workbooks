                {
                  "type": 3,
                  "content": {
                    "version": "KqlItem/1.0",
                    "query": "Resources\r\n| where type in~ (\r\n    \"microsoft.network/virtualnetworkgateways\",   // vNet gateways\r\n    \"microsoft.network/expressroutegateways\"      // ExpressRoute gateways (vWAN)\r\n)\r\n| extend gatewayKind = case(\r\n    type =~ \"microsoft.network/virtualnetworkgateways\"\r\n        and tostring(properties.gatewayType) =~ \"Vpn\",          \"vNet VPN gateway\",\r\n    type =~ \"microsoft.network/virtualnetworkgateways\"\r\n        and tostring(properties.gatewayType) =~ \"ExpressRoute\", \"vNet ExpressRoute gateway\",\r\n    type =~ \"microsoft.network/expressroutegateways\",           \"ExpressRoute gateway (VWAN)\",\r\n    \"Other\"\r\n)\r\n| project\r\nid,\r\n    resourceGroup,\r\n    location,\r\n    gatewayKind,\r\n    gatewayType = tostring(properties.gatewayType),\r\n    vpnType     = tostring(properties.vpnType),\r\n    enableBgp   = tostring(properties.enableBgp),\r\n    skuName     = tostring(sku.name),\r\n    skuTier     = tostring(sku.tier),\r\n    skuCapacity = tostring(sku.capacity)\r\n",
                    "size": 0,
                    "title": "virtualnetworkgateways",
                    "showExportToExcel": true,
