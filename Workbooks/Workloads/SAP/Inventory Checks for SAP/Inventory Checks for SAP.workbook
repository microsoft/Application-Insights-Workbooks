                },
                {
                  "version": "KqlParameterItem/1.0",
                  "name": "VMSCSI",
                  "type": 1,
                  "query": "resources\r\n| where type =~ \"microsoft.compute/virtualmachines\"\r\n| where resourceGroup in~ ({Resource_Group}) or '*' in ({Resource_Group})\r\n| extend\r\n    vmSize = tostring(properties.hardwareProfile.vmSize),\r\n    diskControllerType = tostring(properties.storageProfile.diskControllerType)\r\n| where vmSize in~ (\r\n    \"Standard_M416ds_6_v3\",\r\n    \"Standard_M416ds_8_v3\",\r\n    \"Standard_M624ds_12_v3\",\r\n    \"Standard_M832ds_12_v3\",\r\n    \"Standard_M832ids_16_v3\",\r\n    \"Standard_M416s_6_v3\",\r\n    \"Standard_M416s_8_v3\",\r\n    \"Standard_M624s_12_v3\",\r\n    \"Standard_M832s_12_v3\",\r\n    \"Standard_M832is_16_v3\",\r\n    \"Standard_E2bds_v5\",\r\n    \"Standard_E4bds_v5\",\r\n    \"Standard_E8bds_v5\",\r\n    \"Standard_E16bds_v5\",\r\n    \"Standard_E32bds_v5\",\r\n    \"Standard_E48bds_v5\",\r\n    \"Standard_E64bds_v5\",\r\n    \"Standard_E96bds_v5\"\r\n)\r\n| where diskControllerType == \"SCSI\"\r\n| summarize totalVmCount = count()\r\n| project Message = strcat(totalVmCount)",
                  "crossComponentResources": [
                    "{Subscriptions}"
                  ],
                  "isHiddenWhenLocked": true,
                  "timeContext": {
                    "durationMs": 86400000
                  },
                  "queryType": 1,
                  "resourceType": "microsoft.resourcegraph/resources",
                  "id": "680cfd1b-e959-4f6c-81fc-bdfa7d1e13c0",
                  "value": "0"
                },
                {
                  "id": "8b106648-6c6e-42fe-bc66-497fb85e835b",
                  "version": "KqlParameterItem/1.0",
                  "name": "VMFamilysummary",
                  "type": 1,
                  "query": "resources\r\n| where type =~ \"microsoft.compute/virtualmachines\"\r\n| where resourceGroup in ({Resource_Group}) or '*' in ({Resource_Group})\r\n| extend vmSize       = tostring(properties.hardwareProfile.vmSize)\r\n| extend vmVersionNum = toint(split(vmSize, \"_v\")[1])\r\n| where vmVersionNum in (2, 3, 4, 5)\r\n| where vmSize contains \"Standard_D\" or vmSize contains \"Standard_E\"\r\n| summarize vmCount = count() by vmVersionNum\r\n| extend key = 1\r\n| join kind=inner (\r\n    resources\r\n    | where type =~ \"microsoft.compute/virtualmachines\"\r\n    | where resourceGroup in ({Resource_Group}) or '*' in ({Resource_Group})\r\n    | extend vmSize2       = tostring(properties.hardwareProfile.vmSize)\r\n    | extend vmVersionNum2 = toint(split(vmSize2, \"_v\")[1])\r\n    | where vmVersionNum2 in (2, 3, 4, 5)\r\n    | summarize totalVm = count()\r\n    | extend key = 1\r\n) on key\r\n| extend vmVersion = strcat(\"v\", tostring(vmVersionNum))\r\n| extend vmPercent = round(100.0 * vmCount / todouble(totalVm), 2)\r\n| extend part      = strcat(tostring(vmCount), \" are \", vmVersion, \" (\", tostring(vmPercent), \"%)\")\r\n| summarize parts = make_list(part), totalVm = any(totalVm)\r\n| extend parts_str = tostring(parts)\r\n| extend parts_str = trim('[]', parts_str)\r\n| extend parts_str = replace_string(parts_str, '\",\"', \", \")\r\n| extend parts_str = replace_string(parts_str, '\"', \"\")\r\n| extend summary   = strcat(\"Out of total \", tostring(totalVm), \" E/D-Series VMs, \", parts_str)\r\n| project Message = strcat(summary)",
                  "crossComponentResources": [
                    "{Subscriptions}"
                  ],
                  "isHiddenWhenLocked": true,
                  "timeContext": {
                    "durationMs": 86400000
                  },
                  "queryType": 1,
                  "resourceType": "microsoft.resourcegraph/resources",
                  "value": "Out of total  E/D-Series VMs, []"
                },
                {
                  "version": "KqlParameterItem/1.0",
                  "name": "p_PremiumSSDv1Count",
                  "type": 1,
                  "query": "resources\r\n| where type == \"microsoft.compute/disks\"\r\n| where resourceGroup in ({Resource_Group}) or '*' in ({Resource_Group})\r\n| extend\r\n    diskName   = name,\r\n    skuName    = tostring(sku.name),\r\n    tier       = tostring(sku.tier),\r\n    diskSizeGB = tostring(properties.diskSizeGB),\r\n    avZone     = iff(isempty(zones), \"\", tostring(zones[0])),\r\n    osType     = tostring(properties.osType)\r\n// Exclude OS disks: only data disks have osType == null/empty\r\n| where isnull(osType) or osType == \"\"\r\n// Exclude PremiumV2 and Ultra\r\n| where skuName !startswith \"PremiumV2\"\r\n      and skuName !startswith \"Ultra\"\r\n| summarize name = count()\r\n| project Message = strcat(name)",
                  "crossComponentResources": [
                    "{Subscriptions}"
                  ],
                  "isHiddenWhenLocked": true,
                  "timeContext": {
                    "durationMs": 86400000
                  },
                  "queryType": 1,
                  "resourceType": "microsoft.resourcegraph/resources",
                  "id": "b7c533dd-ab23-4d46-a56b-e75b9c10883c",
                  "value": "0"
                },
                {
                  "version": "KqlParameterItem/1.0",
                  "name": "MSeriesDeployment",
                  "type": 1,
                  "query": "resources\r\n| where type =~ \"microsoft.compute/virtualmachines\"\r\n| where resourceGroup in ({Resource_Group}) or '*' in ({Resource_Group})\r\n| extend vmSize = tostring(properties.hardwareProfile.vmSize)\r\n| where vmSize startswith \"Standard_M\"\r\n| extend vmVersionNum = coalesce(toint(extract(@\"_v(\\d+)$\", 1, vmSize)), 1)  // no _v# suffix => v1\r\n| where vmVersionNum in (1, 2, 3, 4, 5)\r\n| summarize\r\n    totalVm = count(),\r\n    maxV    = max(vmVersionNum),\r\n    v1      = countif(vmVersionNum == 1),\r\n    v2      = countif(vmVersionNum == 2),\r\n    v3      = countif(vmVersionNum == 3),\r\n    v4      = countif(vmVersionNum == 4),\r\n    v5      = countif(vmVersionNum == 5)\r\n| extend maxV = iif(isnull(maxV), 1, maxV)\r\n| extend\r\n    p1 = iif(totalVm == 0, 0.0, round(100.0 * todouble(v1) / todouble(totalVm), 1)),\r\n    p2 = iif(totalVm == 0, 0.0, round(100.0 * todouble(v2) / todouble(totalVm), 1)),\r\n    p3 = iif(totalVm == 0, 0.0, round(100.0 * todouble(v3) / todouble(totalVm), 1)),\r\n    p4 = iif(totalVm == 0, 0.0, round(100.0 * todouble(v4) / todouble(totalVm), 1)),\r\n    p5 = iif(totalVm == 0, 0.0, round(100.0 * todouble(v5) / todouble(totalVm), 1))\r\n| extend\r\n    part1 = strcat(tostring(v1), \" are v1 (\", tostring(p1), \"%)\"),\r\n    part2 = strcat(tostring(v2), \" are v2 (\", tostring(p2), \"%)\"),\r\n    part3 = strcat(tostring(v3), \" are v3 (\", tostring(p3), \"%)\"),\r\n    part4 = strcat(tostring(v4), \" are v4 (\", tostring(p4), \"%)\"),\r\n    part5 = strcat(tostring(v5), \" are v5 (\", tostring(p5), \"%)\")\r\n// Order: v3, v2 & v1 (and if higher versions exist: v5, v4, v3, v2 & v1)\r\n| extend parts_str = case(\r\n    maxV == 1, part1,\r\n    maxV == 2, strcat(part2, \" & \", part1),\r\n    maxV == 3, strcat(part3, \", \", part2, \" & \", part1),\r\n    maxV == 4, strcat(part4, \", \", part3, \", \", part2, \" & \", part1),\r\n    maxV == 5, strcat(part5, \", \", part4, \", \", part3, \", \", part2, \" & \", part1),\r\n    strcat(part3, \", \", part2, \" & \", part1)\r\n)\r\n| project Message = strcat(\"Out of total \", tostring(totalVm), \" M-series VMs [ \", parts_str, \"]\")\r\n",
                  "crossComponentResources": [
                    "{Subscriptions}"
                  ],
                  "isHiddenWhenLocked": true,
                  "timeContext": {
                    "durationMs": 86400000
                  },
                  "queryType": 1,
                  "resourceType": "microsoft.resourcegraph/resources",
                  "id": "069fb363-894b-4191-84e1-f62b19f80eda",
                  "value": null
                }
              ],
              "style": "pills",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources"
            },
            "name": "parameters - 1"
          },
          {
            "type": 1,
            "content": {
              "json": "<h1 style=\"color: Grey; text-align: center; font-family: 'Helvetica Neue', Arial, sans-serif; font-size: 24px; margin-bottom: 10px; font-weight: bold;\">\r\n  Azure Deployment Summary for Selected Resources\r\n</h1>\r\n<p style=\"text-align: center; font-family: 'Helvetica Neue', Arial, sans-serif; font-size: 14px; color: #2E3A59; margin-top: 0; margin-bottom: 15px;\">\r\n  Azure Region of deployment for selected resources: <strong>{Location}</strong>\r\n</p>\r\n\r\n<table style=\"width: 100%; border-collapse: collapse; font-family: 'Helvetica Neue', Arial, sans-serif; margin: 20px auto; box-shadow: 0 2px 6px rgba(0,0,0,0.15);\">\r\n  <colgroup>\r\n    <col style=\"width: 10%;\">\r\n    <col style=\"width: 90%;\">\r\n  </colgroup>\r\n  <thead style=\"background-color: #007BFF; color: white; font-size: 16px;\">\r\n    <tr>\r\n      <th style=\"padding: 12px; border: 1px solid #ccc; text-align: left;\">Item</th>\r\n      <th style=\"padding: 12px; border: 1px solid #ccc; text-align: left;\">Observation</th>\r\n    </tr>\r\n  </thead>\r\n  <tbody style=\"background-color: #f9f9f9; font-size: 14px;\">\r\n\r\n    <!-- Deployment & Availability -->\r\n    <tr style=\"background-color:#f0f0f0;\">\r\n      <td style=\"padding:8px; border:1px solid #ccc;\">AZR-001</td>\r\n      <td style=\"padding:8px; border:1px solid #ccc;\">\r\n        Out of {VM_Count} VMs, {AvZone_VMs} [{p_ZonalVMsPercentage}] are in Availability Zones, {VMSS_VMs} [{p_VMSSPercent}] use VMSS Flex, and {AvSet} [{p_AvSetPercent}] are in an Availability Set.\r\n      </td>\r\n    </tr>\r\n    <tr>\r\n      <td style=\"padding:8px; border:1px solid #ccc;\">AZR-002</td>\r\n      <td style=\"padding:8px; border:1px solid #ccc;\">\r\n        {VM_Standard_OS} VMs use a Standard OS disk SKU, impacting the Single VM SLA.\r\n      </td>\r\n    </tr>\r\n\r\n    <!-- Resource Assignments / Capacity -->\r\n    <tr style=\"background-color:#f0f0f0;\">\r\n      <td style=\"padding:8px; border:1px solid #ccc;\">AZR-003</td>\r\n      <td style=\"padding:8px; border:1px solid #ccc;\">\r\n        {VMwithPPG} Virtual Machines are part of a Proximity Placement Group (PPG).\r\n      </td>\r\n    </tr>\r\n    <tr>\r\n      <td style=\"padding:8px; border:1px solid #ccc;\">AZR-004</td>\r\n      <td style=\"padding:8px; border:1px solid #ccc;\">\r\n        Total of {VMsInCRG} VMs hardware reserved using {crg} Capacity Reservation Groups (CRG) in the selected scope.\r\n      </td>\r\n    </tr>\r\n\r\n    <!-- Compute (Images, Extensions, Disk Controller, VM Family) -->\r\n    <tr style=\"background-color:#f0f0f0;\">\r\n      <td style=\"padding:8px; border:1px solid #ccc;\">AZR-005</td>\r\n      <td style=\"padding:8px; border:1px solid #ccc;\">\r\n        {VMExtension_failed} VM Extensions are in a failed state.\r\n      </td>\r\n    </tr>\r\n    <tr>\r\n      <td style=\"padding:8px; border:1px solid #ccc;\">AZR-006</td>\r\n      <td style=\"padding:8px; border:1px solid #ccc;\">\r\n        Out of {VM_Count} VMs, {Genv1count} [{p_Genv1Percentage}] are Gen1 and {Genv2count} [{p_Genv2Percentage}] are Gen2 image SKU.\r\n      </td>\r\n    </tr>\r\n    <tr style=\"background-color:#f0f0f0;\">\r\n      <td style=\"padding:8px; border:1px solid #ccc;\">AZR-007</td>\r\n      <td style=\"padding:8px; border:1px solid #ccc;\">\r\n        {VMSCSI} Number of VMs use SCSI where NVMe is supported.\r\n      </td>\r\n    </tr>\r\n    <tr>\r\n      <td style=\"padding:8px; border:1px solid #ccc;\">AZR-008</td>\r\n      <td style=\"padding:8px; border:1px solid #ccc;\">\r\n        {VMFamilysummary}.\r\n      </td>\r\n    </tr>\r\n\r\n    <!-- Compute / VM Family (Added AZR-009) -->\r\n    <tr style=\"background-color:#f0f0f0;\">\r\n      <td style=\"padding:8px; border:1px solid #ccc;\">AZR-009</td>\r\n      <td style=\"padding:8px; border:1px solid #ccc;\">\r\n        {MSeriesDeployment}.\r\n      </td>\r\n    </tr>\r\n\r\n    <!-- State, Health & Maintenance (Renumbered from AZR-009 to AZR-010) -->\r\n    <tr>\r\n      <td style=\"padding:8px; border:1px solid #ccc;\">AZR-010</td>\r\n      <td style=\"padding:8px; border:1px solid #ccc;\">\r\n        {Degraded} VMs are in a degraded state, {LiveMigration} VMs were live migrated, and {Unplannedoutage} VMs were impacted by unplanned maintenance.\r\n      </td>\r\n    </tr>\r\n\r\n    <!-- Networking (Renumbered) -->\r\n    <tr style=\"background-color:#f0f0f0;\">\r\n      <td style=\"padding:8px; border:1px solid #ccc;\">AZR-011</td>\r\n      <td style=\"padding:8px; border:1px solid #ccc;\">\r\n        {Accn_false} NICs have Accelerated Networking disabled.\r\n      </td>\r\n    </tr>\r\n    <tr>\r\n      <td style=\"padding:8px; border:1px solid:#ccc;\">AZR-012</td>\r\n      <td style=\"padding:8px; border:1px solid:#ccc;\">\r\n        {LBprobeThreshold} Load Balancers do not have probeThreshold set to 2.\r\n      </td>\r\n    </tr>\r\n\r\n    <!-- Storage (Renumbered) -->\r\n    <tr style=\"background-color:#f0f0f0;\">\r\n      <td style=\"padding:8px; border:1px solid:#ccc;\">AZR-013</td>\r\n      <td style=\"padding:8px; border:1px solid:#ccc;\">\r\n        {p_PremiumSSDv2Count} managed disks are Premium SSDv2; {p_PremiumSSDv2Percentage} of data disks are Premium SSDv2.\r\n      </td>\r\n    </tr>\r\n\r\n    <!-- App Gateway (Renumbered) -->\r\n    <tr>\r\n      <td style=\"padding:8px; border:1px solid:#ccc;\">AZR-014</td>\r\n      <td style=\"padding:8px; border:1px solid:#ccc;\">\r\n        Out of {TotalAppGWs} Application Gateways, {p_AppGWv2Percent} are v2.\r\n      </td>\r\n    </tr>\r\n\r\n  </tbody>\r\n</table>\r\n"
            },
            "name": "ECS Observability Summary",
            "styleSettings": {
              "showBorder": true
            }
          },
          {
            "type": 11,
            "content": {
