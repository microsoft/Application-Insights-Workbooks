          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\r\n| where type =~ \"microsoft.compute/virtualmachines\"\r\n| where '*' in~ ({Resource_Group}) or resourceGroup in~ ({Resource_Group})\r\n| extend\r\n    vmSize = tostring(properties.hardwareProfile.vmSize),\r\n    diskControllerType = tostring(properties.storageProfile.diskControllerType)\r\n| where vmSize in~ (\r\n    \"Standard_M416ds_6_v3\",\r\n    \"Standard_M416ds_8_v3\",\r\n    \"Standard_M624ds_12_v3\",\r\n    \"Standard_M832ds_12_v3\",\r\n    \"Standard_M832ids_16_v3\",\r\n    \"Standard_M416s_6_v3\",\r\n    \"Standard_M416s_8_v3\",\r\n    \"Standard_M624s_12_v3\",\r\n    \"Standard_M832s_12_v3\",\r\n    \"Standard_M832is_16_v3\",\r\n    \"Standard_E2bds_v5\",\r\n    \"Standard_E4bds_v5\",\r\n    \"Standard_E8bds_v5\",\r\n    \"Standard_E16bds_v5\",\r\n    \"Standard_E32bds_v5\",\r\n    \"Standard_E48bds_v5\",\r\n    \"Standard_E64bds_v5\",\r\n    \"Standard_E96bds_v5\"\r\n)\r\n| where diskControllerType == \"SCSI\"\r\n| project VMName=id, vmSize, diskControllerType, location, resourceGroup, subscriptionId\r\n",
              "size": 0,
              "title": "{VMSCSI} VMs with SCSI where NVMe supported",
              "noDataMessage": "No VM found with SCSI where NVMe supported",
              "showExportToExcel": true,
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
