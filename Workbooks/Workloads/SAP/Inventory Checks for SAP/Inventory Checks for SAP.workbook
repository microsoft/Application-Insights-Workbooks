                        {
                          "columnMatch": "AcceleratedNetworkingOn",
                          "formatter": 18,
                          "formatOptions": {
                            "thresholdsOptions": "icons",
                            "thresholdsGrid": [
                              {
                                "operator": "==",
                                "thresholdValue": "true",
                                "representation": "Available",
                                "text": "{0}{1}"
