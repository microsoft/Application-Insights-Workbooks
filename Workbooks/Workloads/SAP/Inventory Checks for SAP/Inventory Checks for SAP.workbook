    {
      "type": 1,
      "content": {
        "json": "\r\n### Network Section"
      },
      "conditionalVisibility": {
        "parameterName": "Show",
        "comparison": "isEqualTo",
        "value": "NoShow"
      },
      "name": "NetworkSection"
    },
    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "items": [
          {
            "type": 9,
            "content": {
              "version": "KqlParameterItem/1.0",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "parameters": [
                {
                  "id": "560b8040-2360-41d8-998b-086fed076f8a",
                  "version": "KqlParameterItem/1.0",
                  "name": "ExpressRouteCount",
                  "type": 1,
                  "query": "Resources\r\n| where type =~ 'microsoft.network/expressroutecircuits'\r\n| where resourceGroup in ({Resource_Group}) or '*' in ({Resource_Group})\r\n| summarize name = count()\r\n| project Message = strcat(name)\r\n",
                  "crossComponentResources": [
                    "{Subscriptions}"
                  ],
                  "isHiddenWhenLocked": true,
                  "timeContext": {
                    "durationMs": 86400000
                  },
                  "queryType": 1,
                  "resourceType": "microsoft.resourcegraph/resources"
                },
                {
                  "id": "e3d87215-0994-491c-95c3-bb82635deda2",
                  "version": "KqlParameterItem/1.0",
                  "name": "ErGWBasicSKU",
                  "type": 1,
                  "query": "Resources\r\n| where type == \"microsoft.network/publicipaddresses\"\r\n| where sku.name =~ \"Basic\"\r\n| join kind=inner (\r\n    Resources\r\n    | where type =~ \"microsoft.network/expressroutegateways\"\r\n) on $left.resourceGroup == $right.resourceGroup\r\n| where resourceGroup in ({Resource_Group}) or '*' in ({Resource_Group})\r\n| summarize name = count()\r\n| project Message = strcat(name)\r\n",
                  "crossComponentResources": [
                    "{Subscriptions}"
                  ],
                  "isHiddenWhenLocked": true,
                  "timeContext": {
                    "durationMs": 86400000
                  },
                  "queryType": 1,
                  "resourceType": "microsoft.resourcegraph/resources"
                },
                {
                  "id": "82c98788-3f3c-4bac-820b-a4c4c49791cc",
                  "version": "KqlParameterItem/1.0",
                  "name": "vnetPeeringMismatch",
                  "type": 1,
                  "query": "Resources\r\n| where type =~ \"microsoft.network/virtualnetworks/virtualnetworkpeerings\"\r\n| extend peeringState = tostring(properties.peeringState)\r\n| summarize total = count(), notConnected = countif(peeringState != \"Connected\")\r\n",
                  "crossComponentResources": [
                    "{Subscriptions}"
                  ],
                  "isHiddenWhenLocked": true,
                  "timeContext": {
                    "durationMs": 86400000
                  },
                  "queryType": 1,
                  "resourceType": "microsoft.resourcegraph/resources"
                },
                {
                  "id": "004b40e6-e688-4853-a799-a0000a2921f5",
                  "version": "KqlParameterItem/1.0",
                  "name": "FirewallRulesMissing",
                  "type": 1,
                  "query": "Resources\r\n| where type =~ 'microsoft.network/networksecuritygroups'\r\n| where resourceGroup in~ ({Resource_Group}) or '*' in~ ({Resource_Group})\r\n| extend rules = properties.securityRules\r\n| mv-expand rules\r\n| extend portMatch = tostring(rules.properties.destinationPortRange)\r\n| where portMatch contains '3200' or portMatch contains '3300' // Common SAP ports\r\n| summarize name = count()\r\n| project Message = strcat(name)\r\n",
                  "crossComponentResources": [
                    "{Subscriptions}"
                  ],
                  "isHiddenWhenLocked": true,
                  "timeContext": {
                    "durationMs": 86400000
                  },
                  "queryType": 1,
                  "resourceType": "microsoft.resourcegraph/resources"
                },
                {
                  "id": "a5544940-decd-450f-b76d-8248d0b4f1ed",
                  "version": "KqlParameterItem/1.0",
                  "name": "ERGWRedundant",
                  "type": 1,
                  "query": "Resources\r\n| where type =~ \"microsoft.network/virtualnetworkgateways\"\r\n| where resourceGroup in~ ({Resource_Group}) or '*' in~ ({Resource_Group})\r\n| where tostring(properties.gatewayType) == \"ExpressRoute\"\r\n| where properties.activeActive != true\r\n| project name\r\n| summarize name = count()\r\n| project Message = strcat(name)\r\n",
                  "crossComponentResources": [
                    "{Subscriptions}"
                  ],
                  "isHiddenWhenLocked": true,
                  "timeContext": {
                    "durationMs": 86400000
                  },
                  "queryType": 1,
                  "resourceType": "microsoft.resourcegraph/resources"
                },
                {
                  "id": "53b98181-60ad-4d84-8e9d-c6f940cb5e2d",
                  "version": "KqlParameterItem/1.0",
                  "name": "vWANConfigDrift",
                  "type": 1,
                  "query": "Resources\r\n| where type =~ \"microsoft.network/virtualwans\"\r\n| where resourceGroup in ({Resource_Group}) or '*' in ({Resource_Group})\r\n| summarize name = count()\r\n| project Message = strcat(name)\r\n",
                  "isHiddenWhenLocked": true,
                  "timeContext": {
                    "durationMs": 86400000
                  },
                  "queryType": 1,
                  "resourceType": "microsoft.resourcegraph/resources"
                },
                {
                  "id": "559f15d9-f0da-469e-9a94-8bbedaa28618",
                  "version": "KqlParameterItem/1.0",
                  "name": "SAPSubnetsNoNSG",
                  "type": 1,
                  "query": "Resources\r\n| where type =~ \"microsoft.network/virtualnetworks/subnets\"\r\n| extend nsg = tostring(properties.networkSecurityGroup.id)\r\n| where isempty(nsg)\r\n| where resourceGroup in ({Resource_Group}) or '*' in ({Resource_Group})\r\n| summarize name = count()\r\n| project Message = strcat(name)\r\n",
                  "crossComponentResources": [
                    "{Subscriptions}"
                  ],
                  "isHiddenWhenLocked": true,
                  "timeContext": {
                    "durationMs": 86400000
                  },
                  "queryType": 1,
                  "resourceType": "microsoft.resourcegraph/resources"
                },
                {
                  "id": "1aeb4357-85e5-4ffc-9f8c-523517652c7e",
                  "version": "KqlParameterItem/1.0",
                  "name": "InboundRDPAccess",
                  "type": 1,
                  "query": "Resources\r\n| where type =~ \"microsoft.network/networkinterfaces\"\r\n| extend ipConfigs = properties.ipConfigurations\r\n| mv-expand ipConfigs\r\n| extend publicIPId = tostring(ipConfigs.properties.publicIPAddress.id)\r\n| join kind=inner (\r\n    Resources\r\n    | where type =~ \"microsoft.network/publicIPAddresses\"\r\n    | extend ip = tostring(properties.ipAddress)\r\n    | where properties.ipAddress != ''\r\n) on $left.publicIPId == $right.id\r\n| where resourceGroup in ({Resource_Group}) or '*' in ({Resource_Group})\r\n| summarize name = count()\r\n| project Message = strcat(name)\r\n",
                  "crossComponentResources": [
                    "{Subscriptions}"
                  ],
                  "isHiddenWhenLocked": true,
                  "timeContext": {
                    "durationMs": 86400000
                  },
                  "queryType": 1,
                  "resourceType": "microsoft.resourcegraph/resources"
                },
                {
                  "id": "2d280d1b-3dff-4a1d-944d-240a7c6b317c",
                  "version": "KqlParameterItem/1.0",
                  "name": "GWSubnetMisconfigured",
                  "type": 1,
                  "query": "Resources\r\n| where type =~ \"microsoft.network/virtualnetworks/subnets\"\r\n| where name =~ \"GatewaySubnet\"\r\n| extend addressPrefix = tostring(properties.addressPrefix)\r\n| where resourceGroup in ({Resource_Group}) or '*' in ({Resource_Group})\r\n| summarize name = count()\r\n| project Message = strcat(name)",
                  "crossComponentResources": [
                    "{Subscriptions}"
                  ],
                  "isHiddenWhenLocked": true,
                  "timeContext": {
                    "durationMs": 86400000
                  },
                  "queryType": 1,
                  "resourceType": "microsoft.resourcegraph/resources"
                },
                {
                  "id": "38ade4de-7e21-4591-a67f-d77bf4ab78ec",
                  "version": "KqlParameterItem/1.0",
                  "name": "RouteTableConflict",
                  "type": 1,
                  "query": "Resources\r\n| where type =~ \"microsoft.network/routeTables\"\r\n| extend routes = properties.routes\r\n| mv-expand routes\r\n| extend destination = tostring(routes.properties.addressPrefix), nextHopType = tostring(routes.properties.nextHopType)\r\n| where resourceGroup in ({Resource_Group}) or '*' in ({Resource_Group})\r\n| summarize name = count()\r\n| project Message = strcat(name)",
                  "crossComponentResources": [
                    "{Subscriptions}"
                  ],
                  "isHiddenWhenLocked": true,
                  "timeContext": {
                    "durationMs": 86400000
                  },
                  "queryType": 1,
                  "resourceType": "microsoft.resourcegraph/resources"
                },
                {
                  "id": "499b7f5d-f710-4d51-8e28-330d2555ade7",
                  "version": "KqlParameterItem/1.0",
                  "name": "disconnected",
                  "type": 1,
                  "query": "Resources\r\n| where type =~ \"microsoft.network/virtualnetworks\"\r\n| where resourceGroup in~ ({Resource_Group}) or '*' in~ ({Resource_Group})\r\n| extend vnetName = name, vnetId = id, peerings = properties.virtualNetworkPeerings\r\n| mv-expand peerings\r\n| extend \r\n    peeringName = tostring(peerings.name),\r\n    remoteVnetId = tostring(peerings.properties.remoteVirtualNetwork.id),\r\n    peeringState = tostring(peerings.properties.peeringState),\r\n    allowForwardedTraffic = tostring(peerings.properties.allowForwardedTraffic),\r\n    allowGatewayTransit = tostring(peerings.properties.allowGatewayTransit),\r\n    useRemoteGateways = tostring(peerings.properties.useRemoteGateways),\r\n    provisioningState = tostring(peerings.properties.provisioningState)\r\n| extend \r\n    peeringSyncStatus = iff(peeringState == \"Connected\" and provisioningState != \"Succeeded\", \"Remote sync required\", \"Synced\")\r\n| project peeringState\r\n| summarize disconnected = countif(peeringState != \"Connected\")\r\n| project Message = strcat(disconnected)\r\n",
                  "crossComponentResources": [
                    "{Subscriptions}"
                  ],
                  "isHiddenWhenLocked": true,
                  "timeContext": {
                    "durationMs": 86400000
                  },
                  "queryType": 1,
                  "resourceType": "microsoft.resourcegraph/resources"
                },
                {
                  "id": "0a3ec27a-7d11-438f-b7f9-e0b6d91f4796",
                  "version": "KqlParameterItem/1.0",
                  "name": "connected",
                  "type": 1,
                  "query": "Resources\r\n| where type =~ \"microsoft.network/virtualnetworks\"\r\n| where resourceGroup in~ ({Resource_Group}) or '*' in~ ({Resource_Group})\r\n| extend vnetName = name, vnetId = id, peerings = properties.virtualNetworkPeerings\r\n| mv-expand peerings\r\n| extend \r\n    peeringName = tostring(peerings.name),\r\n    remoteVnetId = tostring(peerings.properties.remoteVirtualNetwork.id),\r\n    peeringState = tostring(peerings.properties.peeringState),\r\n    allowForwardedTraffic = tostring(peerings.properties.allowForwardedTraffic),\r\n    allowGatewayTransit = tostring(peerings.properties.allowGatewayTransit),\r\n    useRemoteGateways = tostring(peerings.properties.useRemoteGateways),\r\n    provisioningState = tostring(peerings.properties.provisioningState)\r\n| extend \r\n    peeringSyncStatus = iff(peeringState == \"Connected\" and provisioningState != \"Succeeded\", \"Remote sync required\", \"Synced\")\r\n| project peeringState\r\n| summarize connected = countif(peeringState == \"Connected\")\r\n| project Message = strcat(connected)",
                  "crossComponentResources": [
                    "{Subscriptions}"
                  ],
                  "isHiddenWhenLocked": true,
                  "timeContext": {
                    "durationMs": 86400000
                  },
                  "queryType": 1,
                  "resourceType": "microsoft.resourcegraph/resources"
                },
                {
                  "id": "6b116db0-f615-43fd-9e41-224f2eff3307",
                  "version": "KqlParameterItem/1.0",
                  "name": "BasicPublicIP",
                  "type": 1,
                  "query": "Resources\r\n| where type =~ \"Microsoft.Network/publicIPAddresses\"\r\n| where resourceGroup in ({Resource_Group}) or '*' in ({Resource_Group})\r\n| where sku.name =~ \"Basic\"\r\n| project name\r\n| summarize name = count()\r\n| project Message = strcat(name)",
                  "crossComponentResources": [
                    "{Subscriptions}"
                  ],
                  "isHiddenWhenLocked": true,
                  "queryType": 1,
                  "resourceType": "microsoft.resourcegraph/resources"
                },
                {
                  "id": "0cc5593d-6108-472d-816c-5ecc83a12f5e",
                  "version": "KqlParameterItem/1.0",
                  "name": "P_PublicIPStandardPercentage",
                  "type": 1,
                  "query": "resources\r\n| where type =~ \"microsoft.network/publicipaddresses\"\r\n| where resourceGroup in~ ({Resource_Group}) or '*' in ({Resource_Group})\r\n| summarize\r\n    TotalPIPs      = count(),\r\n    StandardPIPs   = countif(tostring(sku.name) =~ \"Standard\")\r\n| extend StandardPercent = iff(TotalPIPs > 0, round(100.0 * StandardPIPs / TotalPIPs, 2), 0.0)\r\n| project Message = strcat(tostring(StandardPercent), \"%\")\r\n",
                  "crossComponentResources": [
                    "{Subscriptions}"
                  ],
                  "isHiddenWhenLocked": true,
                  "queryType": 1,
                  "resourceType": "microsoft.resourcegraph/resources"
                }
              ],
              "style": "pills",
              "doNotRunWhenHidden": true,
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources"
            },
            "name": "parameters - Network Summary"
          },
          {
            "type": 1,
            "content": {
              "json": "<h2 style=\"color: Grey; text-align: center; font-family: 'Helvetica Neue', Arial, sans-serif; font-size: 20px; margin-top: 40px; margin-bottom: 10px; font-weight: bold;\">\r\n  Azure Key Network Configuration Checks\r\n</h2>\r\n<p style=\"text-align: center; font-family: 'Helvetica Neue', Arial, sans-serif; font-size: 14px; color: #2E3A59; margin-top: 0; margin-bottom: 15px;\">\r\n  Summary of key networking elements relevant to SAP deployment and operational readiness.\r\n</p>\r\n\r\n<table style=\"width: 100%; border-collapse: collapse; font-family: 'Helvetica Neue', Arial, sans-serif; margin: 20px auto; box-shadow: 0 2px 6px rgba(0, 0, 0, 0.15);\">\r\n  <colgroup>\r\n    <col style=\"width: 20%;\">\r\n    <col style=\"width: 80%;\">\r\n  </colgroup>\r\n  <thead style=\"background-color: #007BFF; color: white; font-size: 16px;\">\r\n    <tr>\r\n      <th style=\"padding: 12px; border: 1px solid #ccc; text-align: left;\">Item</th>\r\n      <th style=\"padding: 12px; border: 1px solid #ccc; text-align: left;\">Observation</th>\r\n    </tr>\r\n  </thead>\r\n  <tbody style=\"background-color: #f9f9f9; font-size: 14px;\">\r\n\r\n    <tr style=\"background-color:#f0f0f0;\">\r\n      <td style=\"padding:8px; border:1px solid #ccc;\">NET-001</td>\r\n      <td style=\"padding:8px; border:1px solid #ccc;\">\r\n        {ExpressRouteCount} ExpressRoute circuits configured and active for SAP connectivity.\r\n      </td>\r\n    </tr>\r\n\r\n    <tr>\r\n      <td style=\"padding:8px; border:1px solid #ccc;\">NET-002</td>\r\n      <td style=\"padding:8px; border:1px solid #ccc;\">\r\n        {ErGWBasicSKU} ExpressRoute Gateway(s) are still using Basic SKU Public IPs and need migration to Standard SKU.\r\n      </td>\r\n    </tr>\r\n\r\n    <tr style=\"background-color:#f0f0f0;\">\r\n      <td style=\"padding:8px; border:1px solid:#ccc;\">NET-003</td>\r\n      <td style=\"padding:8px; border:1px solid:#ccc;\">\r\n        {BasicPublicIP} Public IP with Basic SKU found; {P_PublicIPStandardPercentage} are Standard SKU.\r\n      </td>\r\n    </tr>\r\n\r\n    <tr>\r\n      <td style=\"padding:8px; border:1px solid:#ccc;\">NET-005</td>\r\n      <td style=\"padding:8px; border:1px solid:#ccc;\">\r\n        {ERGWRedundant} ExpressRoute Gateways are not deployed with active-active configuration.\r\n      </td>\r\n    </tr>\r\n\r\n    <tr style=\"background-color:#f0f0f0;\">\r\n      <td style=\"padding:8px; border:1px solid:#ccc;\">NET-006</td>\r\n      <td style=\"padding:8px; border:1px solid:#ccc;\">\r\n        {vWANConfigDrift} Azure vWAN configuration inconsistent across regions or VNet hubs.\r\n      </td>\r\n    </tr>\r\n\r\n    <tr>\r\n      <td style=\"padding:8px; border:1px solid:#ccc;\">NET-007</td>\r\n      <td style=\"padding:8px; border:1px solid:#ccc;\">\r\n        {SAPSubnetsNoNSG} SAP workload subnets detected without associated Network Security Groups.\r\n      </td>\r\n    </tr>\r\n\r\n    <tr style=\"background-color:#f0f0f0;\">\r\n      <td style=\"padding:8px; border:1px solid:#ccc;\">NET-008</td>\r\n      <td style=\"padding:8px; border:1px solid:#ccc;\">\r\n        {InboundRDPAccess} RDP or SSH access from open or public sources detected.\r\n      </td>\r\n    </tr>\r\n\r\n    <tr>\r\n      <td style=\"padding:8px; border:1px solid:#ccc;\">NET-009</td>\r\n      <td style=\"padding:8px; border:1px solid:#ccc;\">\r\n        {GWSubnetMisconfigured} GatewaySubnet missing or improperly sized in VNet used for ExpressRoute Gateway.\r\n      </td>\r\n    </tr>\r\n\r\n    <tr style=\"background-color:#f0f0f0;\">\r\n      <td style=\"padding:8px; border:1px solid:#ccc;\">NET-010</td>\r\n      <td style=\"padding:8px; border:1px solid:#ccc;\">\r\n        {RouteTableConflict} Conflicting UDRs found between SAP subnets and shared services.\r\n      </td>\r\n    </tr>\r\n\r\n    <tr>\r\n      <td style=\"padding:8px; border:1px solid:#ccc;\">NET-011</td>\r\n      <td style=\"padding:8px; border:1px solid:#ccc;\">\r\n        VNet peering connection state: {connected} connected, {disconnected} not connected.\r\n      </td>\r\n    </tr>\r\n\r\n  </tbody>\r\n</table>\r\n"
            },
            "conditionalVisibility": {
              "parameterName": "Dashboard",
              "comparison": "isEqualTo",
              "value": "Network"
            },
            "name": "Azure Network Summary"
          },
          {
            "type": 11,
