                      "parameterName": "SelectedTab",
                      "comparison": "isEqualTo",
                      "value": "storage"
                    },
                    {
                      "parameterName": "storage",
                      "comparison": "isEqualTo",
                      "value": "overview"
                    }
                  ],
                  "name": "query - Storage Overview"
                },
