                  "content": {
                    "version": "KqlItem/1.0",
                    "query": "resources\r\n| where type == \"microsoft.network/applicationgateways\"\r\n| extend \r\n    AppGWName = name,\r\n    backendPools = properties.backendAddressPools,\r\n    backendHttpSettings = properties.backendHttpSettingsCollection,\r\n    probes = properties.probes\r\n| mv-expand pool = backendPools\r\n| extend \r\n    BackendPoolName = tostring(pool.name),\r\n    backendAddresses = pool.properties.backendAddresses\r\n| mv-expand backendAddress = backendAddresses\r\n| extend \r\n    BackendHostName = tostring(backendAddress.ipAddress)\r\n| mv-expand setting = backendHttpSettings\r\n| extend \r\n    HttpSettingId = tostring(setting.id),\r\n    HttpSettingName = tostring(setting.name),\r\n    Port = toint(setting.properties.port),\r\n    Protocol = tostring(setting.properties.protocol),\r\n    ProvisioningState = tostring(setting.properties.provisioningState),\r\n    PickHostNameFromBackendAddress = tostring(setting.properties.pickHostNameFromBackendAddress),\r\n    CookieBasedAffinity = tostring(setting.properties.cookieBasedAffinity),\r\n    RequestTimeout = toint(setting.properties.requestTimeout),\r\n    ProbeRef = tostring(setting.properties.probe.id)\r\n| mv-expand probe = probes\r\n| extend \r\n    ProbeId = tostring(probe.id),\r\n    ProbeName = tostring(probe.name)\r\n| where isnull(ProbeRef) or ProbeRef == ProbeId\r\n| project \r\n    ProbeName,\r\n    ProvisioningState,\r\n    AppGWName,\r\n    BackendPoolName,\r\n    BackendHostName,\r\n    Port,\r\n    Protocol,\r\n    HttpSettingName,\r\n    PickHostNameFromBackendAddress,\r\n    CookieBasedAffinity,\r\n    RequestTimeout\r\n",
                    "size": 0,
                    "title": "AppGW Probe Configuration",
                    "showExportToExcel": true,
                    "exportToExcelOptions": "all",
                    "queryType": 1,
                    "resourceType": "microsoft.resourcegraph/resources",
                    "crossComponentResources": [
                      "{ApplicationGateway}"
                    ],
                    "gridSettings": {
                      "formatters": [
                        {
                          "columnMatch": "subscriptionId",
                          "formatter": 5
                        },
                        {
                          "columnMatch": "AppGWName",
                          "formatter": 5
                        },
                        {
                          "columnMatch": "protocol",
                          "formatter": 18,
                          "formatOptions": {
                            "thresholdsOptions": "icons",
                            "thresholdsGrid": [
                              {
                                "operator": "==",
                                "thresholdValue": "Https",
                                "representation": "Resolved",
                                "text": "{0}{1}"
                              },
