                            "linkIsContextBlade": true,
                            "showIcon": true,
                            "customColumnWidthSetting": "18ch"
                          }
                        },
                        {
                          "columnMatch": "provisioningState",
                          "formatter": 18,
                          "formatOptions": {
                            "thresholdsOptions": "icons",
                            "thresholdsGrid": [
                              {
