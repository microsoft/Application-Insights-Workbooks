                {
                  "id": "84bdb029-06e5-42e9-90a7-552f223598e4",
                  "version": "KqlParameterItem/1.0",
                  "name": "p_ZonalVMsPercentage",
                  "type": 1,
                  "query": "resources \r\n| where type =~ \"microsoft.compute/virtualmachines\"\r\n| where resourceGroup in ({Resource_Group}) or '*' in ({Resource_Group})\r\n| extend IsZonal = iff(isnotempty(zones), 1, 0)\r\n| summarize TotalVMs = count(), ZonalVMs = countif(IsZonal == 1)\r\n| extend ZonalVMsPercentage = strcat(round(todouble(ZonalVMs) * 100 / todouble(TotalVMs), 2),\"%\")\r\n| extend p_ZonalVMsPercentage = ZonalVMsPercentage  // Creates a parameter\r\n| project p_ZonalVMsPercentage\r\n",
                  "crossComponentResources": [
                    "{Subscriptions}"
                  ],
                  "isHiddenWhenLocked": true,
