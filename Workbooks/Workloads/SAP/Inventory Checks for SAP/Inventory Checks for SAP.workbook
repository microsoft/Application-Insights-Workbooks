          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "Resources\r\n| where type =~ 'microsoft.network/expressroutecircuits'\r\n| where resourceGroup in~ ({Resource_Group}) or '*' in~ ({Resource_Group})\r\n| project \r\n    id,\r\n      SKUName = tostring(sku.name),\r\n    SKUTier = tostring(sku.tier),\r\n    SKUMeter = tostring(sku.family),\r\n    ServiceProviderName = tostring(properties.serviceProviderProperties.serviceProviderName),\r\n    BandwidthInMbps = toint(properties.serviceProviderProperties.bandwidthInMbps),\r\n    PeeringLocation = tostring(properties.serviceProviderProperties.peeringLocation),\r\n      type = tostring(split(type, \"/\")[1]),\r\n    resourceGroup,\r\n    location\r\n",
              "size": 0,
              "title": "{ExpressRouteCount} Number of ExpressRoute Circuits found",
              "noDataMessage": "No ExpressRoute Circuit found in selection",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "gridSettings": {
                "filter": true,
                "sortBy": [
                  {
                    "itemKey": "type",
                    "sortOrder": 2
                  }
                ]
              },
              "sortBy": [
                {
                  "itemKey": "type",
                  "sortOrder": 2
                }
              ]
            },
            "conditionalVisibility": {
              "parameterName": "SelectedTab",
              "comparison": "isEqualTo",
              "value": "NET-001"
            },
            "name": "query - ExpressRoute Circuit"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "Resources\r\n| where type =~ \"microsoft.network/virtualnetworkgateways\"\r\n| where resourceGroup in~ ({Resource_Group}) or '*' in~ ({Resource_Group})\r\n| where tostring(properties.gatewayType) == \"ExpressRoute\"\r\n| extend ipConfig = properties.ipConfigurations\r\n| mv-expand ipConfig\r\n| extend publicIpId = tostring(ipConfig.properties.publicIPAddress.id)\r\n| join kind=leftouter (\r\n    Resources\r\n    | where type =~ \"microsoft.network/publicipaddresses\"\r\n    | where resourceGroup in~ ({Resource_Group}) or '*' in~ ({Resource_Group})\r\n    | project publicIpId = tolower(id), sku = tostring(sku.name)\r\n) on publicIpId\r\n| where sku =~ \"Basic\"\r\n| project name, location, resourceGroup, publicIpId, sku",
              "size": 0,
              "title": "{ErGWBasicSKU} ExpressRoute Gateways using Basic SKU Public IPs",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ]
            },
            "conditionalVisibility": {
              "parameterName": "SelectedTab",
              "comparison": "isEqualTo",
              "value": "NET-002"
            },
            "name": "query - ExpressRoute Gateways using Basic SKU Public IPs"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "Resources\r\n| where type =~ \"Microsoft.Network/publicIPAddresses\"\r\n| where resourceGroup in ({Resource_Group}) or '*' in ({Resource_Group})\r\n| where sku.name =~ \"Basic\"\r\n| project subscriptionId, publicIPName = name,publicIPId = id, sku.name, ipAddress = properties.ipAddress, resourceGroup, location",
              "size": 0,
              "title": "{BasicPublicIP} PublicIP with Basic SKU found",
              "noDataMessage": "No PublicIP with Basic SKU found",
              "showExportToExcel": true,
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "subscriptionId",
                    "formatter": 5
                  },
                  {
                    "columnMatch": "publicIPName",
                    "formatter": 5
                  },
                  {
                    "columnMatch": "publicIPId",
                    "formatter": 13,
                    "formatOptions": {
                      "linkTarget": "Resource",
                      "linkIsContextBlade": true,
                      "showIcon": true
                    }
                  },
                  {
                    "columnMatch": "resourceGroup",
                    "formatter": 0,
                    "formatOptions": {
                      "customColumnWidthSetting": "35ch"
                    }
                  }
                ],
                "filter": true,
                "labelSettings": [
                  {
                    "columnId": "publicIPId",
                    "label": "Public IP Name"
                  },
                  {
                    "columnId": "sku_name",
                    "label": "SKU"
                  },
                  {
                    "columnId": "ipAddress",
                    "label": "IP Address"
                  },
                  {
                    "columnId": "resourceGroup",
                    "label": "Resource Group"
                  },
                  {
                    "columnId": "location",
                    "label": "Azure region"
                  }
                ]
              }
            },
            "conditionalVisibilities": [
              {
                "parameterName": "SelectedTab",
                "comparison": "isEqualTo",
                "value": "NET-003"
              },
              {
                "parameterName": "Expand_Summary",
                "comparison": "isEqualTo",
                "value": "Yes"
              }
            ],
            "name": "NET-003  BasicPublicIP",
            "styleSettings": {
              "showBorder": true
            }
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "Resources\r\n| where type =~ \"microsoft.network/networksecuritygroups\"\r\n| where resourceGroup in~ ({Resource_Group}) or '*' in~ ({Resource_Group})\r\n| extend rules = properties.securityRules\r\n| mv-expand rules\r\n| extend nsgName = name, portMatch = tostring(rules.properties.destinationPortRange)\r\n| where portMatch !in~ (\"3200\", \"3300\", \"443\", \"22\")\r\n| project nsgName, portMatch",
              "size": 0,
              "title": "NSG rules missing for SAP ports",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ]
            },
            "conditionalVisibility": {
              "parameterName": "SelectedTab",
              "comparison": "isEqualTo",
              "value": "NET-004"
            },
            "name": " NET-004: NSG rules missing for SAP ports"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "Resources\r\n| where type =~ \"microsoft.network/virtualnetworkgateways\"\r\n| where resourceGroup in~ ({Resource_Group}) or '*' in~ ({Resource_Group})\r\n| where tostring(properties.gatewayType) == \"ExpressRoute\"\r\n| where properties.activeActive != true\r\n| project name, SKU=properties.sku.name, Tier=properties.sku.tier,location, resourceGroup, activeActive = properties.activeActive",
              "size": 0,
              "title": "ExpressRoute Gateways not in active-active config",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ]
            },
            "conditionalVisibility": {
              "parameterName": "SelectedTab",
              "comparison": "isEqualTo",
              "value": "NET-005"
            },
            "name": "NET-005: ExpressRoute Gateways not in active-active config"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "Resources\r\n| where type =~ \"microsoft.network/virtualwan\"\r\n| where resourceGroup in~ ({Resource_Group}) or '*' in~ ({Resource_Group})\r\n| project name, location, resourceGroup",
              "size": 0,
              "title": "NET-006: Azure vWAN configuration inconsistency",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ]
            },
            "conditionalVisibility": {
              "parameterName": "SelectedTab",
              "comparison": "isEqualTo",
              "value": "NET-006"
            },
            "name": "NET-006: Azure vWAN configuration inconsistency",
            "styleSettings": {
              "showBorder": true
            }
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "Resources\r\n| where type =~ \"microsoft.network/virtualnetworks/subnets\"\r\n| where resourceGroup in~ ({Resource_Group}) or '*' in~ ({Resource_Group})\r\n| where name contains \"sap\"\r\n| extend subnetName = name, hasNsg = isnotempty(properties.networkSecurityGroup.id)\r\n| where hasNsg == false\r\n| project subnetName, resourceGroup, id",
              "size": 0,
              "title": "SAP subnets without associated NSGs",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ]
            },
            "conditionalVisibility": {
              "parameterName": "SelectedTab",
              "comparison": "isEqualTo",
              "value": "NET-007"
            },
            "name": "NET-007: SAP subnets without associated NSGs",
            "styleSettings": {
              "showBorder": true
            }
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "Resources\r\n| where type =~ \"microsoft.network/networksecuritygroups\"\r\n| where resourceGroup in~ ({Resource_Group}) or '*' in~ ({Resource_Group})\r\n| extend rules = properties.securityRules\r\n| mv-expand rules\r\n| extend proto = tostring(rules.properties.protocol), src = tostring(rules.properties.sourceAddressPrefix), port = tostring(rules.properties.destinationPortRange), ruleName = tostring(rules.name)\r\n| where proto in~ (\"Tcp\") and port in~ (\"22\", \"3389\") and src in~ (\"*\", \"0.0.0.0/0\")\r\n| project nsgName = name, ruleName, port, src",
              "size": 0,
              "title": "NET-008: RDP or SSH public access",
              "showExportToExcel": true,
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ]
            },
            "conditionalVisibility": {
              "parameterName": "SelectedTab",
              "comparison": "isEqualTo",
              "value": "NET-008"
            },
            "name": "NET-008: RDP or SSH public access",
            "styleSettings": {
              "showBorder": true
            }
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "Resources\r\n| where type =~ \"microsoft.network/virtualnetworks/subnets\"\r\n| where resourceGroup in~ ({Resource_Group}) or '*' in~ ({Resource_Group})\r\n| where name == \"GatewaySubnet\"\r\n| extend subnetName = name, addressPrefix = tostring(properties.addressPrefix)\r\n| where isnull(addressPrefix) or addressPrefix !has \"/27\" and addressPrefix !has \"/28\"\r\n| project subnetName, resourceGroup, addressPrefix",
              "size": 0,
              "title": "NET-009: GatewaySubnet missing or improperly sized",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ]
            },
            "conditionalVisibility": {
              "parameterName": "SelectedTab",
              "comparison": "isEqualTo",
              "value": "NET-009"
            },
            "name": "NET-009: GatewaySubnet missing or improperly sized"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "Resources\r\n| where type =~ \"microsoft.network/routeTables\"\r\n| where resourceGroup in~ ({Resource_Group}) or '*' in~ ({Resource_Group})\r\n| extend routes = properties.routes\r\n| mv-expand routes\r\n| extend nextHopType = tostring(routes.nextHopType), addressPrefix = tostring(routes.addressPrefix)\r\n| where addressPrefix contains \"sap\" and nextHopType == \"VirtualAppliance\"\r\n| project routeTable = name, addressPrefix, nextHopType",
              "size": 0,
              "title": "NET-010: Conflicting UDRs on SAP subnets",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ]
            },
            "conditionalVisibility": {
              "parameterName": "SelectedTab",
              "comparison": "isEqualTo",
              "value": "NET-010"
            },
            "name": "NET-010: Conflicting UDRs on SAP subnets",
            "styleSettings": {
              "showBorder": true
            }
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "Resources\r\n| where type =~ \"microsoft.network/virtualnetworks\"\r\n| where resourceGroup in~ ({Resource_Group}) or '*' in~ ({Resource_Group})\r\n| extend vnetName = name, vnetId = id, peerings = properties.virtualNetworkPeerings\r\n| mv-expand peerings\r\n| extend \r\n    peeringName = tostring(peerings.name),\r\n    remoteVnetId = tostring(peerings.properties.remoteVirtualNetwork.id),\r\n    peeringState = tostring(peerings.properties.peeringState),\r\n    allowForwardedTraffic = tostring(peerings.properties.allowForwardedTraffic),\r\n    allowGatewayTransit = tostring(peerings.properties.allowGatewayTransit),\r\n    useRemoteGateways = tostring(peerings.properties.useRemoteGateways),\r\n    provisioningState = tostring(peerings.properties.provisioningState)\r\n| extend \r\n    peeringSyncStatus = iff(peeringState == \"Connected\" and provisioningState != \"Succeeded\", \"Remote sync required\", \"Synced\")\r\n| project\r\n    subscriptionId,\r\n    vnetName,\r\n    peeringName,\r\n    peeringState,\r\n    peeringSyncStatus,\r\n    remoteVnetId,\r\n    allowGatewayTransit,\r\n    useRemoteGateways,\r\n    allowForwardedTraffic,\r\n    resourceGroup,\r\n    location\r\n",
              "size": 0,
              "title": "Vnet Peering",
              "showExportToExcel": true,
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscriptions}"
              ],
