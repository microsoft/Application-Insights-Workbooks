                {
                  "id": "44f9dcaf-7860-4a1d-b33b-eccb2ba5d58d",
                  "version": "KqlParameterItem/1.0",
                  "name": "Genv1count",
                  "type": 1,
                  "query": "resources\r\n| where type =~ 'microsoft.compute/virtualmachines'\r\n| where resourceGroup in ({Resource_Group}) or '*' in ({Resource_Group})\r\n| extend osDiskId = tolower(tostring(properties.storageProfile.osDisk.managedDisk.id))\r\n| project vmSub = subscriptionId, vmRG = resourceGroup, vmName = name, vmLocation = location, osDiskId\r\n| join kind=leftouter (\r\n    Resources\r\n    | where type =~ 'microsoft.compute/disks'\r\n    | extend osDiskId = tolower(id)\r\n    | project osDiskId, hyperVGeneration = tostring(properties.hyperVGeneration)\r\n) on $left.osDiskId == $right.osDiskId\r\n| extend vmGeneration = case(\r\n    tolower(hyperVGeneration) == \"v2\", \"Gen2\",\r\n    tolower(hyperVGeneration) == \"v1\", \"Gen1\",\r\n    \"Unknown\"   // e.g., ephemeral OS disks with no managed OS disk to join\r\n)\r\n| where vmGeneration contains \"Gen1\"\r\n| summarize name = count()\r\n| project Message = strcat(name)",
                  "crossComponentResources": [
                    "{Subscriptions}"
                  ],
                  "isHiddenWhenLocked": true,
                  "timeContext": {
                    "durationMs": 86400000
                  },
                  "queryType": 1,
                  "resourceType": "microsoft.resourcegraph/resources"
                },
                {
                  "id": "68fbcca0-8d00-41ce-8d73-e4fddd85ef4f",
                  "version": "KqlParameterItem/1.0",
                  "name": "Genv2count",
                  "type": 1,
                  "query": "resources\r\n| where type =~ 'microsoft.compute/virtualmachines'\r\n| where resourceGroup in ({Resource_Group}) or '*' in ({Resource_Group})\r\n| extend osDiskId = tolower(tostring(properties.storageProfile.osDisk.managedDisk.id))\r\n| project vmSub = subscriptionId, vmRG = resourceGroup, vmName = name, vmLocation = location, osDiskId\r\n| join kind=leftouter (\r\n    Resources\r\n    | where type =~ 'microsoft.compute/disks'\r\n    | extend osDiskId = tolower(id)\r\n    | project osDiskId, hyperVGeneration = tostring(properties.hyperVGeneration)\r\n) on $left.osDiskId == $right.osDiskId\r\n| extend vmGeneration = case(\r\n    tolower(hyperVGeneration) == \"v2\", \"Gen2\",\r\n    tolower(hyperVGeneration) == \"v1\", \"Gen1\",\r\n    \"Unknown\"   // e.g., ephemeral OS disks with no managed OS disk to join\r\n)\r\n| where vmGeneration contains \"Gen2\"\r\n| summarize name = count()\r\n| project Message = strcat(name)",
                  "crossComponentResources": [
                    "{Subscriptions}"
                  ],
                  "isHiddenWhenLocked": true,
                  "timeContext": {
                    "durationMs": 86400000
                  },
                  "queryType": 1,
                  "resourceType": "microsoft.resourcegraph/resources"
                },
                {
                  "id": "edbb7b50-c617-4660-8514-527da977a29f",
                  "version": "KqlParameterItem/1.0",
                  "name": "p_Genv1Percentage",
                  "type": 1,
                  "query": "resources\r\n| where type =~ \"microsoft.compute/virtualmachines\"\r\n| where '*' in ({Resource_Group}) or resourceGroup in~ ({Resource_Group})\r\n| extend osDiskId = tolower(tostring(properties.storageProfile.osDisk.managedDisk.id))\r\n| join kind=leftouter (\r\n    resources\r\n    | where type =~ \"microsoft.compute/disks\"\r\n    | extend osDiskId = tolower(id)\r\n    | project osDiskId, hyperVGeneration = tostring(properties.hyperVGeneration)\r\n) on $left.osDiskId == $right.osDiskId\r\n| extend vmGeneration = case(\r\n    tolower(hyperVGeneration) == \"v2\",\"Gen2\",\r\n    tolower(hyperVGeneration) == \"v1\",\"Gen1\",\r\n    \"Unknown\"\r\n)\r\n| summarize\r\n    TotalVMs = count(),\r\n    Gen1VMs  = countif(vmGeneration == \"Gen1\"),\r\n    Gen2VMs  = countif(vmGeneration == \"Gen2\"),\r\n    UnknownVMs = countif(vmGeneration == \"Unknown\")\r\n| extend Gen1VMsPercent = iff(TotalVMs == 0, 0.0, 100.0 * todouble(Gen1VMs) / todouble(TotalVMs))\r\n| project p_Gen1VMsPercentage = strcat(tostring(round(Gen1VMsPercent, 2)), \"%\")\r\n",
                  "crossComponentResources": [
                    "{Subscriptions}"
                  ],
                  "isHiddenWhenLocked": true,
                  "timeContext": {
                    "durationMs": 86400000
                  },
                  "queryType": 1,
                  "resourceType": "microsoft.resourcegraph/resources"
                },
                {
                  "version": "KqlParameterItem/1.0",
                  "name": "AppGW1Count",
                  "type": 1,
                  "query": "resources\r\n| where type =~ \"microsoft.network/applicationgateways\"\r\n| where resourceGroup in~ ({Resource_Group}) or '*' in ({Resource_Group})\r\n| extend tier = tostring(properties.sku.tier)              // e.g., Standard, WAF, Standard_v2, WAF_v2\r\n| extend Version = iif(tolower(tier) contains \"_v2\", \"v2\", \"v1\")\r\n| where Version == \"v1\"\r\n| summarize v1Count = count()\r\n| project Message = strcat(v1Count)",
                  "crossComponentResources": [
