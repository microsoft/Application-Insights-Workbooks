                {
                  "version": "KqlParameterItem/1.0",
                  "name": "TotalAppGWs",
                  "type": 1,
                  "query": "resources\r\n| where type =~ \"microsoft.network/applicationgateways\"\r\n| where resourceGroup in~ ({Resource_Group}) or '*' in ({Resource_Group})\r\n| summarize TotalAppGWs = count()\r\n| project Message = strcat(tostring(TotalAppGWs))\r\n",
                  "crossComponentResources": [
