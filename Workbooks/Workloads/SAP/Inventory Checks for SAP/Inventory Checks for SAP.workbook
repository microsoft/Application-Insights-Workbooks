                {
                  "id": "5c7924ef-d1d1-4682-8f88-8857f413c9f7",
                  "version": "KqlParameterItem/1.0",
                  "name": "AppGw_Count",
                  "type": 1,
                  "query": "resources\r\n| where type == \"microsoft.network/applicationgateways\"\r\n| where resourceGroup in ({Resource_Group}) or '*' in ({Resource_Group})\r\n| summarize name = count()\r\n| project Message = strcat(name)",
                  "crossComponentResources": [
