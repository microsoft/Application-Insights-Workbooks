nts | distinct operation_Id | extend HasAgentMatch = 1) on operation_Id\r\n| where \"{SelectedAgent}\" == \"__ALL__\" or HasAgentMatch == 1\r\n| summarize Num = count()\r\n| project HasResults = iff(Num > 0, \"true\", \"false\")",
