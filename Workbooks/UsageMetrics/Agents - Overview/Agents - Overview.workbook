        "title": "Foundry Recommendations",
        "items": [
          {
            "type": "microsoft.insights.foundryAnomalies",
            "name": "Foundry Anomalies - 0",
            "content": {
              "version": "FoundryAnomaliesStep/1.0",
              "query": "{\"version\":\"FoundryAnomaliesQueryProvider/1.0\",\"numResults\":3}",
              "crossComponentResources": [
                "{ResourceId}"
              ],
              "title": "",
