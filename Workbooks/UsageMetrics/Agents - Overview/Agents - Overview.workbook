                "comparison": "isEqualTo",
                "value": "NotFound"
              }
            ],
            "name": "evaluationsNoData",
            "styleSettings": {
              "margin": "10px 0 0 0"
            }
          }
        ]
      },
      "name": "DashboardTab",
      "conditionalVisibilities": [
        {
