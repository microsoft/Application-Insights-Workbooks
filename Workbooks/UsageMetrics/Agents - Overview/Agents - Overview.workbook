                  {
                    "columnId": "Total Tokens",
                    "label": "Total tokens"
                  },
                  {
                    "columnId": "Duration (ms)",
                    "label": "Duration"
                  }
                ]
              },
              "sortBy": []
            },
            "name": "traceLevelCost",
            "styleSettings": {
              "showBorder": true,
              "borderStyle": "rounded shadow",
              "x": 0,
              "y": 15,
              "w": 24,
              "h": 7,
              "margin": "4px",
              "padding": "0"
            }
          }
        ],
        "layout": {
          "type": "grid"
