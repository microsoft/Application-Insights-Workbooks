          {
            "type": 12,
            "content": {
              "version": "NotebookGroup/1.0",
              "groupType": "editable",
              "title": "Evaluations",
              "expandable": true,
              "expanded": true,
              "items": [
                {
                  "type": 1,
                  "content": {
                    "json": "<div style=\"text-align:left;padding: 0 40px;\">\r\n   <h1>Get started with evaluations for AI Agents</h1>\r\n   <p>Get insights into the ongoing performance of how your Generative AI applications work in production.</p>\r\n   <a href=\"https://aka.ms/app-insights/agents-getstarted-evaluations\" target=\"_blank\">Learn how to get started</a>\r\n</div>\r\n<div style=\"text-align:left;margin-top:80px;padding: 0 40px 40px;\">\r\n   Already set up?<br/>There may be no recent activity. Select a different time range at the top of the page.\r\n</div>"
                  },
                  "name": "EvaluationsNotFoundText"
                }
              ]
            },
            "conditionalVisibilities": [
              {
                "parameterName": "GenAIDataCheck",
                "comparison": "isNotEqualTo",
                "value": "NotFound"
              },
              {
                "parameterName": "EvaluationDataCheck",
                "comparison": "isEqualTo",
                "value": "NotFound"
              }
            ],
            "name": "evaluationsNoData",
            "styleSettings": {
              "margin": "10px 0 0 0"
            }
          }
        ]
      },
      "name": "DashboardTab",
      "conditionalVisibilities": [
