                        "content": {
                          "version": "KqlParameterItem/1.0",
                          "parameters": [
                            {
                              "id": "df51ece0-c8c7-4626-895c-6194406c98bd",
                              "version": "KqlParameterItem/1.0",
                              "name": "Evaluator",
                              "type": 2,
