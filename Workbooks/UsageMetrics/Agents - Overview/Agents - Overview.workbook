                  },
                  "customWidth": "50",
                  "name": "EvaluationGroup2",
                  "styleSettings": {
                    "margin": "10px",
                    "padding": "10px 10px 0 10px",
                    "showBorder": true,
                    "borderStyle": "rounded shadow"
                  }
                },
                {
                  "type": 12,
                  "content": {
                    "version": "NotebookGroup/1.0",
                    "groupType": "editable",
                    "items": [
                      {
                        "type": 9,
                        "content": {
                          "version": "KqlParameterItem/1.0",
                          "parameters": [
                            {
                              "id": "a0ccbf0c-f3af-42fb-b6a6-bf516dbead2a",
                              "version": "KqlParameterItem/1.0",
                              "name": "Evaluator",
                              "type": 2,
                              "query": "let agents = dependencies\r\n| where customDimensions[\"gen_ai.operation.name\"] == \"invoke_agent\"\r\n| extend AgentName = tostring(customDimensions[\"gen_ai.agent.name\"]), AgentId=tostring(customDimensions[\"gen_ai.agent.id\"]);\r\ncustomEvents\r\n| where name == \"gen_ai.evaluation.result\"\r\n| extend Evaluator = tostring(customDimensions[\"gen_ai.evaluation.name\"])\r\n| extend AgentId = tostring(customDimensions[\"gen_ai.agent.id\"])\r\n| lookup (agents) on AgentId\r\n| where \"{SelectedAgent}\" == \"__ALL__\" or \"{SelectedAgent}\" == AgentName\r\n| distinct Evaluator\r\n| project value = Evaluator, display = Evaluator, is_selected = Evaluator == \"tool_call_accuracy\"",
                              "typeSettings": {
                                "additionalResourceOptions": [],
                                "showDefault": false
                              },
                              "timeContext": {
                                "durationMs": 0
                              },
                              "timeContextFromParameter": "TimeRange",
                              "queryType": 0,
                              "resourceType": "microsoft.insights/components",
                              "label": "Evaluation"
                            },
                            {
                              "id": "c28914cc-cdf0-4616-8dfa-96d6f26d5d85",
                              "version": "KqlParameterItem/1.0",
                              "name": "Threshold",
                              "type": 1,
                              "query": "let agents = dependencies\r\n| where customDimensions[\"gen_ai.operation.name\"] == \"invoke_agent\"\r\n| extend AgentName = tostring(customDimensions[\"gen_ai.agent.name\"]), AgentId=tostring(customDimensions[\"gen_ai.agent.id\"]);\r\ncustomEvents\r\n| where name == \"gen_ai.evaluation.result\"\r\n| where customDimensions[\"gen_ai.evaluation.name\"] == \"{Evaluator}\"\r\n| extend success = customDimensions[\"gen_ai.evaluation.score.label\"] == \"pass\"\r\n| extend AgentId = tostring(customDimensions[\"gen_ai.agent.id\"])\r\n| lookup (agents) on AgentId\r\n| where \"{SelectedAgent}\" == \"__ALL__\" or \"{SelectedAgent}\" == AgentName\r\n| extend InternalProperties = todynamic(tostring(customDimensions.internal_properties))\r\n| project timestamp,\r\n    Evaluator = tostring(customDimensions[\"gen_ai.evaluation.name\"]),\r\n    Score = todouble(customDimensions[\"gen_ai.evaluation.score.value\"]),\r\n    Label = tostring(customDimensions[\"gen_ai.evaluation.score.label\"]),\r\n    Threshold = todouble(InternalProperties[\"gen_ai.evaluation.threshold\"]),\r\n    Min = todouble(InternalProperties[\"gen_ai.evaluation.min_value\"]),\r\n    Max = todouble(InternalProperties[\"gen_ai.evaluation.max_value\"]),\r\n    Error = tostring(customDimensions[\"error.type\"])\r\n| order by timestamp desc\r\n| where isnotempty(Threshold)\r\n| project Threshold\r\n| take 1",
                              "isHiddenWhenLocked": true,
                              "timeContext": {
                                "durationMs": 2592000000
                              },
                              "timeContextFromParameter": "TimeRange",
                              "queryType": 0,
                              "resourceType": "microsoft.insights/components"
                            },
                            {
                              "id": "f4d34de3-25ef-4472-b74a-1f2b06d93336",
                              "version": "KqlParameterItem/1.0",
                              "name": "EvaluationCardSearchParameters3",
                              "type": 1,
                              "isHiddenWhenLocked": true,
                              "query": "let effectiveEvaluator = iff(\"{Evaluator}\" == \"\", \"tool_call_accuracy\", \"{Evaluator}\");\r\nlet invokeAgents = materialize(\r\ndependencies\r\n| where customDimensions[\"gen_ai.operation.name\"] == \"invoke_agent\"\r\n| extend\r\n    AgentName = tostring(customDimensions[\"gen_ai.agent.name\"]),\r\n    AgentId = tostring(customDimensions[\"gen_ai.agent.id\"]),\r\n    operation_Id = tostring(operation_Id)\r\n| where \"{SelectedAgent}\" == \"__ALL__\" or AgentName == \"{SelectedAgent}\"\r\n| where isnotempty(operation_Id)\r\n| project operation_Id, invokeTs = timestamp, AgentId, AgentName, spanId = id\r\n);\r\n\r\nlet responseOps = materialize(\r\nunion isfuzzy=true dependencies, customEvents\r\n| extend\r\n    responseId = tostring(customDimensions[\"gen_ai.response.id\"]),\r\n    operation_Id = tostring(operation_Id)\r\n| where isnotempty(responseId) and isnotempty(operation_Id)\r\n| summarize arg_max(timestamp, operation_Id) by responseId\r\n| project responseId, responseOperationId = operation_Id\r\n);\r\n\r\nlet evalBase = materialize(\r\ncustomEvents\r\n| where name == \"gen_ai.evaluation.result\"\r\n| where tostring(customDimensions[\"gen_ai.evaluation.name\"]) == effectiveEvaluator\r\n| extend EventOperationIdRaw = tostring(operation_Id)\r\n| extend EventOperationId = EventOperationIdRaw\r\n| extend responseId = tostring(customDimensions[\"gen_ai.response.id\"])\r\n| extend EvalAgentId = tostring(customDimensions[\"gen_ai.agent.id\"])\r\n| project itemId, evalTs = timestamp, EventOperationId, responseId, EvalAgentId, parentId = tostring(operation_ParentId)\r\n);\r\n\r\nlet responseCorrelatedOps =\r\nevalBase\r\n| where isnotempty(responseId)\r\n| join kind=inner (responseOps) on responseId\r\n| summarize Latest = max(evalTs) by operation_Id = responseOperationId;\r\n\r\nlet parentCorrelatedOps =\r\nevalBase\r\n| where isnotempty(parentId)\r\n| join kind=inner (invokeAgents | project spanId, operation_Id) on $left.parentId == $right.spanId\r\n| summarize Latest = max(evalTs) by operation_Id;\r\n\r\nunion responseCorrelatedOps, parentCorrelatedOps\r\n| summarize Latest = max(Latest) by operation_Id\r\n| join kind=leftouter (invokeAgents | distinct operation_Id | extend HasAgentMatch = 1) on operation_Id\r\n| where \"{SelectedAgent}\" == \"__ALL__\" or HasAgentMatch == 1\r\n| order by Latest desc\r\n| take 300\r\n| summarize Num = count(), OpIds = make_list(operation_Id)\r\n| extend BaseFilter = iff(\r\n    \"{SelectedAgent}\" != \"__ALL__\",\r\n    \"{         \\\"dimension\\\": {             \\\"name\\\": \\\"customDimensions/gen_ai.agent.name\\\",             \\\"draftKey\\\": \\\"customDimensions/gen_ai.agent.name\\\",             \\\"displayName\\\": \\\"Agent name\\\",             \\\"tables\\\": [               \\\"dependencies\\\"             ]           },           \\\"values\\\": [             \\\"{SelectedAgent}\\\"           ]         }\",\r\n    \"{         \\\"dimension\\\": {             \\\"name\\\": \\\"customDimensions/gen_ai.operation.name\\\",             \\\"draftKey\\\": \\\"customDimensions/gen_ai.operation.name\\\",             \\\"displayName\\\": \\\"GenAI Operation\\\",             \\\"tables\\\": [               \\\"dependencies\\\"             ]           },           \\\"values\\\": [             \\\"invoke_agent\\\"           ]         }\"\r\n)\r\n| extend OpFilter = iff(Num > 0, strcat(\r\n        \", {          \\\"dimension\\\": {              \\\"displayName\\\": \\\"Operation Id\\\",              \\\"tables\\\": [                  \\\"dependencies\\\"              ],              \\\"name\\\": \\\"operation/id\\\",              \\\"draftKey\\\": \\\"operation/id\\\"          },          \\\"values\\\":\",\r\n        OpIds,\r\n        \"}\"\r\n), \"\")\r\n| project BladeJson = strcat(\r\n    \"{   \\\"ResourceId\\\": \\\"{ResourceId:id}\\\", \\\"HideChart\\\": true, \\\"IsGenAiFlow\\\": true,   \\\"FilterSpec\\\": {     \\\"originalParams\\\": {       \\\"sort\\\": \\\"evaluationsAsc\\\",       \\\"timeContext\\\": {         \\\"durationMs\\\": \\\"{TimeRange:seconds}000\\\",         \\\"endTime\\\": \\\"{TimeRange:endISO}\\\",         \\\"createdTime\\\": \\\"{TimeRange:startISO}\\\",         \\\"isInitialTime\\\": false,         \\\"grain\\\": 1,         \\\"useDashboardTimeRange\\\": false       },       \\\"filter\\\": [\",\r\n    BaseFilter,\r\n    OpFilter,\r\n    \"],       \\\"searchPhrase\\\": {         \\\"originalPhrase\\\": \\\"\\\"       }     }   } }\"\r\n)",
                              "timeContext": {
                                "durationMs": 0
                              },
                              "timeContextFromParameter": "TimeRange",
                              "queryType": 0,
                              "resourceType": "microsoft.insights/components"
                            },
                            {
                              "id": "89654005-48ef-4b1c-ab8b-69a17c534e81",
                              "version": "KqlParameterItem/1.0",
                              "name": "EvaluationCardHasResults3",
                              "type": 1,
                              "isHiddenWhenLocked": true,
                              "query": "let effectiveEvaluator = iff(\"{Evaluator}\" == \"\", \"tool_call_accuracy\", \"{Evaluator}\");\r\nlet invokeAgents = materialize(\r\ndependencies\r\n| where customDimensions[\"gen_ai.operation.name\"] == \"invoke_agent\"\r\n| extend\r\n    AgentName = tostring(customDimensions[\"gen_ai.agent.name\"]),\r\n    AgentId = tostring(customDimensions[\"gen_ai.agent.id\"]),\r\n    operation_Id = tostring(operation_Id)\r\n| where \"{SelectedAgent}\" == \"__ALL__\" or AgentName == \"{SelectedAgent}\"\r\n| where isnotempty(operation_Id)\r\n| project operation_Id, invokeTs = timestamp, AgentId, AgentName, spanId = id\r\n);\r\n\r\nlet responseOps = materialize(\r\nunion isfuzzy=true dependencies, customEvents\r\n| extend\r\n    responseId = tostring(customDimensions[\"gen_ai.response.id\"]),\r\n    operation_Id = tostring(operation_Id)\r\n| where isnotempty(responseId) and isnotempty(operation_Id)\r\n| summarize arg_max(timestamp, operation_Id) by responseId\r\n| project responseId, responseOperationId = operation_Id\r\n);\r\n\r\nlet evalBase = materialize(\r\ncustomEvents\r\n| where name == \"gen_ai.evaluation.result\"\r\n| where tostring(customDimensions[\"gen_ai.evaluation.name\"]) == effectiveEvaluator\r\n| extend responseId = tostring(customDimensions[\"gen_ai.response.id\"])\r\n| project evalTs = timestamp, responseId, parentId = tostring(operation_ParentId)\r\n);\r\n\r\nlet responseCorrelatedOps =\r\nevalBase\r\n| where isnotempty(responseId)\r\n| join kind=inner (responseOps) on responseId\r\n| summarize Latest = max(evalTs) by operation_Id = responseOperationId;\r\n\r\nlet parentCorrelatedOps =\r\nevalBase\r\n| where isnotempty(parentId)\r\n| join kind=inner (invokeAgents | project spanId, operation_Id) on $left.parentId == $right.spanId\r\n| summarize Latest = max(evalTs) by operation_Id;\r\n\r\nunion responseCorrelatedOps, parentCorrelatedOps\r\n| summarize Latest = max(Latest) by operation_Id\r\n| join kind=leftouter (invokeAgents | distinct operation_Id | extend HasAgentMatch = 1) on operation_Id\r\n| where \"{SelectedAgent}\" == \"__ALL__\" or HasAgentMatch == 1\r\n| summarize Num = count()\r\n| project HasResults = iff(Num > 0, \"true\", \"false\")",
                              "timeContext": {
                                "durationMs": 0
                              },
                              "timeContextFromParameter": "TimeRange",
                              "queryType": 0,
                              "resourceType": "microsoft.insights/components"
                            }
                          ],
                          "style": "formHorizontal"
                        },
                        "customWidth": "70",
                        "name": "EvaluationParameters3"
                      },
                      {
                        "type": 3,
                        "content": {
                          "version": "KqlItem/1.0",
                          "query": "let agents = dependencies\r\n| where customDimensions[\"gen_ai.operation.name\"] == \"invoke_agent\"\r\n| extend AgentName = tostring(customDimensions[\"gen_ai.agent.name\"]), AgentId=tostring(customDimensions[\"gen_ai.agent.id\"]);\r\ncustomEvents\r\n| where name == \"gen_ai.evaluation.result\"\r\n| where customDimensions[\"gen_ai.evaluation.name\"] == \"{Evaluator}\"\r\n| extend success = customDimensions[\"gen_ai.evaluation.score.label\"] == \"pass\"\r\n| extend AgentId = tostring(customDimensions[\"gen_ai.agent.id\"])\r\n| lookup (agents) on AgentId\r\n| where \"{SelectedAgent}\" == \"__ALL__\" or \"{SelectedAgent}\" == AgentName\r\n| extend InternalProperties = todynamic(tostring(customDimensions.internal_properties))\r\n| project timestamp,\r\n    //Evaluator = tostring(customDimensions[\"gen_ai.evaluation.name\"]),\r\n    Score = todouble(customDimensions[\"gen_ai.evaluation.score.value\"]),\r\n    Label = tostring(customDimensions[\"gen_ai.evaluation.score.label\"]),\r\n    //Threshold = todouble(InternalProperties[\"gen_ai.evaluation.threshold\"]),\r\n    //Min = todouble(InternalProperties[\"gen_ai.evaluation.min_value\"]),\r\n    //Max = todouble(InternalProperties[\"gen_ai.evaluation.max_value\"]),\r\n    Error = tostring(customDimensions[\"error.type\"])\r\n| extend Label = case(\r\n    isnotempty(Error), \"Errored\",\r\n    //Label == \"pass\", \"Pass\",\r\n    //Label == \"fail\", \"Fail\",\r\n    \"Run\")\r\n| project-away Error",
                          "size": 1,
                          "aggregation": 3,
                          "noDataMessage": "Pick an evaluation from the dropdown above",
                          "timeContextFromParameter": "TimeRange",
                          "queryType": 0,
                          "resourceType": "microsoft.insights/components",
                          "visualization": "scatterchart",
                          "chartSettings": {
                            "yAxis": [
                              "Score"
                            ],
                            "group": "Label",
                            "createOtherGroup": null,
                            "seriesLabelSettings": [
                              {
                                "seriesName": "Errored",
                                "label": "Score for Errored Runs",
                                "color": "purple"
                              },
                              {
                                "seriesName": "$_thresholdLine",
                                "label": "Threshold score",
                                "color": "red"
                              },
                              {
                                "seriesName": "Run",
                                "label": "Score",
                                "color": "blue"
                              }
                            ],
                            "customThresholdLine": "{Threshold}",
                            "customThresholdLineStyle": 5,
                            "xSettings": {
                              "label": ""
                            },
                            "ySettings": {
                              "numberFormatSettings": {
                                "unit": 0,
                                "options": {
                                  "style": "decimal",
                                  "useGrouping": true,
                                  "maximumFractionDigits": 2
                                }
                              },
                              "min": 0
                            }
                          },
                          "titleOptions": {
                            "titleActions": [
                              {
                                "id": "69ff2056-5e94-4a28-92db-49776a8c8b70",
                                "linkTarget": "OpenBlade",
                                "linkLabel": "View Traces",
                                "style": "secondary",
                                "linkIsContextBlade": true,
                                "bladeOpenContext": {
                                  "bladeName": "SearchV2Blade",
                                  "extensionName": "AppInsightsExtension",
                                  "bladeJsonParameters": "{EvaluationCardSearchParameters3}"
                                },
                                "conditionalVisibility": {
                                  "parameterName": "EvaluationCardHasResults3",
                                  "comparison": "isEqualTo",
                                  "value": "true"
                                }
                              }
                            ]
                          }
                        },
                        "name": "EvaluationQuery3"
                      }
                    ]
                  },
                  "customWidth": "50",
                  "name": "EvaluationGroup3",
                  "styleSettings": {
                    "margin": "10px",
                    "padding": "10px 10px 0 10px",
                    "showBorder": true,
                    "borderStyle": "rounded shadow"
                  }
                }
              ]
            },
            "conditionalVisibilities": [
              {
                "parameterName": "EvaluationDataCheck",
                "comparison": "isNotEqualTo",
                "value": "NotFound"
              },
              {
                "parameterName": "GenAIDataCheck",
                "comparison": "isNotEqualTo",
                "value": "NotFound"
              }
            ],
            "name": "evaluations",
            "styleSettings": {
              "margin": "10px 0 0 0",
              "showBorder": false,
              "borderStyle": "rounded shadow",
              "padding": "0"
            }
          },
          {
            "type": 12,
            "content": {
              "version": "NotebookGroup/1.0",
              "groupType": "editable",
              "title": "Evaluations",
              "expandable": true,
              "expanded": true,
              "items": [
                {
                  "type": 1,
                  "content": {
                    "json": "# Get started with evaluations for AI Agents\r\n\r\nGet insights into the ongoing performance of how your Generative AI applications work in production.\r\n\r\n<a href=\"https://aka.ms/app-insights/agents-getstarted-evaluations\" target=\"_blank\">Learn how to get started</a>\r\n\r\n### Already set up?\r\n\r\nThere may be no recent activity. Select a different time range at the top of the page.\r\n",
                    "title": "",
                    "headingLevel": 3
                  },
                  "name": "EvaluationsNotFoundText",
                  "styleSettings": {
                    "padding": "0 0 20px 0"
                  }
                }
              ]
            },
