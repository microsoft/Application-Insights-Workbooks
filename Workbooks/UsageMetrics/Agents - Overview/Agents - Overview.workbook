      },
      "name": "CostTab",
      "conditionalVisibilities": [
        {
          "parameterName": "selectedTab",
          "comparison": "isEqualTo",
          "value": "Cost"
        },
        {
          "parameterName": "GenAIDataCheck",
          "comparison": "isNotEqualTo",
