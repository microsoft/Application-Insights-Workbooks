                                  "value": "true"
                                }
                              ],
                              "templateId": "Community-Workbooks/UsageMetrics/Agents - Overview",
                              "viewMode": "viewer"
                            }
                          }
                        },
                        {
                          "columnMatch": "Errors",
                          "formatter": 1,
                          "numberFormat": {
                            "unit": 17,
                            "options": {
                              "style": "decimal",
                              "maximumFractionDigits": 0
                            }
                          }
                        },
                        {
                          "columnMatch": "Tokens",
                          "formatter": 1,
                          "numberFormat": {
                            "unit": 17,
                            "options": {
                              "style": "decimal",
                              "useGrouping": true,
                              "maximumFractionDigits": 0
                            }
                          }
                        },
                        {
                          "columnMatch": "Link",
                          "formatter": 5
                        },
                        {
                          "columnMatch": "AgentName",
                          "formatter": 5
