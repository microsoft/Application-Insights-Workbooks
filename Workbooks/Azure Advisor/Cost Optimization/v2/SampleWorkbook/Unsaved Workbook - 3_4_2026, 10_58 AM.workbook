{
  "version": "Notebook/1.0",
  "items": [
    {
      "type": 9,
      "content": {
        "version": "KqlParameterItem/1.0",
        "parameters": [
          {
            "id": "93d543f4-8f2d-4a8d-a793-ef0f90f486df",
            "version": "KqlParameterItem/1.0",
            "name": "Subscription",
            "type": 6,
            "isRequired": true,
            "multiSelect": true,
            "quote": "'",
            "delimiter": ",",
            "typeSettings": {
              "additionalResourceOptions": [
                "value::all"
              ],
              "includeAll": false,
              "showDefault": false
            },
            "timeContext": {
              "durationMs": 86400000
            },
            "defaultValue": "value::all",
            "label": " Subscription",
            "value": [
              "value::all"
            ]
          },
          {
            "id": "267dfdc1-32f2-4fc8-8046-93982529750c",
            "version": "KqlParameterItem/1.0",
            "name": "ResourceGroup",
            "label": "Resource Group",
            "type": 2,
            "isRequired": true,
            "multiSelect": true,
            "quote": "'",
            "delimiter": ",",
            "query": "resources\r\n| distinct resourceGroup",
            "crossComponentResources": [
              "{Subscription}"
            ],
            "typeSettings": {
              "additionalResourceOptions": [
                "value::all"
              ],
              "showDefault": false
            },
            "defaultValue": "value::all",
            "queryType": 1,
            "resourceType": "microsoft.resourcegraph/resources"
          },
          {
            "id": "d6478aae-5fd7-4986-9179-b639769bb53e",
            "version": "KqlParameterItem/1.0",
            "name": "SingleSubHidden",
            "type": 1,
            "isRequired": true,
            "query": "resourcecontainers\r\n| where type==\"microsoft.resources/subscriptions\"\r\n| take 1\r\n| project subscriptionId",
            "crossComponentResources": [
              "{Subscription}"
            ],
            "isHiddenWhenLocked": true,
            "queryType": 1,
            "resourceType": "microsoft.resourcegraph/resources",
            "label": "Hidden Subscription"
          },
          {
            "id": "7b80f35b-df7a-4c25-aacb-74145146ecb5",
            "version": "KqlParameterItem/1.0",
            "name": "ServiceGroup",
            "type": 2,
            "query": "resourcecontainers\r\n| where type == 'microsoft.management/servicegroups'\r\n| project value=id, label=name\r\n| order by label asc",
            "crossComponentResources": [
              "{Subscription}"
            ],
            "typeSettings": {
              "additionalResourceOptions": []
            },
            "queryType": 1,
            "resourceType": "microsoft.resourcegraph/resources",
            "value": null,
            "label": "Service Group"
          },
          {
            "id": "ca8cbe71-8a49-46be-a8c8-e8cc15c2e0e9",
            "version": "KqlParameterItem/1.0",
            "name": "TagName",
            "type": 2,
            "query": "Resources\r\n| where tags != '' and tags != '[]'\r\n| mvexpand tags\r\n| extend tagName = tostring(bag_keys(tags)[0])\r\n| distinct tagName\r\n| sort by tagName asc",
            "crossComponentResources": [
              "{Subscription}"
            ],
            "typeSettings": {
              "additionalResourceOptions": []
            },
            "queryType": 1,
            "resourceType": "microsoft.resourcegraph/resources",
            "value": null,
            "label": "Tag Name"
          },
          {
            "id": "823ab53f-2c93-49bb-8c5d-e63391f2f45e",
            "version": "KqlParameterItem/1.0",
            "name": "TagValue",
            "type": 2,
            "query": "Resources\r\n| mvexpand tags\r\n| extend tagName = tostring(bag_keys(tags)[0])\r\n| extend tagValue = tostring(tags[tagName])\r\n| where tags != '' and tags != '[]' and tostring(bag_keys(tags)[0]) == '{TagName}'\r\n| distinct tagValue\r\n| sort by tagValue asc",
            "crossComponentResources": [
              "{Subscription}"
            ],
            "typeSettings": {
              "additionalResourceOptions": []
            },
            "queryType": 1,
            "resourceType": "microsoft.resourcegraph/resources",
            "value": null,
            "label": "Tag Value"
          }
        ],
        "style": "pills",
        "queryType": 0,
        "resourceType": "microsoft.resourcegraph/resources"
      },
      "customWidth": "75",
      "name": "parameters - Filters"
    },
    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "title": "Compute",
        "items": [
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "// Dev/Test Subscriptions with Production-Grade VM SKUs\r\n// VMs in Dev/Test or MSDN subscriptions running non-burstable, enterprise-class SKUs that could be downsized\r\nResourceContainers\r\n| where type =~ \"microsoft.resources/subscriptions\"\r\n| where tostring(properties.subscriptionPolicies.quotaId) contains \"DevTest\" \r\n    or tostring(properties.subscriptionPolicies.quotaId) contains \"MSDN\"\r\n| project devTestSubId = subscriptionId, subName = name\r\n| join kind=inner (\r\n    resources\r\n    | where type =~ \"microsoft.compute/virtualmachines\"\r\n    | extend vmSize = tostring(properties.hardwareProfile.vmSize)\r\n    | where vmSize !startswith \"Standard_B\"  // Exclude burstable (dev-appropriate)\r\n    | where vmSize !contains \"s_v\" or vmSize contains \"Standard_E\" or vmSize contains \"Standard_M\" or vmSize contains \"Standard_L\"\r\n    | project id, name, vmSize, location, resourceGroup, subscriptionId\r\n) on $left.devTestSubId == $right.subscriptionId\r\n| project id, name, vmSize, location, resourceGroup, subscriptionId, subName\r\n| join kind=leftouter (relationshipresources | where type == 'microsoft.relationships/servicegroupmember' | where properties.TargetId =~ '{ServiceGroup}' | project _sgFilterId = tostring(properties.SourceId) | distinct _sgFilterId) on $left.id == $right._sgFilterId\r\n| where '{ServiceGroup}' == '' or isnotempty(_sgFilterId)\r\n| project-away _sgFilterId\r\n| order by vmSize asc\r\n",
              "size": 0,
              "title": "Dev/Test Subscriptions with Production-Grade VM SKUs",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "gridSettings": {
                "filter": true
              },
              "noDataMessage": "✅ No Dev/Test subscriptions found running production-grade VM SKUs.",
              "noDataMessageStyle": 3
            },
            "name": "query - devtest-production-skus"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "// Unused Container Apps Environments\r\n// Managed environments with zero container apps — paying infrastructure cost for nothing\r\nresources\r\n| where type =~ \"microsoft.app/managedenvironments\"\r\n| project envId = tolower(id), envName = name, location, resourceGroup, subscriptionId\r\n| join kind=leftouter (\r\n    resources\r\n    | where type =~ \"microsoft.app/containerapps\"\r\n    | extend envId = tolower(tostring(properties.managedEnvironmentId))\r\n    | summarize appCount = count() by envId\r\n) on envId\r\n| extend appCount = coalesce(appCount, 0)\r\n| where appCount == 0\r\n| project envId, envName, appCount, location, resourceGroup, subscriptionId\r\n| join kind=leftouter (relationshipresources | where type == 'microsoft.relationships/servicegroupmember' | where properties.TargetId =~ '{ServiceGroup}' | project _sgFilterId = tolower(tostring(properties.SourceId)) | distinct _sgFilterId) on $left.envId == $right._sgFilterId\r\n| where '{ServiceGroup}' == '' or isnotempty(_sgFilterId)\r\n| project-away _sgFilterId\r\n",
              "size": 0,
              "title": "Unused Container Apps Environments",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "gridSettings": {
                "filter": true
              },
              "noDataMessage": "✅ All Container Apps environments have at least one container app deployed.",
              "noDataMessageStyle": 3
            },
            "name": "query - unused-container-apps-envs"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "// Idle Container Instances\r\n// Container groups in Succeeded/Failed/Stopped state or with non-running instances\r\nresources\r\n| where type =~ \"microsoft.containerinstance/containergroups\"\r\n| extend\r\n    provisioningState = tostring(properties.provisioningState),\r\n    osType = tostring(properties.osType),\r\n    containerCount = array_length(properties.containers),\r\n    restartPolicy = tostring(properties.restartPolicy),\r\n    cpu = tostring(properties.containers[0].properties.resources.requests.cpu),\r\n    memGB = tostring(properties.containers[0].properties.resources.requests.memoryInGB)\r\n| where provisioningState in (\"Succeeded\", \"Failed\", \"Stopped\")\r\n| extend instanceState = tostring(properties.instanceView.state)\r\n| where instanceState != \"Running\" or provisioningState != \"Succeeded\"\r\n| project id, name, provisioningState, instanceState, osType, containerCount, restartPolicy, cpu, memGB, location, resourceGroup, subscriptionId\r\n| join kind=leftouter (relationshipresources | where type == 'microsoft.relationships/servicegroupmember' | where properties.TargetId =~ '{ServiceGroup}' | project _sgFilterId = tostring(properties.SourceId) | distinct _sgFilterId) on $left.id == $right._sgFilterId\r\n| where '{ServiceGroup}' == '' or isnotempty(_sgFilterId)\r\n| project-away _sgFilterId\r\n",
              "size": 0,
              "title": "Idle Container Instances",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "gridSettings": {
                "filter": true
              },
              "noDataMessage": "✅ No idle or stopped container instances found.",
              "noDataMessageStyle": 3
            },
            "name": "query - idle-container-instances"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "// Spot VM Opportunity Analysis\r\n// Running non-Spot VMs in dev/test/staging environments (by RG name or tags) — candidates for Spot pricing\r\nresources\r\n| where type =~ \"microsoft.compute/virtualmachines\"\r\n| extend\r\n    vmSize = tostring(properties.hardwareProfile.vmSize),\r\n    priority = tostring(properties.priority),\r\n    powerState = tostring(properties.extended.instanceView.powerState.displayStatus),\r\n    tagStr = tolower(tostring(tags))\r\n| where priority != \"Spot\" and priority != \"Low\"\r\n| where powerState == \"VM running\"\r\n| where resourceGroup matches regex \"(?i)(dev|test|stag|sandbox|lab|poc|demo|tmp|temp)\"\r\n    or tagStr contains \"dev\"\r\n    or tagStr contains \"test\"\r\n    or tagStr contains \"staging\"\r\n    or tagStr contains \"sandbox\"\r\n    or tagStr contains \"non-production\"\r\n    or tagStr contains \"nonproduction\"\r\n    or tagStr contains \"spot-candidate\"\r\n| project id, name, vmSize, priority, resourceGroup, location, subscriptionId\r\n| join kind=leftouter (relationshipresources | where type == 'microsoft.relationships/servicegroupmember' | where properties.TargetId =~ '{ServiceGroup}' | project _sgFilterId = tostring(properties.SourceId) | distinct _sgFilterId) on $left.id == $right._sgFilterId\r\n| where '{ServiceGroup}' == '' or isnotempty(_sgFilterId)\r\n| project-away _sgFilterId\r\n| order by vmSize asc\r\n",
              "size": 0,
              "title": "Spot VM Opportunity Analysis",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "gridSettings": {
                "filter": true
              },
              "noDataMessage": "✅ No Spot VM conversion candidates found in dev/test environments.",
              "noDataMessageStyle": 3
            },
            "name": "query - spot-vm-opportunities"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "// Orphaned Custom VM Images\r\n// Custom images not referenced by any VM or VMSS — candidates for deletion\r\nresources\r\n| where type =~ \"microsoft.compute/images\"\r\n| project imageId = tolower(id), imageName = name, location, resourceGroup, subscriptionId,\r\n    timeCreated = tostring(properties.provisioningState)\r\n| join kind=leftouter (\r\n    resources\r\n    | where type =~ \"microsoft.compute/virtualmachines\"\r\n    | extend imageRef = tolower(tostring(properties.storageProfile.imageReference.id))\r\n    | where isnotempty(imageRef)\r\n    | project imageId = imageRef, _vmRef = 1\r\n) on imageId\r\n| where isnull(_vmRef)\r\n| project-away _vmRef\r\n| join kind=leftouter (\r\n    resources\r\n    | where type =~ \"microsoft.compute/virtualmachinescalesets\"\r\n    | extend imageRef = tolower(tostring(properties.virtualMachineProfile.storageProfile.imageReference.id))\r\n    | where isnotempty(imageRef)\r\n    | project imageId = imageRef, _vmssRef = 1\r\n) on imageId\r\n| where isnull(_vmssRef)\r\n| project imageId, imageName, location, resourceGroup, subscriptionId\r\n| join kind=leftouter (relationshipresources | where type == 'microsoft.relationships/servicegroupmember' | where properties.TargetId =~ '{ServiceGroup}' | project _sgFilterId = tolower(tostring(properties.SourceId)) | distinct _sgFilterId) on $left.imageId == $right._sgFilterId\r\n| where '{ServiceGroup}' == '' or isnotempty(_sgFilterId)\r\n| project-away _sgFilterId\r\n",
              "size": 0,
              "title": "Orphaned Custom VM Images",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "gridSettings": {
                "filter": true
              },
              "noDataMessage": "✅ No orphaned custom VM images found — all images are referenced by VMs or VMSS.",
              "noDataMessageStyle": 3
            },
            "name": "query - orphaned-vm-images"
          }
        ]
      },
      "name": "group - Compute"
    },
    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "title": "Networking",
        "items": [
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "// Idle Front Door / CDN Profiles\r\n// Azure Front Door profiles with no AFD endpoints configured\r\nresources\r\n| where type =~ \"microsoft.cdn/profiles\"\r\n| extend skuName = tostring(sku.name)\r\n| project profileId = tolower(id), profileName = name, skuName, location, resourceGroup, subscriptionId\r\n| join kind=leftouter (\r\n    resources\r\n    | where type =~ \"microsoft.cdn/profiles/afdendpoints\"\r\n    | extend profileId = tolower(tostring(split(id, \"/afdEndpoints\")[0]))\r\n    | project profileId, _endpointExists = 1\r\n) on profileId\r\n| where isnull(_endpointExists)\r\n| project profileId, profileName, skuName, location, resourceGroup, subscriptionId\r\n| join kind=leftouter (relationshipresources | where type == 'microsoft.relationships/servicegroupmember' | where properties.TargetId =~ '{ServiceGroup}' | project _sgFilterId = tolower(tostring(properties.SourceId)) | distinct _sgFilterId) on $left.profileId == $right._sgFilterId\r\n| where '{ServiceGroup}' == '' or isnotempty(_sgFilterId)\r\n| project-away _sgFilterId\r\n",
              "size": 0,
              "title": "Idle Front Door / CDN Profiles",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "gridSettings": {
                "filter": true
              },
              "noDataMessage": "✅ All Front Door / CDN profiles have active endpoints configured.",
              "noDataMessageStyle": 3
            },
            "name": "query - idle-frontdoor-cdn"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "// Pending or Rejected Private Endpoints\r\n// Private Endpoints in non-Approved states — may indicate failed or abandoned connection requests\r\nresources\r\n| where type =~ \"microsoft.network/privateendpoints\"\r\n| mv-expand plsc = properties.privateLinkServiceConnections\r\n| extend\r\n    connectionStatus = tostring(plsc.properties.privateLinkServiceConnectionState.status),\r\n    targetResource = tostring(plsc.properties.privateLinkServiceId),\r\n    groupIds = tostring(plsc.properties.groupIds)\r\n| where connectionStatus != \"Approved\"\r\n| project id, name, connectionStatus, targetResource, groupIds, location, resourceGroup, subscriptionId\r\n| join kind=leftouter (relationshipresources | where type == 'microsoft.relationships/servicegroupmember' | where properties.TargetId =~ '{ServiceGroup}' | project _sgFilterId = tostring(properties.SourceId) | distinct _sgFilterId) on $left.id == $right._sgFilterId\r\n| where '{ServiceGroup}' == '' or isnotempty(_sgFilterId)\r\n| project-away _sgFilterId\r\n| order by connectionStatus asc\r\n",
              "size": 0,
              "title": "Pending/Rejected Private Endpoints",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "gridSettings": {
                "filter": true
              },
              "noDataMessage": "✅ All Private Endpoints are in Approved state.",
              "noDataMessageStyle": 3
            },
            "name": "query - pending-rejected-pes"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "// Duplicate Private Endpoints\r\n// Multiple PEs from the same VNet connecting to the same target resource — potential consolidation opportunity\r\nresources\r\n| where type =~ \"microsoft.network/privateendpoints\"\r\n| mv-expand plsc = properties.privateLinkServiceConnections\r\n| extend\r\n    targetResource = tolower(tostring(plsc.properties.privateLinkServiceId)),\r\n    subnetId = tolower(tostring(properties.subnet.id)),\r\n    vnetId = tolower(tostring(split(tostring(properties.subnet.id), \"/subnets/\")[0]))\r\n| summarize\r\n    peCount = count(),\r\n    peIds = make_list(id),\r\n    peNames = make_list(name)\r\n    by targetResource, vnetId\r\n| where peCount > 1\r\n| project targetResource, vnetId, peCount, peNames\r\n| join kind=leftouter (relationshipresources | where type == 'microsoft.relationships/servicegroupmember' | where properties.TargetId =~ '{ServiceGroup}' | project _sgFilterId = tolower(tostring(properties.SourceId)) | distinct _sgFilterId) on $left.targetResource == $right._sgFilterId\r\n| where '{ServiceGroup}' == '' or isnotempty(_sgFilterId)\r\n| project-away _sgFilterId\r\n| order by peCount desc\r\n",
              "size": 0,
              "title": "Duplicate Private Endpoints to Same Target",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "gridSettings": {
                "filter": true
              },
              "noDataMessage": "✅ No duplicate Private Endpoints found targeting the same resource from the same VNet.",
              "noDataMessageStyle": 3
            },
            "name": "query - duplicate-pes"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "// Redundant Private DNS Zones\r\n// Private DNS zones with duplicate names within the same subscription — potential consolidation candidates\r\nresources\r\n| where type =~ \"microsoft.network/privatednszones\"\r\n| extend zoneName = tostring(name)\r\n| join kind=leftouter (relationshipresources | where type == 'microsoft.relationships/servicegroupmember' | where properties.TargetId =~ '{ServiceGroup}' | project _sgFilterId = tostring(properties.SourceId) | distinct _sgFilterId) on $left.id == $right._sgFilterId\r\n| where '{ServiceGroup}' == '' or isnotempty(_sgFilterId)\r\n| project-away _sgFilterId\r\n| summarize\r\n    zoneCount = count(),\r\n    zoneIds = make_list(id),\r\n    resourceGroups = make_list(resourceGroup)\r\n    by zoneName, subscriptionId\r\n| where zoneCount > 1\r\n| project zoneName, subscriptionId, zoneCount, resourceGroups\r\n| order by zoneCount desc\r\n",
              "size": 0,
              "title": "Redundant Private DNS Zones",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "gridSettings": {
                "filter": true
              },
              "noDataMessage": "✅ No redundant Private DNS zones found within the same subscription.",
              "noDataMessageStyle": 3
            },
            "name": "query - redundant-private-dns"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "// Idle Traffic Manager Profiles\r\n// Traffic Manager profiles with zero endpoints or no enabled endpoints\r\nresources\r\n| where type =~ \"microsoft.network/trafficmanagerprofiles\"\r\n| extend\r\n    endpointCount = array_length(properties.endpoints),\r\n    profileStatus = tostring(properties.profileStatus),\r\n    trafficRoutingMethod = tostring(properties.trafficRoutingMethod)\r\n| mv-expand endpoint = properties.endpoints\r\n| extend endpointStatus = tostring(endpoint.properties.endpointStatus)\r\n| summarize\r\n    totalEndpoints = count(),\r\n    enabledEndpoints = countif(endpointStatus == \"Enabled\")\r\n    by id, name, profileStatus, trafficRoutingMethod, resourceGroup, subscriptionId\r\n| where totalEndpoints == 0 or enabledEndpoints == 0\r\n| project id, name, profileStatus, trafficRoutingMethod, totalEndpoints, enabledEndpoints, resourceGroup, subscriptionId\r\n| join kind=leftouter (relationshipresources | where type == 'microsoft.relationships/servicegroupmember' | where properties.TargetId =~ '{ServiceGroup}' | project _sgFilterId = tostring(properties.SourceId) | distinct _sgFilterId) on $left.id == $right._sgFilterId\r\n| where '{ServiceGroup}' == '' or isnotempty(_sgFilterId)\r\n| project-away _sgFilterId\r\n",
              "size": 0,
              "title": "Idle Traffic Manager Profiles",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "gridSettings": {
                "filter": true
              },
              "noDataMessage": "✅ All Traffic Manager profiles have enabled endpoints.",
              "noDataMessageStyle": 3
            },
            "name": "query - idle-traffic-manager"
          }
        ]
      },
      "name": "group - Networking"
    },
    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "title": "Databases",
        "items": [
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "// Stopped MySQL / PostgreSQL Flexible Servers\r\n// Flexible servers in Stopped/Disabled state — compute is deallocated but storage charges continue\r\nresources\r\n| where type =~ \"microsoft.dbformysql/flexibleservers\" \r\n    or type =~ \"microsoft.dbforpostgresql/flexibleservers\"\r\n| extend\r\n    serverState = tostring(properties.state),\r\n    skuName = tostring(sku.name),\r\n    skuTier = tostring(sku.tier),\r\n    storageGB = toint(properties.storage.storageSizeGB),\r\n    version = tostring(properties.version),\r\n    serverType = case(\r\n        type contains \"mysql\", \"MySQL\",\r\n        type contains \"postgresql\", \"PostgreSQL\",\r\n        \"Unknown\"\r\n    )\r\n| where serverState =~ \"Stopped\" or serverState =~ \"Disabled\"\r\n| project id, name, serverType, serverState, skuName, skuTier, storageGB, version, location, resourceGroup, subscriptionId\r\n| join kind=leftouter (relationshipresources | where type == 'microsoft.relationships/servicegroupmember' | where properties.TargetId =~ '{ServiceGroup}' | project _sgFilterId = tostring(properties.SourceId) | distinct _sgFilterId) on $left.id == $right._sgFilterId\r\n| where '{ServiceGroup}' == '' or isnotempty(_sgFilterId)\r\n| project-away _sgFilterId\r\n",
              "size": 0,
              "title": "Stopped MySQL/PostgreSQL Flexible Servers",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "gridSettings": {
                "filter": true
              },
              "noDataMessage": "✅ No stopped MySQL or PostgreSQL Flexible Servers found.",
              "noDataMessageStyle": 3
            },
            "name": "query - stopped-mysql-postgresql-flex"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "// Deprecated MariaDB Instances\r\n// Azure Database for MariaDB is deprecated — these should be migrated to MySQL Flexible Server\r\nresources\r\n| where type =~ \"microsoft.dbformariadb/servers\"\r\n| extend\r\n    serverState = tostring(properties.userVisibleState),\r\n    skuName = tostring(sku.name),\r\n    skuTier = tostring(sku.tier),\r\n    storageGB = toint(properties.storageProfile.storageMB) / 1024,\r\n    version = tostring(properties.version),\r\n    sslEnforcement = tostring(properties.sslEnforcement)\r\n| project id, name, serverState, skuName, skuTier, storageGB, version, sslEnforcement, location, resourceGroup, subscriptionId\r\n| join kind=leftouter (relationshipresources | where type == 'microsoft.relationships/servicegroupmember' | where properties.TargetId =~ '{ServiceGroup}' | project _sgFilterId = tostring(properties.SourceId) | distinct _sgFilterId) on $left.id == $right._sgFilterId\r\n| where '{ServiceGroup}' == '' or isnotempty(_sgFilterId)\r\n| project-away _sgFilterId\r\n",
              "size": 0,
              "title": "MariaDB Instances (Deprecated)",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "gridSettings": {
                "filter": true
              },
              "noDataMessage": "✅ No deprecated MariaDB instances found.",
              "noDataMessageStyle": 3
            },
            "name": "query - mariadb-deprecated"
          }
        ]
      },
      "name": "group - Databases"
    },
    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "title": "Analytics",
        "items": [
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "// Synapse Idle Dedicated SQL Pools\r\n// Dedicated SQL pools in Online state — consider pausing when not actively queried\r\n// NOTE: Full idle detection requires metrics data (not available in ARG). This query surfaces candidate resources for review.\r\nresources\r\n| where type =~ \"microsoft.synapse/workspaces/sqlpools\"\r\n| extend\r\n    poolStatus = tostring(properties.status),\r\n    skuName = tostring(sku.name),\r\n    skuCapacity = toint(sku.capacity),\r\n    collation = tostring(properties.collation),\r\n    maxSizeBytes = tolong(properties.maxSizeBytes),\r\n    maxSizeGB = tolong(properties.maxSizeBytes) / 1073741824,\r\n    workspaceName = tostring(split(id, \"/\")[8])\r\n| where poolStatus =~ \"Online\"\r\n| project id, name, workspaceName, poolStatus, skuName, skuCapacity, maxSizeGB, location, resourceGroup, subscriptionId\r\n| join kind=leftouter (relationshipresources | where type == 'microsoft.relationships/servicegroupmember' | where properties.TargetId =~ '{ServiceGroup}' | project _sgFilterId = tostring(properties.SourceId) | distinct _sgFilterId) on $left.id == $right._sgFilterId\r\n| where '{ServiceGroup}' == '' or isnotempty(_sgFilterId)\r\n| project-away _sgFilterId\r\n| order by skuCapacity desc\r\n",
              "size": 0,
              "title": "Synapse Idle Dedicated SQL Pools",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "gridSettings": {
                "filter": true
              },
              "noDataMessage": "✅ No online Synapse Dedicated SQL Pools found — all pools are paused or no pools exist.",
              "noDataMessageStyle": 3
            },
            "name": "query - synapse-idle-sql-pools"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "// Idle Data Factory Instances\r\n// Lists all Data Factory instances — cross-reference with pipeline run activity to identify idle ones\r\n// NOTE: Full idle detection requires Activity Log or metrics data (not available in ARG). This query surfaces candidate resources for review.\r\nresources\r\n| where type =~ \"microsoft.datafactory/factories\"\r\n| extend\r\n    provisioningState = tostring(properties.provisioningState),\r\n    repoType = tostring(properties.repoConfiguration.type),\r\n    publicNetworkAccess = tostring(properties.publicNetworkAccess),\r\n    createTime = tostring(properties.createTime)\r\n| project id, name, provisioningState, repoType, publicNetworkAccess, createTime, location, resourceGroup, subscriptionId\r\n| join kind=leftouter (relationshipresources | where type == 'microsoft.relationships/servicegroupmember' | where properties.TargetId =~ '{ServiceGroup}' | project _sgFilterId = tostring(properties.SourceId) | distinct _sgFilterId) on $left.id == $right._sgFilterId\r\n| where '{ServiceGroup}' == '' or isnotempty(_sgFilterId)\r\n| project-away _sgFilterId\r\n",
              "size": 0,
              "title": "Idle Data Factory Pipelines",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "gridSettings": {
                "filter": true
              },
              "noDataMessage": "✅ No Data Factory instances found that may be idle. Cross-reference with pipeline activity for confirmation.",
              "noDataMessageStyle": 3
            },
            "name": "query - idle-data-factory"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "// Azure AI Services — Idle Deployment Candidates\r\n// Lists Cognitive Services / AI Services accounts with their SKU and provisioning info\r\n// NOTE: Full idle detection requires metrics data (not available in ARG). This query surfaces candidate resources for review.\r\nresources\r\n| where type =~ \"microsoft.cognitiveservices/accounts\"\r\n| extend\r\n    skuName = tostring(sku.name),\r\n    aiKind = tostring(kind),\r\n    provisioningState = tostring(properties.provisioningState),\r\n    publicNetworkAccess = tostring(properties.publicNetworkAccess),\r\n    customSubDomain = tostring(properties.customSubDomainName),\r\n    endpoint = tostring(properties.endpoint)\r\n| project id, name, aiKind, skuName, provisioningState, publicNetworkAccess, customSubDomain, location, resourceGroup, subscriptionId\r\n| join kind=leftouter (relationshipresources | where type == 'microsoft.relationships/servicegroupmember' | where properties.TargetId =~ '{ServiceGroup}' | project _sgFilterId = tostring(properties.SourceId) | distinct _sgFilterId) on $left.id == $right._sgFilterId\r\n| where '{ServiceGroup}' == '' or isnotempty(_sgFilterId)\r\n| project-away _sgFilterId\r\n| order by aiKind asc\r\n",
              "size": 0,
              "title": "Azure AI Services Idle Deployments",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "gridSettings": {
                "filter": true
              },
              "noDataMessage": "✅ No Azure AI Services accounts found that may be idle. Cross-reference with usage metrics for confirmation.",
              "noDataMessageStyle": 3
            },
            "name": "query - idle-ai-services"
          }
        ]
      },
      "name": "group - Analytics"
    },
    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "title": "Security",
        "items": [
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "// DDoS Protection Plans — Low Utilization\r\n// DDoS Protection Plans protecting fewer than 10 public IPs — at ~$2,944/month, consider consolidation\r\nresources\r\n| where type =~ \"microsoft.network/ddosprotectionplans\"\r\n| extend\r\n    associatedVnets = array_length(properties.virtualNetworks),\r\n    provisioningState = tostring(properties.provisioningState)\r\n| project planId = id, planName = name, associatedVnets, provisioningState, location, resourceGroup, subscriptionId\r\n| join kind=leftouter (\r\n    resources\r\n    | where type =~ \"microsoft.network/publicipaddresses\"\r\n    | where isnotempty(properties.ddosSettings.ddosProtectionPlan.id)\r\n    | extend planId = tostring(properties.ddosSettings.ddosProtectionPlan.id)\r\n    | summarize protectedPIPs = count() by planId\r\n) on planId\r\n| extend protectedPIPs = coalesce(protectedPIPs, 0)\r\n| where protectedPIPs < 10\r\n| project planId, planName, associatedVnets, protectedPIPs, provisioningState, location, resourceGroup, subscriptionId\r\n| join kind=leftouter (relationshipresources | where type == 'microsoft.relationships/servicegroupmember' | where properties.TargetId =~ '{ServiceGroup}' | project _sgFilterId = tostring(properties.SourceId) | distinct _sgFilterId) on $left.planId == $right._sgFilterId\r\n| where '{ServiceGroup}' == '' or isnotempty(_sgFilterId)\r\n| project-away _sgFilterId\r\n| order by protectedPIPs asc\r\n",
              "size": 0,
              "title": "DDoS Protection Plans (Under-Utilized)",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "gridSettings": {
                "filter": true
              },
              "noDataMessage": "✅ No under-utilized DDoS Protection Plans found — all plans protect 10 or more public IPs.",
              "noDataMessageStyle": 3
            },
            "name": "query - ddos-protection-plans"
          }
        ]
      },
      "name": "group - Security"
    },
    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "title": "Integration",
        "items": [
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "// Idle API Management Instances\r\n// APIM instances with zero custom APIs (excluding the built-in echo-api)\r\nresources\r\n| where type =~ \"microsoft.apimanagement/service\"\r\n| extend\r\n    skuName = tostring(sku.name),\r\n    skuCapacity = toint(sku.capacity),\r\n    provisioningState = tostring(properties.provisioningState),\r\n    gatewayUrl = tostring(properties.gatewayUrl),\r\n    publicIPAddresses = properties.publicIPAddresses\r\n| project apimId = tolower(id), apimName = name, skuName, skuCapacity, provisioningState, location, resourceGroup, subscriptionId\r\n| join kind=leftouter (\r\n    resources\r\n    | where type =~ \"microsoft.apimanagement/service/apis\"\r\n    | where name != \"echo-api\"  // Exclude the default built-in echo API\r\n    | extend apimId = tolower(tostring(split(id, \"/apis/\")[0]))\r\n    | summarize apiCount = count() by apimId\r\n) on apimId\r\n| extend apiCount = coalesce(apiCount, 0)\r\n| where apiCount == 0\r\n| project apimId, apimName, skuName, skuCapacity, apiCount, provisioningState, location, resourceGroup, subscriptionId\r\n| join kind=leftouter (relationshipresources | where type == 'microsoft.relationships/servicegroupmember' | where properties.TargetId =~ '{ServiceGroup}' | project _sgFilterId = tolower(tostring(properties.SourceId)) | distinct _sgFilterId) on $left.apimId == $right._sgFilterId\r\n| where '{ServiceGroup}' == '' or isnotempty(_sgFilterId)\r\n| project-away _sgFilterId\r\n",
              "size": 0,
              "title": "Idle API Management Instances",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "gridSettings": {
                "filter": true
              },
              "noDataMessage": "✅ All API Management instances have at least one custom API configured.",
              "noDataMessageStyle": 3
            },
            "name": "query - idle-api-management"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "// Idle Premium Service Bus Namespaces\r\n// Premium-tier Service Bus namespaces with zero queues and zero topics\r\nresources\r\n| where type =~ \"microsoft.servicebus/namespaces\"\r\n| extend\r\n    skuName = tostring(sku.name),\r\n    skuTier = tostring(sku.tier),\r\n    skuCapacity = toint(sku.capacity),\r\n    provisioningState = tostring(properties.provisioningState),\r\n    status = tostring(properties.status)\r\n| where skuTier =~ \"Premium\"\r\n| project sbId = tolower(id), sbName = name, skuName, skuTier, skuCapacity, status, location, resourceGroup, subscriptionId\r\n| join kind=leftouter (\r\n    resources\r\n    | where type =~ \"microsoft.servicebus/namespaces/queues\"\r\n    | extend sbId = tolower(tostring(split(id, \"/queues/\")[0]))\r\n    | summarize queueCount = count() by sbId\r\n) on sbId\r\n| join kind=leftouter (\r\n    resources\r\n    | where type =~ \"microsoft.servicebus/namespaces/topics\"\r\n    | extend sbId = tolower(tostring(split(id, \"/topics/\")[0]))\r\n    | summarize topicCount = count() by sbId\r\n) on sbId\r\n| extend queueCount = coalesce(queueCount, 0), topicCount = coalesce(topicCount, 0)\r\n| where queueCount == 0 and topicCount == 0\r\n| project sbId, sbName, skuName, skuTier, skuCapacity, queueCount, topicCount, status, location, resourceGroup, subscriptionId\r\n| join kind=leftouter (relationshipresources | where type == 'microsoft.relationships/servicegroupmember' | where properties.TargetId =~ '{ServiceGroup}' | project _sgFilterId = tolower(tostring(properties.SourceId)) | distinct _sgFilterId) on $left.sbId == $right._sgFilterId\r\n| where '{ServiceGroup}' == '' or isnotempty(_sgFilterId)\r\n| project-away _sgFilterId\r\n",
              "size": 0,
              "title": "Idle Service Bus Namespaces",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "gridSettings": {
                "filter": true
              },
              "noDataMessage": "✅ All Premium Service Bus namespaces have active queues or topics.",
              "noDataMessageStyle": 3
            },
            "name": "query - idle-service-bus"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "// Idle Logic Apps — Standard Plan\r\n// Standard Logic Apps (App Service-based) that may be idle — review workflow run activity\r\n// NOTE: Full idle detection requires metrics/run history data (not available in ARG). This query surfaces Standard Logic Apps for review.\r\nresources\r\n| where type =~ \"microsoft.web/sites\"\r\n| where kind has \"workflowapp\"\r\n| extend\r\n    appStatus = tostring(properties.state),\r\n    httpsOnly = tobool(properties.httpsOnly),\r\n    serverFarmId = tostring(properties.serverFarmId),\r\n    skuName = tostring(properties.sku.name)\r\n| project id, name, appStatus, kind, httpsOnly, serverFarmId, location, resourceGroup, subscriptionId\r\n| join kind=leftouter (relationshipresources | where type == 'microsoft.relationships/servicegroupmember' | where properties.TargetId =~ '{ServiceGroup}' | project _sgFilterId = tostring(properties.SourceId) | distinct _sgFilterId) on $left.id == $right._sgFilterId\r\n| where '{ServiceGroup}' == '' or isnotempty(_sgFilterId)\r\n| project-away _sgFilterId\r\n",
              "size": 0,
              "title": "Idle Logic Apps (Standard)",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "gridSettings": {
                "filter": true
              },
              "noDataMessage": "✅ No idle Standard Logic Apps found. Cross-reference with workflow run history for confirmation.",
              "noDataMessageStyle": 3
            },
            "name": "query - idle-logic-apps"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "// Idle Event Grid Topics and Domains\r\n// Event Grid topics and domains with no event subscriptions\r\nresources\r\n| where type =~ \"microsoft.eventgrid/topics\"\r\n| extend\r\n    provisioningState = tostring(properties.provisioningState),\r\n    publicNetworkAccess = tostring(properties.publicNetworkAccess),\r\n    inputSchema = tostring(properties.inputSchema),\r\n    resourceType = \"Topic\"\r\n| project resourceId = tolower(id), resourceName = name, resourceType, provisioningState, inputSchema, location, resourceGroup, subscriptionId\r\n| join kind=leftouter (\r\n    resources\r\n    | where type =~ \"microsoft.eventgrid/topics/eventsubscriptions\"\r\n        or type =~ \"microsoft.eventgrid/eventsubscriptions\"\r\n    | extend topicId = tolower(tostring(split(id, \"/eventSubscriptions\")[0]))\r\n    | project resourceId = topicId, _subExists = 1\r\n) on resourceId\r\n| where isnull(_subExists)\r\n| project-away _subExists\r\n| union (\r\n    resources\r\n    | where type =~ \"microsoft.eventgrid/domains\"\r\n    | extend\r\n        provisioningState = tostring(properties.provisioningState),\r\n        publicNetworkAccess = tostring(properties.publicNetworkAccess),\r\n        inputSchema = tostring(properties.inputSchema),\r\n        resourceType = \"Domain\"\r\n    | project resourceId = tolower(id), resourceName = name, resourceType, provisioningState, inputSchema, location, resourceGroup, subscriptionId\r\n    | join kind=leftouter (\r\n        resources\r\n        | where type =~ \"microsoft.eventgrid/domains/eventsubscriptions\"\r\n            or type =~ \"microsoft.eventgrid/eventsubscriptions\"\r\n        | extend domainId = tolower(tostring(split(id, \"/eventSubscriptions\")[0]))\r\n        | project resourceId = domainId, _subExists = 1\r\n    ) on resourceId\r\n    | where isnull(_subExists)\r\n    | project-away _subExists\r\n)\r\n| project resourceId, resourceName, resourceType, provisioningState, inputSchema, location, resourceGroup, subscriptionId\r\n| join kind=leftouter (relationshipresources | where type == 'microsoft.relationships/servicegroupmember' | where properties.TargetId =~ '{ServiceGroup}' | project _sgFilterId = tolower(tostring(properties.SourceId)) | distinct _sgFilterId) on $left.resourceId == $right._sgFilterId\r\n| where '{ServiceGroup}' == '' or isnotempty(_sgFilterId)\r\n| project-away _sgFilterId\r\n",
              "size": 0,
              "title": "Idle Event Grid Topics/Domains",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "gridSettings": {
                "filter": true
              },
              "noDataMessage": "✅ All Event Grid topics and domains have active event subscriptions.",
              "noDataMessageStyle": 3
            },
            "name": "query - idle-event-grid"
          }
        ]
      },
      "name": "group - Integration"
    },
    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "title": "Cross-cutting (Advisor)",
        "items": [
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "// Advisor Cost Recommendations — Catch-All by Impacted Field\r\n// Aggregates all Cost recommendations grouped by impacted resource type\r\nadvisorresources\r\n| where type == \"microsoft.advisor/recommendations\"\r\n| where tostring(properties.category) == \"Cost\"\r\n| extend\r\n    impactedField = tostring(properties.impactedField),\r\n    impact = tostring(properties.impact),\r\n    shortDescription = tostring(properties.shortDescription.solution),\r\n    resourceId = tostring(properties.resourceMetadata.resourceId)\r\n| join kind=leftouter (relationshipresources | where type == 'microsoft.relationships/servicegroupmember' | where properties.TargetId =~ '{ServiceGroup}' | project _sgFilterId = tostring(properties.SourceId) | distinct _sgFilterId) on $left.resourceId == $right._sgFilterId\r\n| where '{ServiceGroup}' == '' or isnotempty(_sgFilterId)\r\n| project-away _sgFilterId\r\n| summarize\r\n    recommendationCount = count(),\r\n    highImpact = countif(impact == \"High\"),\r\n    mediumImpact = countif(impact == \"Medium\"),\r\n    lowImpact = countif(impact == \"Low\"),\r\n    sampleDescription = take_any(shortDescription)\r\n    by impactedField\r\n| order by recommendationCount desc\r\n| project impactedField, recommendationCount, highImpact, mediumImpact, lowImpact, sampleDescription\r\n",
              "size": 0,
              "title": "Advisor Cost Recommendations (Catch-All)",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "gridSettings": {
                "filter": true
              },
              "noDataMessage": "✅ No Azure Advisor cost recommendations found for the selected scope.",
              "noDataMessageStyle": 3
            },
            "name": "query - advisor-cost-catchall"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "// Advisor Reliability Recommendations — Catch-All by Impacted Field\r\n// Aggregates all Reliability (High Availability) recommendations grouped by impacted resource type\r\nadvisorresources\r\n| where type == \"microsoft.advisor/recommendations\"\r\n| where tostring(properties.category) == \"HighAvailability\"\r\n| extend\r\n    impactedField = tostring(properties.impactedField),\r\n    impact = tostring(properties.impact),\r\n    shortDescription = tostring(properties.shortDescription.solution),\r\n    resourceId = tostring(properties.resourceMetadata.resourceId)\r\n| join kind=leftouter (relationshipresources | where type == 'microsoft.relationships/servicegroupmember' | where properties.TargetId =~ '{ServiceGroup}' | project _sgFilterId = tostring(properties.SourceId) | distinct _sgFilterId) on $left.resourceId == $right._sgFilterId\r\n| where '{ServiceGroup}' == '' or isnotempty(_sgFilterId)\r\n| project-away _sgFilterId\r\n| summarize\r\n    recommendationCount = count(),\r\n    highImpact = countif(impact == \"High\"),\r\n    mediumImpact = countif(impact == \"Medium\"),\r\n    lowImpact = countif(impact == \"Low\"),\r\n    sampleDescription = take_any(shortDescription)\r\n    by impactedField\r\n| order by recommendationCount desc\r\n| project impactedField, recommendationCount, highImpact, mediumImpact, lowImpact, sampleDescription\r\n",
              "size": 0,
              "title": "Advisor Reliability Recommendations (Catch-All)",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "gridSettings": {
                "filter": true
              },
              "noDataMessage": "✅ No Azure Advisor reliability recommendations found for the selected scope.",
              "noDataMessageStyle": 3
            },
            "name": "query - advisor-reliability-catchall"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "// Advisor Security Recommendations — Catch-All by Impacted Field\r\n// Aggregates all Security recommendations grouped by impacted resource type\r\nadvisorresources\r\n| where type == \"microsoft.advisor/recommendations\"\r\n| where tostring(properties.category) == \"Security\"\r\n| extend\r\n    impactedField = tostring(properties.impactedField),\r\n    impact = tostring(properties.impact),\r\n    shortDescription = tostring(properties.shortDescription.solution),\r\n    resourceId = tostring(properties.resourceMetadata.resourceId)\r\n| join kind=leftouter (relationshipresources | where type == 'microsoft.relationships/servicegroupmember' | where properties.TargetId =~ '{ServiceGroup}' | project _sgFilterId = tostring(properties.SourceId) | distinct _sgFilterId) on $left.resourceId == $right._sgFilterId\r\n| where '{ServiceGroup}' == '' or isnotempty(_sgFilterId)\r\n| project-away _sgFilterId\r\n| summarize\r\n    recommendationCount = count(),\r\n    highImpact = countif(impact == \"High\"),\r\n    mediumImpact = countif(impact == \"Medium\"),\r\n    lowImpact = countif(impact == \"Low\"),\r\n    sampleDescription = take_any(shortDescription)\r\n    by impactedField\r\n| order by recommendationCount desc\r\n| project impactedField, recommendationCount, highImpact, mediumImpact, lowImpact, sampleDescription\r\n",
              "size": 0,
              "title": "Advisor Security Recommendations (Catch-All)",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "gridSettings": {
                "filter": true
              },
              "noDataMessage": "✅ No Azure Advisor security recommendations found for the selected scope.",
              "noDataMessageStyle": 3
            },
            "name": "query - advisor-security-catchall"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "// Advisor Performance Recommendations — Catch-All by Impacted Field\r\n// Aggregates all Performance recommendations grouped by impacted resource type\r\nadvisorresources\r\n| where type == \"microsoft.advisor/recommendations\"\r\n| where tostring(properties.category) == \"Performance\"\r\n| extend\r\n    impactedField = tostring(properties.impactedField),\r\n    impact = tostring(properties.impact),\r\n    shortDescription = tostring(properties.shortDescription.solution),\r\n    resourceId = tostring(properties.resourceMetadata.resourceId)\r\n| join kind=leftouter (relationshipresources | where type == 'microsoft.relationships/servicegroupmember' | where properties.TargetId =~ '{ServiceGroup}' | project _sgFilterId = tostring(properties.SourceId) | distinct _sgFilterId) on $left.resourceId == $right._sgFilterId\r\n| where '{ServiceGroup}' == '' or isnotempty(_sgFilterId)\r\n| project-away _sgFilterId\r\n| summarize\r\n    recommendationCount = count(),\r\n    highImpact = countif(impact == \"High\"),\r\n    mediumImpact = countif(impact == \"Medium\"),\r\n    lowImpact = countif(impact == \"Low\"),\r\n    sampleDescription = take_any(shortDescription)\r\n    by impactedField\r\n| order by recommendationCount desc\r\n| project impactedField, recommendationCount, highImpact, mediumImpact, lowImpact, sampleDescription\r\n",
              "size": 0,
              "title": "Advisor Performance Recommendations (Catch-All)",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "gridSettings": {
                "filter": true
              },
              "noDataMessage": "✅ No Azure Advisor performance recommendations found for the selected scope.",
              "noDataMessageStyle": 3
            },
            "name": "query - advisor-performance-catchall"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "// Advisor Operational Excellence Recommendations — Catch-All by Impacted Field\r\n// Aggregates all Operational Excellence recommendations grouped by impacted resource type\r\nadvisorresources\r\n| where type == \"microsoft.advisor/recommendations\"\r\n| where tostring(properties.category) == \"OperationalExcellence\"\r\n| extend\r\n    impactedField = tostring(properties.impactedField),\r\n    impact = tostring(properties.impact),\r\n    shortDescription = tostring(properties.shortDescription.solution),\r\n    resourceId = tostring(properties.resourceMetadata.resourceId)\r\n| join kind=leftouter (relationshipresources | where type == 'microsoft.relationships/servicegroupmember' | where properties.TargetId =~ '{ServiceGroup}' | project _sgFilterId = tostring(properties.SourceId) | distinct _sgFilterId) on $left.resourceId == $right._sgFilterId\r\n| where '{ServiceGroup}' == '' or isnotempty(_sgFilterId)\r\n| project-away _sgFilterId\r\n| summarize\r\n    recommendationCount = count(),\r\n    highImpact = countif(impact == \"High\"),\r\n    mediumImpact = countif(impact == \"Medium\"),\r\n    lowImpact = countif(impact == \"Low\"),\r\n    sampleDescription = take_any(shortDescription)\r\n    by impactedField\r\n| order by recommendationCount desc\r\n| project impactedField, recommendationCount, highImpact, mediumImpact, lowImpact, sampleDescription\r\n",
              "size": 0,
              "title": "Advisor Operational Excellence Recommendations (Catch-All)",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "gridSettings": {
                "filter": true
              },
              "noDataMessage": "✅ No Azure Advisor operational excellence recommendations found for the selected scope.",
              "noDataMessageStyle": 3
            },
            "name": "query - advisor-operational-excellence-catchall"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "// App Service Plans — Multi-Worker Without Autoscale\r\n// Non-Free/Shared App Service Plans with multiple workers but no autoscale settings configured\r\nresources\r\n| where type =~ \"microsoft.web/serverfarms\"\r\n| where sku.tier !~ \"Free\" and sku.tier !~ \"Shared\"\r\n| extend\r\n    skuName = tostring(sku.name),\r\n    skuTier = tostring(sku.tier),\r\n    workers = toint(properties.numberOfWorkers),\r\n    maxWorkers = toint(properties.maximumNumberOfWorkers),\r\n    siteCount = toint(properties.numberOfSites),\r\n    planId = tolower(id)\r\n| where workers > 1\r\n| join kind=leftouter (\r\n    resources\r\n    | where type =~ \"microsoft.insights/autoscalesettings\"\r\n    | extend planId = tolower(tostring(properties.targetResourceUri))\r\n    | project planId, _autoscaleExists = 1\r\n) on planId\r\n| where isnull(_autoscaleExists) and siteCount > 0\r\n| project id, name, skuName, skuTier, workers, maxWorkers, siteCount, location, resourceGroup, subscriptionId\r\n| join kind=leftouter (relationshipresources | where type == 'microsoft.relationships/servicegroupmember' | where properties.TargetId =~ '{ServiceGroup}' | project _sgFilterId = tostring(properties.SourceId) | distinct _sgFilterId) on $left.id == $right._sgFilterId\r\n| where '{ServiceGroup}' == '' or isnotempty(_sgFilterId)\r\n| project-away _sgFilterId\r\n| order by workers desc\r\n",
              "size": 0,
              "title": "App Service Plans Without Autoscale",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "gridSettings": {
                "filter": true
              },
              "noDataMessage": "✅ All multi-worker App Service Plans have autoscale configured.",
              "noDataMessageStyle": 3
            },
            "name": "query - app-service-plans-no-autoscale"
          }
        ]
      },
      "name": "group - Cross-cutting (Advisor)"
    }
  ],
  "fallbackResourceIds": [
    "Azure Monitor"
  ],
  "$schema": "https://github.com/Microsoft/Application-Insights-Workbooks/blob/master/schema/workbook.json"
}