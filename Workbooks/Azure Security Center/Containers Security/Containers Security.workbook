                {
                  "type": 3,
                  "content": {
                    "version": "KqlItem/1.0",
                    "query": "securityresources\n| where type == \"microsoft.security/assessments\"\n| where properties.metadata.recommendationCategory == \"SoftwareUpdate\"\n| where properties.resourceDetails.ResourceType == \"K8s-container\"\n| where properties.resourceDetails.Source == \"Azure\"\n| extend status = tostring(properties.status.code)\n| where status == \"Unhealthy\"\n| extend Resource = tolower(extract(@'(?i)(.*?)/securityentitydata/([^/]+)', 1, id))\n| where Resource in~ ({k8sclu})\n| extend SoftwareName = tostring(properties.additionalData.SoftwareName)\n| where SoftwareName == '{aksSW}'\n| extend resourceData = parse_json(tostring(properties.resourceAdditionalData))\n| extend ContainerName = tostring(resourceData.ContainerName)\n| where ContainerName == '{aksCt}'\n| extend Vendor = tostring(properties.additionalData.SoftwareVendor)\n| extend PackageType = tostring(properties.additionalData.PackageType)\n| extend Vendor = iff(isnotempty(PackageType), strcat(Vendor, \" (\", PackageType, \")\"), Vendor)\n| extend FixedVersion = tostring(properties.additionalData.FixedVersion)\n| extend FixStatus = iff(isnotempty(FixedVersion), \"Fix Available\", \"No Fix\")\n| extend ImageUri = tostring(resourceData.ImageDetails.ImageUri)\n| extend CvesRaw = parse_json(tostring(properties.additionalData.CvesDetails))\n| project-away properties\n| mv-expand cve = CvesRaw\n| project-away CvesRaw\n| extend CveId = tostring(cve.CveId)\n| extend CveSeverity = tostring(cve.Severity)\n| mv-expand cvss = cve.Cvss\n| where tostring(cvss.Key) == \"3\"\n| extend CvssScore = toreal(cvss.Value.Base)\n| extend CvssVector = tostring(cvss.Value.CvssVectorString)\n| extend PublishedDate = tostring(cve.PublishedDate)\n| extend ExploitStepsPublished = iff(tostring(cve.ExploitabilityDetails.ExploitStepsPublished) == \"true\", \"Yes\", \"No\")\n| extend InExploitKit = iff(tostring(cve.ExploitabilityDetails.IsInExploitKit) == \"true\", \"Yes\", \"No\")\n| extend ExploitStepsVerified = iff(tostring(cve.ExploitabilityDetails.ExploitStepsVerified) == \"true\", \"Yes\", \"No\")\n| extend cveSelected = \"true\"\n| extend Impact = coalesce(tostring(cve.ExtendedDescription.Impact), \"\")\n| extend Remediation = coalesce(tostring(cve.Remediation), \"\")\n| extend RefsRaw = tostring(cve.References)\n| mv-expand ref = todynamic(RefsRaw)\n| extend refUrl = tostring(ref.Link)\n| extend refTitle = tostring(ref.Title)\n\n| extend CveDescription = tostring(cve.Description)\n| extend ExtDescription = tostring(cve.ExtendedDescription.Summary)\n| summarize CveSeverity=take_any(CveSeverity), CvssScore=max(CvssScore), CvssVector=take_any(CvssVector), FixStatus=take_any(FixStatus), FixedVersion=take_any(FixedVersion), Impact=take_any(Impact), Remediation=take_any(Remediation), RefsRaw=take_any(RefsRaw), AllRefs=make_set(strcat(\"[\", refTitle, \"](\", refUrl, \")  \\n\")), Vendor=take_any(Vendor), ImageUri=take_any(ImageUri), ExploitStepsPublished=take_any(ExploitStepsPublished), InExploitKit=take_any(InExploitKit), ExploitStepsVerified=take_any(ExploitStepsVerified), PublishedDate=take_any(PublishedDate), CveDescription=take_any(CveDescription), ExtDescription=take_any(ExtDescription), cveSelected=take_any(cveSelected) by CveId\n| extend AllRefs = strcat_array(AllRefs, \"\")\n| order by case(CveSeverity =~ \"Critical\", 0, CveSeverity =~ \"High\", 1, CveSeverity =~ \"Medium\", 2, CveSeverity =~ \"Low\", 3, 4) asc, CvssScore desc",
