                      "thresholdsGrid": [
                        {
                          "operator": "==",
                          "thresholdValue": "on",
                          "representation": "green",
                          "text": "Enabled"
                        },
                        {
                          "operator": "Default",
                          "thresholdValue": null,
                          "representation": "redBright",
                          "text": "Disabled"
                        }
                      ]
                    }
                  },
                  {
                    "columnMatch": "accountId",
                    "formatter": 5
                  },
                  {
                    "columnMatch": "subscriptionId",
                    "formatter": 15,
                    "formatOptions": {
                      "linkTarget": null,
                      "showIcon": true
                    }
                  }
                ],
                "rowLimit": 10000,
                "filter": true,
                "labelSettings": [
