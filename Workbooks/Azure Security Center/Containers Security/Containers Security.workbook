    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "items": [
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "securityresources \n    | where type == \"microsoft.security/assessments\" \n    | extend healthState = properties.status.code    \n    | extend url = strcat(\"https://\", properties.links.azurePortal)\n    | extend resource = tostring(properties.resourceDetails.Id)\n    | extend resourcesecblade = strcat(tostring(id), \"/security\")\n    | extend recommendation = tostring(properties.metadata.displayName)\n    | extend ResourceType = id \n    | extend AssessmentKey = name\n    | where healthState in ('Unhealthy')\n    | where recommendation contains ('Policy add-on for Kubernetes installed')\n    | project \n        resource,\n        recommendation, \n        AssessmentKey\n    | order by recommendation desc\n    | take 5",
              "size": 1,
              "title": "Missing Azure Policy add-on for Kubernetes",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "value::all"
