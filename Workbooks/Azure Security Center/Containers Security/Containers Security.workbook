                    "query": "securityresources\n| where type == \"microsoft.security/assessments\"\n| where properties.metadata.recommendationCategory == \"SoftwareUpdate\"\n| where properties.resourceDetails.ResourceType == \"K8s-container\"\n| where properties.resourceDetails.Source == \"GCP\"\n| extend status = tostring(properties.status.code)\n| where status == \"Unhealthy\"\n| extend SoftwareName = tostring(properties.additionalData.SoftwareName)\n| extend FixedVersion = tostring(properties.additionalData.FixedVersion)\n| extend DetectedVersion = replace_string(replace_string(replace_string(tostring(properties.additionalData.DetectedSoftwareVersions), \"[\", \"\"), \"]\", \"\"), '\\\"', \"\")\n| extend resourceData = parse_json(tostring(properties.resourceAdditionalData))\n| extend ClusterName = tostring(resourceData.ClusterDetails.ClusterName)\n| extend ContainerName = tostring(resourceData.ContainerName)\n| extend CvesRaw = parse_json(tostring(properties.additionalData.CvesDetails))\n| project-away properties\n| mv-expand cve = CvesRaw\n| project-away CvesRaw\n| extend CveId = tostring(cve.CveId)\n| extend CveSeverity = tostring(cve.Severity)\n| extend swSelected = \"true\"\n| summarize TotalCVEs = dcount(CveId),\n    AffectedClusters = dcount(ClusterName),\n    AffectedContainers = dcount(ContainerName),\n    PatchableCount = dcountif(ContainerName, isnotempty(FixedVersion)),\n    TotalAssessments = dcount(id),\n    DetectedVersions = strcat_array(array_sort_asc(make_set(DetectedVersion)), \", \"),\n    swSelected = take_any(swSelected)\n    by SoftwareName\n| extend Patchable = strcat(PatchableCount, \" of \", AffectedContainers)\n| order by TotalCVEs desc\n| take 500",
