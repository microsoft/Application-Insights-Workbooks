                {
                  "type": 1,
                  "content": {
                    "json": "### Exploitable software"
                  },
                  "name": "aks_expl_hdr"
                },
                {
                  "type": 3,
                  "content": {
                    "version": "KqlItem/1.0",
                    "query": "securityresources\n| where type == \"microsoft.security/assessments\"\n| where properties.metadata.recommendationCategory == \"SoftwareUpdate\"\n| where properties.resourceDetails.ResourceType == \"K8s-container\"\n| where properties.resourceDetails.Source == \"Azure\"\n| extend status = tostring(properties.status.code)\n| where status == \"Unhealthy\"\n| extend Resource = tolower(extract(@'(?i)(.*?)/securityentitydata/([^/]+)', 1, id))\n| where Resource in~ ({k8sclu})\n| extend SoftwareName = tostring(properties.additionalData.SoftwareName)\n| extend FixedVersion = tostring(properties.additionalData.FixedVersion)\n| extend DetectedVersion = replace_string(replace_string(replace_string(tostring(properties.additionalData.DetectedSoftwareVersions), \"[\", \"\"), \"]\", \"\"), '\\\"', \"\")\n| extend resourceData = parse_json(tostring(properties.resourceAdditionalData))\n| extend ClusterName = tostring(resourceData.ClusterDetails.ClusterName)\n| extend CvesRaw = parse_json(tostring(properties.additionalData.CvesDetails))\n| project-away properties\n| mv-expand cve = CvesRaw\n| project-away CvesRaw\n| extend CveId = tostring(cve.CveId)\n| extend CveSeverity = tostring(cve.Severity)\n| mv-expand cvss = cve.Cvss\n| where tostring(cvss.Key) == \"3\"\n| extend CvssScore = toreal(cvss.Value.Base)\n| extend ExploitStepsPublished = iff(tostring(cve.ExploitabilityDetails.ExploitStepsPublished) == \"true\", \"Yes\", \"No\")\n| extend InExploitKit = iff(tostring(cve.ExploitabilityDetails.IsInExploitKit) == \"true\", \"Yes\", \"No\")\n| extend ExploitStepsVerified = iff(tostring(cve.ExploitabilityDetails.ExploitStepsVerified) == \"true\", \"Yes\", \"No\")\n| where ExploitStepsPublished == \"Yes\" or InExploitKit == \"Yes\" or ExploitStepsVerified == \"Yes\"\n| summarize MaxCvss = max(CvssScore), ExploitableCVEs = dcount(CveId), AffectedClusters = dcount(ClusterName), ExploitStepsPublished = max(ExploitStepsPublished), InExploitKit = max(InExploitKit), ExploitStepsVerified = max(ExploitStepsVerified), FixedVersion = max(FixedVersion), DetectedVersions = strcat_array(array_sort_asc(make_set(DetectedVersion)), \", \") by SoftwareName\n| order by AffectedClusters desc, MaxCvss desc\n| take 500",
                    "size": 0,
                    "title": "Software with known exploits",
                    "noDataMessage": "No data found",
                    "showExportToExcel": true,
                    "exportToExcelOptions": "all",
                    "queryType": 1,
                    "resourceType": "microsoft.resourcegraph/resources",
                    "crossComponentResources": [
                      "{subscription}"
                    ],
                    "visualization": "table",
                    "gridSettings": {
                      "formatters": [
                        {
                          "columnMatch": "SoftwareName",
                          "formatter": 1,
                          "formatOptions": {
                            "customColumnWidthSetting": "28ch"
                          }
                        },
                        {
                          "columnMatch": "ExploitStepsPublished|InExploitKit|ExploitStepsVerified",
                          "formatter": 18,
                          "formatOptions": {
