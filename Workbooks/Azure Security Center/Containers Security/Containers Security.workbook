          {
            "type": 12,
            "content": {
              "version": "NotebookGroup/1.0",
              "groupType": "editable",
              "items": [
                {
                  "type": 3,
                  "content": {
                    "version": "KqlItem/1.0",
                    "query": "securityresources\n| where type == \"microsoft.security/assessments\"\n| where properties.metadata.recommendationCategory == \"SoftwareUpdate\"\n| where properties.resourceDetails.ResourceType == \".containerimage\"\n| where properties.resourceDetails.Source == \"AWS\"\n| extend status = tostring(properties.status.code)\n| where status == \"Unhealthy\"\n| extend SoftwareName = tostring(properties.additionalData.SoftwareName)\n| extend FixedVersion = tostring(properties.additionalData.FixedVersion)\n| extend CvesRaw = parse_json(tostring(properties.additionalData.CvesDetails))\n| project-away properties\n| mv-expand cve = CvesRaw\n| project-away CvesRaw\n| extend CveId = tostring(cve.CveId)\n| extend isExpl = iff(tostring(cve.ExploitabilityDetails.ExploitStepsPublished) == \"true\" or tostring(cve.ExploitabilityDetails.IsInExploitKit) == \"true\" or tostring(cve.ExploitabilityDetails.ExploitStepsVerified) == \"true\", 1, 0)\n| summarize [\"Vulnerable packages\"] = dcount(SoftwareName), [\"Unique CVEs\"] = dcount(CveId), [\"Exploitable CVEs\"] = dcountif(CveId, isExpl == 1), [\"Patchable packages\"] = dcountif(SoftwareName, isnotempty(FixedVersion))",
                    "size": 4,
                    "title": "AWS (ECR) - Summary",
                    "noDataMessage": "No data found",
                    "exportToExcelOptions": "all",
                    "queryType": 1,
                    "resourceType": "microsoft.resourcegraph/resources",
                    "crossComponentResources": [
                      "{subscription}"
                    ],
                    "visualization": "table",
                    "gridSettings": {
                      "formatters": [
                        {
                          "columnMatch": "Vulnerable packages",
                          "formatter": 1,
                          "numberFormat": {
                            "unit": 17,
                            "options": {
                              "style": "decimal"
                            }
                          }
                        },
                        {
                          "columnMatch": "Unique CVEs",
                          "formatter": 1,
                          "numberFormat": {
                            "unit": 17,
                            "options": {
                              "style": "decimal"
                            }
                          }
                        },
                        {
                          "columnMatch": "Exploitable CVEs",
                          "formatter": 1,
                          "numberFormat": {
                            "unit": 17,
                            "options": {
                              "style": "decimal"
                            }
                          }
                        },
                        {
                          "columnMatch": "Patchable packages",
                          "formatter": 1,
                          "numberFormat": {
                            "unit": 17,
                            "options": {
                              "style": "decimal"
