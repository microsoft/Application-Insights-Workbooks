                {
                  "type": 3,
                  "content": {
                    "version": "KqlItem/1.0",
                    "query": "securityresources\n| where type == \"microsoft.security/assessments\"\n| where properties.metadata.recommendationCategory == \"SoftwareUpdate\"\n| where properties.resourceDetails.ResourceType == \".containerimage\"\n| where properties.resourceDetails.Source == \"Azure\"\n| extend status = tostring(properties.status.code)\n| where status == \"Unhealthy\"\n| extend Resource = tolower(extract(@'(?i)(.*?)/securityentitydata/([^/]+)', 1, id))\n| where Resource in~ ({acrs})\n| extend CvesRaw = parse_json(tostring(properties.additionalData.CvesDetails))\n| extend FixedVersion = tostring(properties.additionalData.FixedVersion)\n| project-away properties\n| mv-expand cve = CvesRaw\n| project-away CvesRaw\n| extend CveId = tostring(cve.CveId)\n| extend CveSeverity = tostring(cve.Severity)\n| extend isExpl = iff(tostring(cve.ExploitabilityDetails.ExploitStepsPublished) == \"true\" or tostring(cve.ExploitabilityDetails.IsInExploitKit) == \"true\" or tostring(cve.ExploitabilityDetails.ExploitStepsVerified) == \"true\", 1, 0)\n| extend isPatchable = iff(isnotempty(FixedVersion), 1, 0)\n| where CveSeverity in~ (\"Critical\", \"High\", \"Medium\", \"Low\")\n| summarize UniqueCVEs = dcount(CveId), Exploitable = dcountif(CveId, isExpl == 1), Patchable = dcountif(CveId, isPatchable == 1) by CveSeverity\n| extend SortOrder = case(CveSeverity == \"Critical\", 0, CveSeverity == \"High\", 1, CveSeverity == \"Medium\", 2, CveSeverity == \"Low\", 3, 4)\n| order by SortOrder asc",
                    "size": 4,
