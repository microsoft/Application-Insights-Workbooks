    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "securityresources\r\n | where type == \"microsoft.security/assessments\"\r\n | where name == \"f97aa83c-9b63-4f9a-99f6-b22c4398f936\" or name == \"82e20e14-edc5-4373-bfc4-f13121257c37\"\r\n | where properties.status.code == 'Unhealthy'\r\n | project ResourceType=tolower(split(id,\"/\").[6]), resourceName=tolower(split(id,\"/\").[8])\r\n | summarize Count=dcount(resourceName) by ResourceType",
