    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "securityresources\r\n| where type in (\"microsoft.security/securityconnectors/devops/azuredevopsorgs/projects/repos\",\r\n    \"microsoft.security/securityconnectors/devops/githubowners/repos\",\r\n    \"microsoft.security/securityconnectors/devops/gitlabgroups/projects\")\r\n| extend source = case(type == \"microsoft.security/securityconnectors/devops/azuredevopsorgs/projects/repos\", \"AzureDevOps\",\r\n                       type == \"microsoft.security/securityconnectors/devops/githubowners/repos\", \"GitHub\",\r\n                       type == \"microsoft.security/securityconnectors/devops/gitlabgroups/projects\", \"GitLab\", \"\")\r\n| project name, id, source\r\n|join kind= inner (securityresources\r\n| where type == \"microsoft.security/assessments\"\r\n| where id has \"/devops/default/\"\r\n| extend recommendationCategory = tostring(properties.metadata.recommendationCategory)\r\n| where recommendationCategory == \"ExposedSecrets\"\r\n| project subscriptionId, Status = tostring(properties.status.code), Source = tostring(properties.resourceDetails.source), RiskLevel = tostring(properties.risk.level), id\r\n| where Status == 'Unhealthy'\r\n| where RiskLevel in (\"Critical\", \"High\", \"Medium\", \"Low\") \r\n| extend assessedResourceId = tostring(split(id, \"/providers/Microsoft.Security/assessments/\", 0)[0])\r\n) on $left.id == $right.assessedResourceId\r\n| summarize count() by source, name\r\n| sort by count_",
        "size": 1,
        "title": "Exposed secrets by repo",
        "queryType": 1,
        "resourceType": "microsoft.resourcegraph/resources",
        "crossComponentResources": [
          "value::all"
        ],
