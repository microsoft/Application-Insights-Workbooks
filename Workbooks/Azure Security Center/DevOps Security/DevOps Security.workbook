                "linkTarget": "Url"
              }
            },
            {
              "columnMatch": "EnablementUrl",
              "formatter": 5
            }
          ],
          "rowLimit": 10000,
          "filter": true
        }
      },
      "conditionalVisibility": {
        "parameterName": "SelectedTab",
