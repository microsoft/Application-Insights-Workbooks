    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "securityresources\r\n| where type == \"microsoft.security/assessments\"\r\n| where id has \"/devops/default/\"\r\n| extend recommendationCategory = tostring(properties.metadata.recommendationCategory)\r\n| where recommendationCategory == \"ExposedSecrets\"\r\n| extend Secret = tostring(properties.additionalData.SecretTypeDisplayName)\r\n| summarize count() by Secret\r\n| sort by count_",
        "size": 0,
        "title": "Count by secret type",
        "queryType": 1,
        "resourceType": "microsoft.resources/tenants",
        "crossComponentResources": [
          "value::tenant"
        ],
        "visualization": "piechart"
      },
      "conditionalVisibility": {
        "parameterName": "SelectedTab",
        "comparison": "isEqualTo",
        "value": "SecretsTab"
      },
      "customWidth": "50",
      "name": "SecretsChart"
    },
    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "securityresources\r\n| where type in (\"microsoft.security/securityconnectors/devops/azuredevopsorgs/projects/repos\",\r\n    \"microsoft.security/securityconnectors/devops/githubowners/repos\",\r\n    \"microsoft.security/securityconnectors/devops/gitlabgroups/projects\")\r\n| extend source = case(type == \"microsoft.security/securityconnectors/devops/azuredevopsorgs/projects/repos\", \"AzureDevOps\",\r\n                       type == \"microsoft.security/securityconnectors/devops/githubowners/repos\", \"GitHub\",\r\n                       type == \"microsoft.security/securityconnectors/devops/gitlabgroups/projects\", \"GitLab\",\"\")\r\n| project Repo= name, id, source\r\n|join kind= inner (securityresources\r\n| where type == \"microsoft.security/assessments\"\r\n| where id has \"/devops/default/\"\r\n| extend recommendationCategory = tostring(properties.metadata.recommendationCategory)\r\n| where recommendationCategory == \"ExposedSecrets\"\r\n| project subscriptionId, Status = tostring(properties.status.code), Source = tostring(properties.resourceDetails.source), RiskLevel = tostring(properties.risk.level), id\r\n| where Status == 'Unhealthy'\r\n| where RiskLevel in (\"Critical\", \"High\", \"Medium\", \"Low\") \r\n| where RiskLevel != \"\"\r\n| extend assessedResourceId = tostring(split(id, \"/providers/Microsoft.Security/assessments/\", 0)[0])\r\n) on $left.id == $right.assessedResourceId\r\n| summarize count() by Repo\r\n| sort by count_",
        "size": 0,
        "title": "Count secrets by repo",
        "queryType": 1,
        "resourceType": "microsoft.resourcegraph/resources",
        "crossComponentResources": [
          "value::all"
        ],
        "visualization": "barchart"
      },
      "conditionalVisibility": {
        "parameterName": "SelectedTab",
        "comparison": "isEqualTo",
        "value": "SecretsTab"
      },
      "customWidth": "50",
      "name": "Count secrets by repo"
    },
    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "securityresources\r\n| where type == \"microsoft.security/assessments/subassessments\"\r\n| extend assessmentKey = extract(\".*assessments/(.+?)/.*\",1,  id)\r\n| where assessmentKey == \"b5ef903f-8655-473b-9784-4f749eeb25c6\" or assessmentKey == \"dd98425c-1407-40cc-8a2c-da5d0a2f80da\"\r\n| extend Source = tostring(properties.resourceDetails.source)\r\n| extend Repo = tostring(iff(Source == 'GitHub', split(id,'/')[14], split(id,'/')[16])), Project = tostring(iff(Source == 'AzureDevOps', split(id,'/')[14], 'N/A')), Organization = tostring(iff(Source == 'GitHub', split(id,'/')[12], split(id,'/')[12])),\r\n    Finding = tostring(properties.status.description),\r\n    Status = tostring(properties.status.code),\r\n    RuleID = tostring(properties.additionalData.data.Rule_id),\r\n    Location = tostring(properties.additionalData.data.Html_Url),\r\n    Time = tostring(properties.timeGenerated),\r\n    Secret = tostring(iff(Source == 'GitHub', properties.description, properties.displayName)),\r\n    Details = \"info\"\r\n| extend Creation_Date_Raw = tostring(properties.additionalData.data.Creation_Date)\r\n| extend Creation_Date_Trimmed = trim('\\\"', tostring(Creation_Date_Raw)) \r\n| extend Creation_Date = todatetime(Creation_Date_Trimmed) \r\n| extend CreatedAt = Creation_Date\r\n| project Source, Organization, Project, Repo, Secret, properties, CreatedAt, Location, Details",
