eAdditionalData.RepositoryDetails.HtmlUrl),\r\n                       iff(tostring(resourceAdditionalData.HtmlUrl) != \"\",\r\n                           resourceAdditionalData.HtmlUrl,\r\n                           \"\"))\r\n| extend Finding = tostring(properties.status.description)\r\n| extend Tool = tostring(properties.additionalData.ToolName)\r\n| extend Details = \"info\"\r\n| where RiskLevel in (\"Critical\", \"High\", \"Medium\", \"Low\")\r\n| project RiskLevel, Source, Organization, Project, Repo, Finding, Tool, Branch, CreatedAt,location, Details",
        "size": 0,
        "showExportToExcel": true,
        "exportToExcelOptions": "all",
        "queryType": 1,
        "resourceType": "microsoft.resourcegraph/resources",
        "crossComponentResources": [
          "value::all"
        ],
        "gridSettings": {
          "formatters": [
            {
              "columnMatch": "RiskLevel",
              "formatter": 5
            },
            {
              "columnMatch": "properties",
              "formatter": 5
            },
            {
              "columnMatch": "Location",
              "formatter": 7,
              "formatOptions": {
                "linkTarget": "Url",
                "linkLabel": "Alert Url"
              }
            },
            {
              "columnMatch": "Details",
              "formatter": 11,
              "formatOptions": {
                "linkTarget": "GenericDetails",
                "linkIsContextBlade": true
              }
            },
            {
              "columnMatch": "AlertUrl",
              "formatter": 7,
              "formatOptions": {
                "linkTarget": "Url",
                "linkLabel": "Link"
              }
            }
          ],
          "rowLimit": 10000,
          "filter": true,
          "hierarchySettings": {
            "treeType": 1,
            "groupBy": [
              "RiskLevel"
            ]
          }
        }
      },
