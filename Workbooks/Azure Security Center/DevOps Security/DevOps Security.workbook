    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "securityresources
| where type == "microsoft.security/assessments"
| extend assessmentKey = tostring(name)
| where assessmentKey in ("9dbf49ec-ce06-476d-ab70-7bd612c4a52c", "3178ab5f-ee29-48a9-a886-e30aa6adf44f", "7b123b34-1f78-4902-abb6-3b813abe9866", "fd104c01-29d0-428d-bb62-2c936addd2cf")
| extend status = tostring(properties.status.code)
| where status == "Unhealthy"
| extend severity = tostring(properties.metadata.severity)
| summarize dcount(id) by severity",
