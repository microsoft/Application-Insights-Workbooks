        {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "securityresources\r\n| where type == \"microsoft.security/assessments\"\r\n| where id has \"/devops/default/\"\r\n| extend recommendationCategory = tostring(properties.metadata.recommendationCategory)\r\n| where recommendationCategory == \"ExposedSecrets\"\r\n| extend RiskLevel = tostring(properties.risk.level), Status = tostring(properties.status.code)\r\n| where Status == 'Unhealthy'\r\n| where RiskLevel != \"\"\r\n| summarize Count = count() by RiskLevel",
        "size": 4,
        "title": "Exposed secrets",
        "queryType": 1,
        "resourceType": "microsoft.resourcegraph/resources",
        "crossComponentResources": [
          "value::all"
        ],
        "visualization": "piechart",
        "gridSettings": {
          "formatters": [
            {
              "columnMatch": "Resource",
              "formatter": 0,
              "formatOptions": {
                "customColumnWidthSetting": "22ch"
              }
            },
            {
              "columnMatch": "sevH",
              "formatter": 4,
              "formatOptions": {
                "min": 0,
                "palette": "redBright",
                "compositeBarSettings": {
                  "labelText": "",
                  "columnSettings": []
                },
                "customColumnWidthSetting": "15ch"
              }
            },
            {
              "columnMatch": "sevM",
              "formatter": 4,
              "formatOptions": {
                "min": 0,
                "palette": "yellow",
                "customColumnWidthSetting": "15ch"
              }
            },
            {
              "columnMatch": "sevL",
              "formatter": 4,
              "formatOptions": {
                "min": 0,
                "palette": "blueDark",
                "customColumnWidthSetting": "15ch"
              }
            }
          ]
        },
        "chartSettings": {
          "seriesLabelSettings": [
            {
              "seriesName": "Medium",
              "color": "yellow"
            },
            {
              "seriesName": "High",
              "color": "redBright"
            },
            {
              "seriesName": "Low",
              "color": "blueDark"
            }
          ]
        }
      },
      "conditionalVisibility": {
        "parameterName": "SelectedTab",
        "comparison": "isEqualTo",
        "value": "OverviewTab"
      },
      "customWidth": "30",
      "name": "SecretsExposed"
    },
    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "securityresources\r\n| where type == \"microsoft.security/assessments\"\r\n| where id has \"/devops/default/\"\r\n| extend recommendationCategory = tostring(properties.metadata.recommendationCategory)\r\n| where recommendationCategory in (\"CodeVulnerabilities\", \"ApiVulnerabilities\", \"IacVulnerabilities\", \"SoftwareUpdate\", \"ExposedSecrets\")\r\n| extend RiskLevel = tostring(properties.risk.level), Status = tostring(properties.status.code)\r\n| where Status == 'Unhealthy'\r\n| where RiskLevel != \"\"\r\n| summarize Count = count() by RiskLevel",
        "size": 1,
        "title": "DevOps security recommendations",
        "queryType": 1,
        "resourceType": "microsoft.resourcegraph/resources",
        "crossComponentResources": [
          "value::all"
        ],
        "visualization": "piechart",
        "gridSettings": {
          "formatters": [
            {
              "columnMatch": "Resource",
              "formatter": 0,
              "formatOptions": {
