    RuleID = tostring(properties.additionalData.data.Rule_id), Details = "info", 
    Html_Url = tostring(properties.additionalData.data.Html_Url)
| extend Location = iff(isnotempty(Html_Url), Html_Url, tostring(properties.additionalData.data.Build_Url))
| extend Branch = iff(Source =~ 'AzureDevOps' and Tool == 'CodeQL', 'default branch', tostring(properties.additionalData.data.Branch)), Time = tostring(properties.timeGenerated)
