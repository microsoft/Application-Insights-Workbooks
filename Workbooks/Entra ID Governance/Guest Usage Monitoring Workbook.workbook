    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "title": "Governed Guest Stats",
        "items": [
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "let _GovernedGuestEventCount = AuditLogs\n| where TimeGenerated {pTimeRange:value}\n| extend key_ = tostring(AdditionalDetails[0].key)\n| where key_ == \"GovernanceLicenseFeatureUsed\"\n| extend isGovernanceLicenseFeatureUsed = toboolean(AdditionalDetails[0].value)\n| extend TargetId = tostring(TargetResources[0].id)\n| extend TargetDisplayName = tostring(TargetResources[0].displayName)\n| extend TargetUserType = tostring(AdditionalDetails[8].value)\n|where isGovernanceLicenseFeatureUsed == true and TargetUserType == \"Guest\"\n| project TimeGenerated,OperationName,TargetId,TargetDisplayName,TargetUserType,isGovernanceLicenseFeatureUsed\n| summarize count();\nlet _UniqueGuestCount = AuditLogs\n| where TimeGenerated {pTimeRange:value}\n| extend key_ = tostring(AdditionalDetails[0].key)\n| where key_ == \"GovernanceLicenseFeatureUsed\"\n| extend isGovernanceLicenseFeatureUsed = toboolean(AdditionalDetails[0].value)\n| extend TargetId = tostring(TargetResources[0].id)\n| extend TargetDisplayName = tostring(TargetResources[0].displayName)\n| extend TargetUserType = tostring(AdditionalDetails[8].value)\n|where isGovernanceLicenseFeatureUsed == true and TargetUserType == \"Guest\"\n| project TimeGenerated,OperationName,TargetId,TargetDisplayName,TargetUserType,isGovernanceLicenseFeatureUsed\n| project TimeGenerated,OperationName,TargetId,TargetDisplayName\n| summarize dcount(TargetId);\nlet _results = \nunion (print Result = \"Governed Guests Event Count\", Metric = toscalar(_GovernedGuestEventCount)),\n    (print Result = \"Unique Governed Guest Count\", Metric = toscalar(_UniqueGuestCount)),\n    (print Result = \"Governed Guest Cost Estimate\", Metric = toreal(toscalar(_UniqueGuestCount) * 0.75));\n_results\n\n\n\n",
              "size": 4,
              "title": "Count of Governed Guest Actions",
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces",
              "visualization": "tiles",
              "tileSettings": {
                "titleContent": {
                  "columnMatch": "Result",
                  "formatter": 4,
                  "formatOptions": {
                    "palette": "blue"
                  }
                },
                "leftContent": {
                  "columnMatch": "Metric_long",
                  "formatter": 12,
                  "formatOptions": {
                    "palette": "blue"
                  }
                },
                "rightContent": {
                  "columnMatch": "Metric_real",
                  "formatter": 12,
                  "formatOptions": {
                    "palette": "blue"
                  },
                  "numberFormat": {
                    "unit": 0,
                    "options": {
                      "currency": "USD",
                      "style": "currency",
                      "useGrouping": true
                    }
                  }
                },
                "showBorder": true,
                "size": "auto",
                "styleSettings": {
                  "backgroundColor": "colorGray200"
                }
              },
              "statSettings": {
                "valueAggregation": "None",
                "colorSettings": {
                  "type": "static",
                  "mode": "background",
                  "heatmapPalette": "greenRed",
                  "thresholdsGrid": []
                },
                "iconSettings": {
                  "thresholdsGrid": []
                },
                "tagText": "",
                "valueFontStyle": "auto"
              }
            },
            "name": "query_count_GovernedGuestActions"
          },
          {
            "type": 12,
            "content": {
              "version": "NotebookGroup/1.0",
              "groupType": "editable",
              "title": "Estimated Cost Trends",
              "items": [
                {
                  "type": 3,
                  "content": {
                    "version": "KqlItem/1.0",
                    "query": "AuditLogs\n| where TimeGenerated {pTimeRange:value}\n| extend key_ = tostring(AdditionalDetails[0].key)\n| where key_ == \"GovernanceLicenseFeatureUsed\"\n| extend isGovernanceLicenseFeatureUsed = toboolean(AdditionalDetails[0].value)\n| extend TargetId = tostring(TargetResources[0].id)\n| extend TargetDisplayName = tostring(TargetResources[0].displayName)\n| extend TargetUserType = tostring(AdditionalDetails[8].value)\n|where isGovernanceLicenseFeatureUsed == true and TargetUserType == \"Guest\"\n| project TimeGenerated,OperationName,TargetId,TargetDisplayName,TargetUserType,isGovernanceLicenseFeatureUsed\n| project TimeGenerated,OperationName,TargetId,TargetDisplayName\n| summarize Cost = (dcount(TargetId) * 0.75) by bin(TimeGenerated,1d)",
                    "size": 0,
                    "title": "Guest Governance Cost | Daily",
                    "queryType": 0,
                    "resourceType": "microsoft.operationalinsights/workspaces",
                    "visualization": "timechart",
                    "chartSettings": {
                      "xAxis": "TimeGenerated",
                      "yAxis": [
                        "Cost"
                      ],
                      "seriesLabelSettings": [
                        {
                          "seriesName": "Cost",
                          "label": "Cost"
                        }
                      ],
                      "xSettings": {
                        "dateFormatSettings": {
                          "formatName": "monthDayPattern",
                          "showUtcTime": false
                        },
                        "scale": "time",
                        "label": "Month"
                      },
                      "ySettings": {
                        "numberFormatSettings": {
                          "unit": 0,
                          "options": {
                            "currency": "USD",
                            "style": "currency",
                            "useGrouping": true
                          }
                        },
                        "label": "Cost"
                      }
                    }
                  },
                  "name": "query - 30 Day History"
                },
                {
                  "type": 3,
                  "content": {
                    "version": "KqlItem/1.0",
                    "query": "AuditLogs\n| where TimeGenerated {pTimeRange:value}\n| extend key_ = tostring(AdditionalDetails[0].key)\n| where key_ == \"GovernanceLicenseFeatureUsed\"\n| extend isGovernanceLicenseFeatureUsed = toboolean(AdditionalDetails[0].value)\n| extend TargetId = tostring(TargetResources[0].id)\n| extend TargetDisplayName = tostring(TargetResources[0].displayName)\n| extend TargetUserType = tostring(AdditionalDetails[8].value)\n|where isGovernanceLicenseFeatureUsed == true and TargetUserType == \"Guest\"\n| project TimeGenerated,OperationName,TargetId,TargetDisplayName,TargetUserType,isGovernanceLicenseFeatureUsed\n| summarize Cost = (dcount(TargetId) * 0.75) by Month = startofmonth(TimeGenerated)\n| project Month = format_datetime(Month, 'yyyy-MM'), Cost",
                    "size": 0,
                    "title": "Guest Governance Cost | Monthly",
                    "queryType": 0,
                    "resourceType": "microsoft.operationalinsights/workspaces",
                    "visualization": "barchart",
                    "chartSettings": {
                      "xAxis": "Month",
                      "yAxis": [
                        "Cost"
                      ],
                      "group": null,
                      "createOtherGroup": 0,
                      "seriesLabelSettings": [
                        {
                          "seriesName": "Cost",
                          "label": "Cost"
                        }
                      ],
                      "xSettings": {
                        "label": "Month"
                      },
                      "ySettings": {
                        "numberFormatSettings": {
                          "unit": 0,
                          "options": {
                            "currency": "USD",
                            "style": "currency",
                            "useGrouping": true
                          }
                        },
                        "label": "Cost"
                      }
                    }
                  },
                  "name": "query - Guest Governance Cost Monthly"
                }
              ]
            },
            "name": "group_Costs_Trends"
          },
          {
            "type": 12,
            "content": {
              "version": "NotebookGroup/1.0",
              "groupType": "editable",
              "items": [
                {
                  "type": 12,
                  "content": {
                    "version": "NotebookGroup/1.0",
                    "groupType": "editable",
                    "items": [
                      {
                        "type": 3,
                        "content": {
                          "version": "KqlItem/1.0",
                          "query": "AuditLogs\n| where TimeGenerated {pTimeRange:value}\n| extend key_ = tostring(AdditionalDetails[0].key)\n| where key_ == \"GovernanceLicenseFeatureUsed\"\n| extend isGovernanceLicenseFeatureUsed = toboolean(AdditionalDetails[0].value)\n| extend TargetId = tostring(TargetResources[0].id)\n| extend TargetDisplayName = tostring(TargetResources[0].displayName)\n| extend TargetUserType = tostring(AdditionalDetails[8].value)\n|where isGovernanceLicenseFeatureUsed == true and TargetUserType == \"Guest\"\n| project LoggedByService\n| summarize EventCount = count() by LoggedByService",
                          "size": 3,
                          "title": "Governed Guest Users Events By Service",
                          "noDataMessage": "No Events In Selected Time Range",
                          "queryType": 0,
                          "resourceType": "microsoft.operationalinsights/workspaces",
                          "visualization": "piechart",
                          "chartSettings": {
                            "showLegend": true
                          }
                        },
                        "customWidth": "50",
                        "name": "query_LoggedByService_Count"
                      }
                    ]
                  },
                  "name": "group_Service_Charts"
                },
                {
                  "type": 3,
                  "content": {
                    "version": "KqlItem/1.0",
                    "query": "AuditLogs\n| where TimeGenerated {pTimeRange:value}\n| extend key_ = tostring(AdditionalDetails[0].key)\n| where key_ == \"GovernanceLicenseFeatureUsed\"\n| extend isGovernanceLicenseFeatureUsed = toboolean(AdditionalDetails[0].value)\n| extend TargetId = tostring(TargetResources[0].id)\n| extend TargetDisplayName = tostring(TargetResources[0].displayName)\n| extend TargetUserType = tostring(AdditionalDetails[8].value)\n|where isGovernanceLicenseFeatureUsed == true and TargetUserType == \"Guest\"\n| project TimeGenerated,OperationName,TargetId,TargetDisplayName,TargetUserType,isGovernanceLicenseFeatureUsed\n| project TimeGenerated,OperationName,TargetId,TargetDisplayName\n| summarize count() by OperationName",
                    "size": 3,
                    "title": "Governed Guest Users Events By Operation | All IGA Services",
                    "noDataMessage": "No Events for IGA Services In Time Range",
                    "queryType": 0,
                    "resourceType": "microsoft.operationalinsights/workspaces",
                    "visualization": "piechart"
                  },
                  "customWidth": "25",
                  "name": "query_GovernedGuestsOperations_AllServices_Count"
                },
                {
                  "type": 3,
                  "content": {
                    "version": "KqlItem/1.0",
                    "query": "AuditLogs\n| where TimeGenerated {pTimeRange:value}\n| extend key_ = tostring(AdditionalDetails[0].key)\n| where key_ == \"GovernanceLicenseFeatureUsed\"\n| extend isGovernanceLicenseFeatureUsed = toboolean(AdditionalDetails[0].value)\n| extend TargetId = tostring(TargetResources[0].id)\n| extend TargetDisplayName = tostring(TargetResources[0].displayName)\n| extend TargetUserType = tostring(AdditionalDetails[8].value)\n|where isGovernanceLicenseFeatureUsed == true and TargetUserType == \"Guest\" and LoggedByService == \"Entitlement Management\"\n| project TimeGenerated,OperationName,TargetId,TargetDisplayName,TargetUserType,isGovernanceLicenseFeatureUsed\n| project TimeGenerated,OperationName,TargetId,TargetDisplayName\n| summarize count() by OperationName",
                    "size": 3,
                    "title": "Governed Guest Users Events By Operation | Entitlement Management",
                    "noDataMessage": "No Entitlement Management Events In Selected Time Range",
                    "queryType": 0,
                    "resourceType": "microsoft.operationalinsights/workspaces",
                    "visualization": "piechart"
                  },
                  "customWidth": "25",
