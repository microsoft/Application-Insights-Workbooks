              ]
            },
            "name": "group_Service_Operations_Charts"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "AuditLogs\n| where TimeGenerated {pTimeRange:value}\n| extend key_ = tostring(AdditionalDetails[0].key)\n| where key_ == \"GovernanceLicenseFeatureUsed\"\n| extend isGovernanceLicenseFeatureUsed = toboolean(AdditionalDetails[0].value)\n| extend TargetId = tostring(TargetResources[0].id)\n| extend TargetDisplayName = tostring(TargetResources[0].displayName)\n| extend TargetUserType = tostring(AdditionalDetails[8].value)\n| extend TargetEmail = tostring(AdditionalDetails[2].value)\n| extend TargetEmailDomain = tostring(split(TargetEmail,\"@\")[1])\n|where isGovernanceLicenseFeatureUsed == true and TargetUserType == \"Guest\"\n| project TargetEmailDomain\n| summarize count() by TargetEmailDomain",
              "size": 3,
              "title": "Governed Guest Users By Email Domain",
              "noDataMessage": "No Events In Selected Time Range",
              "queryType": 0,
