                    "visualization": "piechart"
                  },
                  "customWidth": "25",
                  "name": "query_GovernedGuestsOperations_AR_Count"
                },
                {
                  "type": 3,
                  "content": {
                    "version": "KqlItem/1.0",
                    "query": "AuditLogs\n| where TimeGenerated {pTimeRange:value}\n| extend key_ = tostring(AdditionalDetails[0].key)\n| where key_ == \"GovernanceLicenseFeatureUsed\"\n| extend isGovernanceLicenseFeatureUsed = toboolean(AdditionalDetails[0].value)\n| extend TargetId = tostring(TargetResources[0].id)\n| extend TargetDisplayName = tostring(TargetResources[0].displayName)\n| extend TargetUserType = tostring(AdditionalDetails[8].value)\n|where isGovernanceLicenseFeatureUsed == true and TargetUserType == \"Guest\" and LoggedByService == \"Lifecycle Workflows\"\n| project TimeGenerated,OperationName,TargetId,TargetDisplayName,TargetUserType,isGovernanceLicenseFeatureUsed\n| project TimeGenerated,OperationName,TargetId,TargetDisplayName\n| summarize count() by OperationName",
                    "size": 3,
                    "title": "Governed Guest Users Events By Operation | Lifecycle Workflows",
