{
  "version": "Notebook/1.0",
  "items": [
    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "title": "About Workbook",
        "expandable": true,
        "expanded": true,
        "items": [
          {
            "type": 1,
            "content": {
              "json": "This is a Workbook designed to help organizations gain clear insight into their Entra Governance guest usage and understand the associated cost drivers. It brings data points from your tenant to highlight how external identities interact with your environment and how these patterns translate into licensing and billing considerations.\n\nMore Information can be found at [Microsoft Entra ID Governance licensing for guest users](https://learn.microsoft.com/en-us/entra/id-governance/microsoft-entra-id-governance-licensing-for-guest-users)"
            },
            "name": "text - 0"
          }
        ]
      },
      "name": "group_AboutWorkbook"
    },
    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "title": "Parameters",
