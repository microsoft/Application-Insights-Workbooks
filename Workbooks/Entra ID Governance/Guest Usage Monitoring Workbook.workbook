      },
      "name": "group - Stats"
    },
    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "title": "User Details",
        "items": [
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "let _GovernedGuests = AuditLogs\n| where TimeGenerated {pTimeRange:value}\n| extend key_ = tostring(AdditionalDetails[0].key)\n| where key_ == \"GovernanceLicenseFeatureUsed\"\n| extend isGovernanceLicenseFeatureUsed = toboolean(AdditionalDetails[0].value)\n| extend TargetId = tostring(TargetResources[0].id)\n| extend TargetDisplayName = tostring(TargetResources[0].displayName)\n| extend TargetUserPrincipalName = tostring(AdditionalDetails[3].value)\n| extend TargetEmail = tostring(AdditionalDetails[2].value)\n| extend TargetUserType = tostring(AdditionalDetails[8].value)\n|where isGovernanceLicenseFeatureUsed == true and TargetUserType == \"Guest\"\n| project TimeGenerated,OperationName,TargetId,TargetDisplayName,TargetUserType,isGovernanceLicenseFeatureUsed\n| summarize GovernedEventCount = count() by TargetId,TargetDisplayName;\nlet _GovernedGuestsEvents = AuditLogs\n| where TimeGenerated {pTimeRange:value}\n| extend key_ = tostring(AdditionalDetails[0].key)\n| where key_ == \"GovernanceLicenseFeatureUsed\"\n| extend isGovernanceLicenseFeatureUsed = toboolean(AdditionalDetails[0].value)\n| extend TargetId = tostring(TargetResources[0].id)\n| extend TargetDisplayName = tostring(TargetResources[0].displayName)\n| extend TargetUserType = tostring(AdditionalDetails[8].value)\n| extend TargetUserPrincipalName = tostring(AdditionalDetails[3].value)\n| extend TargetEmail = tostring(AdditionalDetails[2].value)\n|where isGovernanceLicenseFeatureUsed == true and TargetUserType == \"Guest\"\n| project TimeGenerated,todynamic(OperationName),TargetId,TargetDisplayName,TargetUserPrincipalName,TargetEmail;\n_GovernedGuests\n| join kind=inner (_GovernedGuestsEvents) on TargetId\n| summarize GovernanceOperations =  tostring(make_list(OperationName)) by TargetId,TargetDisplayName,TargetEmail,TargetUserPrincipalName,GovernedEventCount\n\n",
              "size": 0,
              "queryType": 0,
              "resourceType": "microsoft.operationalinsights/workspaces"
            },
            "name": "query - 0"
          }
        ]
      },
      "name": "group - User Details"
    }
  ]
}