        }
      ],
      "customWidth": "50",
      "name": "txid metric chart",
      "styleSettings": {
        "showBorder": true
      }
    },
    {
      "type": 10,
      "content": {
        "chartId": "workbook0190696b-5f8a-4fc0-8c21-5bf6c6a9ece2",
        "version": "MetricsItem/2.0",
        "size": 0,
        "chartType": 2,
