                          },
                          "numberFormat": {
                            "unit": 1,
                            "options": {
                              "style": "decimal"
                            }
                          }
                        },
                        {
                          "columnMatch": "DatabaseName_s",
                          "formatter": 1
                        }
                      ],
                      "rowLimit": 10000,
                      "filter": true,
                      "hierarchySettings": {
                        "treeType": 1,
                        "groupBy": [
                          "DatabaseName"
                        ]
                      },
                      "labelSettings": [
                        {
                          "columnId": "TimeGenerated",
                          "label": "Time Generated "
                        },
                        {
                          "columnId": "DatabaseName",
                          "label": "Database Name"
                        },
                        {
                          "columnId": "Tables_counter",
                          "label": "Total Tables"
                        },
                        {
                          "columnId": "Tables_analyzed",
                          "label": "Tables Analyzed "
                        },
                        {
                          "columnId": "Tables_autoanalyzed",
                          "label": "Tables Autoanalyzed"
                        },
                        {
                          "columnId": "Tables_autoanalyzed_pct",
                          "label": "Tables Autoanalyzed [Pct]"
                        },
                        {
                          "columnId": "Tables_never_autoanalyzed",
                          "label": "Tables Never Autoanalyzed "
                        },
                        {
                          "columnId": "Tables_never_autoanalyzed_pct",
                          "label": "Tables Never Autoanalyzed [Pct]"
                        }
                      ]
                    },
                    "sortBy": []
                  },
                  "conditionalVisibility": {
                    "parameterName": "Database",
                    "comparison": "isEqualTo",
                    "value": "All"
                  },
                  "name": "Tables Analyzed Execution Count for cluster grids"
                },
                {
                  "type": 3,
                  "content": {
                    "version": "KqlItem/1.0",
                    "query": "let graphgrain=iff({TimeRange:grain}<30m,30m,{TimeRange:grain});\r\nlet Start_Time = todatetime('{GlobalStartTime}');\r\nlet End_Time = todatetime('{GlobalEndTime}');\r\n{PostgreSQLFlexTableStats}\r\n|where TimeGenerated >= Start_Time and TimeGenerated <= End_Time\r\n| where DatabaseName == '{Database}' and SchemaName in ({QualifiedSchemas})\r\n| distinct TimeGenerated, TablesCount,TablesAnalyzedCount,TablesAutoanalyzedCount,SchemaName\r\n|summarize _Tables_counter=sum(TablesCount),_Tables_analyzed=sum(TablesAnalyzedCount),_Tables_autoanalyzed=sum(TablesAutoanalyzedCount) by bin(TimeGenerated,5m),SchemaName\r\n|make-series Tables_counter=max(_Tables_counter) default=-1 ,Tables_analyzed=max(_Tables_analyzed) default=-1,Tables_autoanalyzed=max(_Tables_autoanalyzed) default=-1 on TimeGenerated from Start_Time to End_Time step graphgrain by SchemaName\r\n| mv-expand TimeGenerated,Tables_counter, Tables_analyzed,Tables_autoanalyzed\r\n| where Tables_counter !=-1 or Tables_analyzed !=-1 or Tables_autoanalyzed != -1\r\n| extend Tables_counter = tolong(Tables_counter), Tables_analyzed=tolong(Tables_analyzed),Tables_autoanalyzed=tolong(Tables_autoanalyzed), TimeGenerated=todatetime(TimeGenerated)\r\n| extend Tables_never_autoanalyzed=Tables_counter-Tables_autoanalyzed\r\n| extend Tables_autoanalyzed_pct= iff(Tables_autoanalyzed < Tables_counter, (toreal(Tables_autoanalyzed)/toreal (Tables_counter))*100,100.0)\r\n| extend Tables_never_autoanalyzed_pct= iff(Tables_never_autoanalyzed < Tables_counter, (toreal(Tables_never_autoanalyzed)/toreal (Tables_counter))*100,100.0)\r\n| project TimeGenerated, SchemaName, Tables_counter, Tables_analyzed, Tables_autoanalyzed, Tables_autoanalyzed_pct,Tables_never_autoanalyzed, Tables_never_autoanalyzed_pct\r\n| order by TimeGenerated, Tables_never_autoanalyzed_pct desc",
                    "size": 1,
                    "showExportToExcel": true,
                    "queryType": 0,
                    "resourceType": "microsoft.dbforpostgresql/flexibleservers",
                    "crossComponentResources": [
                      "{Resource}"
                    ],
                    "visualization": "table",
                    "gridSettings": {
                      "formatters": [
                        {
                          "columnMatch": "Group",
                          "formatter": 1
                        },
                        {
                          "columnMatch": "Tables_autoanalyzed_pct",
                          "formatter": 8,
                          "formatOptions": {
                            "palette": "blue"
                          },
                          "numberFormat": {
                            "unit": 1,
                            "options": {
                              "style": "decimal"
                            }
                          }
                        },
                        {
                          "columnMatch": "Tables_never_autoanalyzed",
                          "formatter": 5
                        },
                        {
                          "columnMatch": "Tables_never_autoanalyzed_pct",
                          "formatter": 8,
                          "formatOptions": {
                            "palette": "blue"
                          },
                          "numberFormat": {
                            "unit": 1,
                            "options": {
                              "style": "decimal"
                            }
                          }
                        },
                        {
                          "columnMatch": "Schemaname_s",
                          "formatter": 1
                        }
                      ],
                      "rowLimit": 10000,
                      "filter": true,
                      "hierarchySettings": {
                        "treeType": 1,
                        "groupBy": [
                          "SchemaName"
                        ]
                      },
                      "labelSettings": [
                        {
                          "columnId": "TimeGenerated",
                          "label": "Time Generated"
                        },
                        {
                          "columnId": "SchemaName",
                          "label": "Schema Name"
                        },
                        {
                          "columnId": "Tables_counter",
                          "label": "Total Tables"
                        },
                        {
                          "columnId": "Tables_analyzed",
                          "label": "Tables Analyzed"
                        },
                        {
                          "columnId": "Tables_autoanalyzed",
                          "label": "Tables Autoanalyzed"
                        },
                        {
                          "columnId": "Tables_autoanalyzed_pct",
                          "label": "Tables Autoanalyzed [Pct]"
                        },
                        {
                          "columnId": "Tables_never_autoanalyzed",
                          "label": "Tables Never Autoanalyzed "
                        },
                        {
                          "columnId": "Tables_never_autoanalyzed_pct",
                          "label": "Tables Never Autoanalyzed [Pct]"
                        }
                      ]
                    },
                    "sortBy": []
                  },
                  "conditionalVisibilities": [
                    {
                      "parameterName": "Database",
                      "comparison": "isNotEqualTo",
                      "value": "All"
                    },
                    {
                      "parameterName": "QualifiedSchemaCount",
                      "comparison": "isEqualTo",
                      "value": "Yes"
                    }
                  ],
                  "name": " Tables Analyzed Execution Count for the database grids"
                },
                {
                  "type": 1,
                  "content": {
                    "json": "Monitor the Total Tables Never Autoanalyzed[pct] column for all databases on server. If we identify a database with a high Total Tables Never Autoanalyzed[pct] value then suggest to select the identified database from the drop down in the troubleshooting guide to further drill down and analyze.",
                    "style": "info"
                  },
                  "conditionalVisibility": {
                    "parameterName": "Database",
                    "comparison": "isEqualTo",
                    "value": "All"
                  },
                  "name": "identify databases from the dropdown"
                },
                {
                  "type": 1,
                  "content": {
                    "json": "Monitor the Total Tables Never Autoanalyzed[pct] column at schema level for selected {Database} database.\r\n\r\nHigh Total Tables Never Autoanalyzed[pct] value found. Follow the suggestions below for further analysis:\r\n\r\n1. Please consider making autovacuum_analyze_scale_factor and autovacuum_analyze_threshold more aggressive after carefully understanding the workload. Please refer to https://learn.microsoft.com/en-us/azure/postgresql/flexible-server/how-to-autovacuum-tuning for suggestions.",
                    "style": "info"
                  },
                  "conditionalVisibilities": [
                    {
                      "parameterName": "Database",
                      "comparison": "isNotEqualTo",
                      "value": "All"
                    },
                    {
                      "parameterName": "QualifiedSchemaCount",
                      "comparison": "isEqualTo",
                      "value": "Yes"
                    }
                  ],
                  "name": "monitor the total tables that have not been autoanalyzed"
                }
              ]
            },
            "conditionalVisibility": {
              "parameterName": "vacuum-tab",
              "comparison": "isEqualTo",
              "value": "analyze"
            },
            "name": "analyze"
          }
        ],
        "exportParameters": true
      },
      "conditionalVisibilities": [
        {
          "parameterName": "tab",
          "comparison": "isEqualTo",
          "value": "vacuumanalyze"
        },
        {
          "parameterName": "QualifiedDatabasesCount",
          "comparison": "isEqualTo",
          "value": "Yes"
        }
      ],
      "name": "vacuum & analyze group section"
    },
    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "items": [
          {
            "type": 9,
            "content": {
              "version": "KqlParameterItem/1.0",
              "crossComponentResources": [
                "{Resource}"
              ],
              "parameters": [
                {
                  "id": "2f5a7b41-0b8a-4f2b-9d62-2a4d3c6b9e10",
                  "version": "KqlParameterItem/1.0",
                  "name": "PeakConcurrentRuns",
                  "type": 1,
                  "query": "let dbFilter = '{Database}';\r\nlet runs = materialize(\r\n    {ParsedAutovacuumLogs}\r\n    | where dbFilter == 'All' or database == dbFilter\r\n    | where isnotnull(elapsed_time) and todouble(elapsed_time) > 0\r\n    | project endTime   = TimeGenerated,\r\n              startTime = TimeGenerated - (1s * todouble(elapsed_time))\r\n);\r\nlet events =\r\n    runs | project t = startTime, delta = 1\r\n    | union (runs | project t = endTime, delta = -1);\r\nevents\r\n| order by t asc, delta desc           // process +1 before -1 on ties → safer (higher) peak\r\n| extend running = row_cumsum(delta)\r\n| summarize PeakRuns = max(running)\r\n| extend PeakRuns = iff(isnull(PeakRuns), 0, PeakRuns)\r\n| project tostring(PeakRuns)\r\n",
                  "crossComponentResources": [
                    "{Resource}"
                  ],
                  "isHiddenWhenLocked": true,
                  "queryType": 0,
                  "resourceType": "microsoft.dbforpostgresql/flexibleservers"
                },
                {
                  "id": "07a5b4d2-2c41-4e16-8f6f-7d3f5b9a2c45",
                  "version": "KqlParameterItem/1.0",
                  "name": "IsWorkersSaturated",
                  "type": 1,
                  "isHiddenWhenLocked": true,
                  "criteriaData": [
                    {
                      "criteriaContext": {
                        "leftOperand": "PeakConcurrentRuns",
                        "operator": ">=",
                        "rightValType": "param",
                        "rightVal": "fetch_autovacuum_max_workers",
                        "resultValType": "static",
                        "resultVal": "Yes"
                      }
                    },
                    {
                      "criteriaContext": {
                        "operator": "Default",
                        "resultValType": "static",
                        "resultVal": "No"
                      }
                    }
                  ]
                }
              ],
              "style": "pills",
              "queryType": 0,
              "resourceType": "microsoft.dbforpostgresql/flexibleservers"
            },
            "conditionalVisibility": {
              "parameterName": "x",
              "comparison": "isEqualTo",
              "value": "y"
            },
            "name": "autovacuum activity hidden checks"
          },
          {
            "type": 1,
            "content": {
              "json": "### Autovacuum activity\r\n\r\nA server-wide view of autovacuum runs in the selected time range. Use the trend chart to spot when activity spikes, the trigger breakdown to identify regular versus emergency runs (anti-wraparound, failsafe), and the per-database grid to see which databases drive the load.\r\n\r\nIf the worker saturation banner appears, autovacuum reached `autovacuum_max_workers` at least once during the window, which means additional vacuum work had to wait. For per-table detail and drilldown into individual runs, switch to the **Autovacuum per table** tab.",
              "style": "info"
            },
            "name": "autovacuum activity intro"
          },
          {
            "type": 1,
            "content": {
              "json": "#### No autovacuum entries were found in the PostgreSQL server logs for the selected window. Verify that the database has activity and that `PostgreSQLLogs` is being sent to the Log Analytics workspace.",
              "style": "info"
            },
            "conditionalVisibility": {
              "parameterName": "IsAVDataExists",
              "comparison": "isEqualTo",
              "value": "No"
            },
            "name": "autovacuum activity empty state"
          },
          {
            "type": 1,
            "content": {
              "json": "**Autovacuum workers were saturated**\r\n\r\nIn this window, autovacuum reached `autovacuum_max_workers` ({fetch_autovacuum_max_workers}) at least once. When all worker slots are busy, additional tables that need vacuuming have to wait. Consider raising `autovacuum_max_workers` together with `autovacuum_vacuum_cost_limit`, or reducing the workload driving the bloat. See the **Configuration** tab for current values.",
              "style": "warning"
            },
            "conditionalVisibilities": [
              {
                "parameterName": "IsAVDataExists",
                "comparison": "isEqualTo",
                "value": "Yes"
              },
              {
                "parameterName": "IsWorkersSaturated",
                "comparison": "isEqualTo",
                "value": "Yes"
              }
            ],
            "name": "autovacuum activity saturation banner"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "let dbFilter = '{Database}';\r\nlet binSize  = iff({TimeRange:grain} < 5m, 5m, {TimeRange:grain});\r\n{ParsedAutovacuumLogs}\r\n| where dbFilter == 'All' or database == dbFilter\r\n| summarize Runs = count() by bin(TimeGenerated, binSize), database\r\n| order by TimeGenerated asc",
              "size": 0,
              "title": "Autovacuum runs over time (by database)",
              "noDataMessage": "No autovacuum runs in the selected window.",
              "queryType": 0,
              "resourceType": "microsoft.dbforpostgresql/flexibleservers",
              "crossComponentResources": [
                "{Resource}"
              ],
              "visualization": "linechart",
              "chartSettings": {
                "xAxis": "TimeGenerated",
                "yAxis": [
                  "Runs"
                ],
                "group": "database",
                "createOtherGroup": 10,
                "showLegend": true,
                "ySettings": {
                  "numberFormatSettings": {
                    "unit": 17,
                    "options": {
                      "style": "decimal",
                      "maximumFractionDigits": 0
                    }
                  }
                }
              }
            },
            "customWidth": "100",
            "conditionalVisibility": {
              "parameterName": "IsAVDataExists",
              "comparison": "isEqualTo",
              "value": "Yes"
            },
            "name": "autovacuum activity trend"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "let dbFilter = '{Database}';\r\nlet binSize  = iff({TimeRange:grain} < 5m, 5m, {TimeRange:grain});\r\n{ParsedAutovacuumLogs}\r\n| where dbFilter == 'All' or database == dbFilter\r\n| extend trigger = case(\r\n    is_failsafe,        'Failsafe',\r\n    is_antiwraparound,  'Anti-wraparound',\r\n    is_aggressive,      'Aggressive',\r\n                        'Regular')\r\n| summarize Runs = count() by bin(TimeGenerated, binSize), trigger\r\n| order by TimeGenerated asc",
              "size": 0,
              "title": "Autovacuum runs by trigger type",
              "noDataMessage": "No autovacuum runs in the selected window.",
              "queryType": 0,
              "resourceType": "microsoft.dbforpostgresql/flexibleservers",
              "crossComponentResources": [
                "{Resource}"
              ],
              "visualization": "areachart",
              "chartSettings": {
                "xAxis": "TimeGenerated",
                "yAxis": [
                  "Runs"
                ],
                "group": "trigger",
                "createOtherGroup": 0,
                "seriesLabelSettings": [
                  {
                    "seriesName": "Regular",
                    "color": "blue"
                  },
                  {
                    "seriesName": "Aggressive",
                    "color": "yellow"
                  },
                  {
                    "seriesName": "Anti-wraparound",
                    "color": "orange"
                  },
                  {
                    "seriesName": "Failsafe",
                    "color": "red"
                  }
                ],
                "showLegend": true,
                "ySettings": {
                  "numberFormatSettings": {
                    "unit": 17,
                    "options": {
                      "style": "decimal",
                      "maximumFractionDigits": 0
                    }
                  }
                }
              }
            },
            "customWidth": "50",
            "conditionalVisibility": {
              "parameterName": "IsAVDataExists",
              "comparison": "isEqualTo",
              "value": "Yes"
            },
            "name": "autovacuum activity by trigger"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "let dbFilter = '{Database}';\r\n{ParsedAutovacuumLogs}\r\n| where dbFilter == 'All' or database == dbFilter\r\n| summarize\r\n    Runs               = count(),\r\n    AntiWraparoundRuns = countif(is_antiwraparound),\r\n    TablesTouched      = dcount(database_table),\r\n    TotalSec           = round(todouble(sum(elapsed_time)), 1)\r\n    by database\r\n| order by Runs desc\r\n| project\r\n    ['database']         = database,\r\n    ['runs']             = Runs,\r\n    ['tables touched']   = TablesTouched,\r\n    ['anti-wraparound']  = AntiWraparoundRuns,\r\n    ['total seconds']    = TotalSec",
              "size": 0,
              "title": "Activity by database",
              "noDataMessage": "No autovacuum runs in the selected window.",
              "queryType": 0,
              "resourceType": "microsoft.dbforpostgresql/flexibleservers",
              "crossComponentResources": [
                "{Resource}"
              ],
              "visualization": "table",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "runs",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "blue",
                      "customColumnWidthSetting": "20ch"
                    },
                    "numberFormat": {
                      "unit": 17,
                      "options": {
                        "style": "decimal",
                        "maximumFractionDigits": 0
                      }
                    }
                  },
                  {
                    "columnMatch": "tables touched",
                    "formatter": 0,
                    "numberFormat": {
                      "unit": 17,
                      "options": {
                        "style": "decimal",
                        "maximumFractionDigits": 0
                      }
                    }
                  },
                  {
                    "columnMatch": "anti-wraparound",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "red",
                      "customColumnWidthSetting": "20ch"
                    },
                    "numberFormat": {
                      "unit": 17,
                      "options": {
                        "style": "decimal",
                        "maximumFractionDigits": 0
                      }
                    }
                  },
                  {
                    "columnMatch": "total seconds",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "blueDark",
                      "customColumnWidthSetting": "20ch"
                    },
                    "numberFormat": {
                      "unit": 17,
                      "options": {
                        "style": "decimal",
                        "maximumFractionDigits": 2
                      }
                    }
                  }
                ],
                "rowLimit": 200,
                "filter": true
              }
            },
            "customWidth": "50",
            "conditionalVisibility": {
              "parameterName": "IsAVDataExists",
              "comparison": "isEqualTo",
              "value": "Yes"
            },
            "name": "autovacuum activity by database"
          },
          {
            "type": 1,
            "content": {
              "json": "The trend chart shows total autovacuum runs over time, broken down by database. The chart on the left categorises those runs by trigger type so you can spot when **Anti-wraparound** or **Failsafe** runs appear (which usually indicate trouble). The grid on the right ranks databases by activity. For per-table detail, switch to the **Autovacuum per table** tab.",
              "style": "info"
            },
            "conditionalVisibility": {
              "parameterName": "IsAVDataExists",
              "comparison": "isEqualTo",
              "value": "Yes"
            },
            "name": "autovacuum activity footer"
          }
        ],
        "exportParameters": true
      },
      "conditionalVisibilities": [
        {
          "parameterName": "tab",
          "comparison": "isEqualTo",
          "value": "vacuumworkers"
        },
        {
          "parameterName": "QualifiedDatabasesCount",
          "comparison": "isEqualTo",
          "value": "Yes"
        }
      ],
      "name": "autovacuum activity tab"
    },
    {
      "type": 1,
      "content": {
        "json": "#### No autovacuum entries were found in the PostgreSQL server logs for the selected window. Verify that the database has activity and that `PostgreSQLLogs` is being sent to the Log Analytics workspace.",
        "style": "info"
      },
      "conditionalVisibilities": [
        {
          "parameterName": "IsAVDataExists",
          "comparison": "isEqualTo",
          "value": "No"
        },
        {
          "parameterName": "QualifiedDatabasesCount",
          "comparison": "isEqualTo",
          "value": "Yes"
        }
      ],
      "name": "autovacuum per table empty state"
    },
    {
      "type": 1,
      "content": {
        "json": "### Autovacuum per table\r\n\r\nReview autovacuum runs at the table level. The summary tiles below show key signals across all tables. The charts highlight the busiest, most blocked, and longest-running vacuums. The daily grid lists every run with a drill-down to individual entries.\r\n\r\n**Note:** This tab relies on autovacuum entries in the PostgreSQL logs forwarded to your Log Analytics workspace. These entries are produced only when the server parameter `log_autovacuum_min_duration` is set to a non-negative value.",
        "style": "info"
      },
      "conditionalVisibilities": [
        {
          "parameterName": "tab",
          "comparison": "isEqualTo",
          "value": "vacuumpertablehistory"
        },
        {
          "parameterName": "QualifiedDatabasesCount",
          "comparison": "isEqualTo",
          "value": "Yes"
        }
      ],
      "name": "avpertableSectionIntro"
    },
    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "let dbFilter = '{Database}';\r\nlet summary = {ParsedAutovacuumLogs}\r\n| where dbFilter == 'All' or database == dbFilter\r\n| summarize\r\n    TotalRuns             = count(),\r\n    TablesVacuumed        = dcount(database_table),\r\n    AntiWraparoundRuns    = countif(is_antiwraparound),\r\n    TotalSecondsVacuuming = round(todouble(sum(elapsed_time)), 1),\r\n    AvgSecondsVacuuming   = round(todouble(avg(elapsed_time)), 2),\r\n    MaxSecondsVacuuming   = round(todouble(max(elapsed_time)), 1),\r\n    PeakBlockedTuples     = max(tuples_dead_not_removed);\r\nlet cancelled = toscalar({PostgreSQLLogs}\r\n    | where TimeGenerated >= todatetime('{GlobalStartTime}') and TimeGenerated <= todatetime('{GlobalEndTime}')\r\n    | where Message has \"canceling autovacuum task\"\r\n    | count);\r\nsummary\r\n| project Metric = 'Total runs',                    Value = todouble(TotalRuns),           Tooltip = 'Total autovacuum runs in the selected time range across all tables.',                                                                                                                                                          Order = 1\r\n| union (summary | project Metric = 'Tables vacuumed',              Value = todouble(TablesVacuumed),      Tooltip = 'Number of distinct tables that received at least one autovacuum run.',                                                                                                                                              Order = 2)\r\n| union (summary | project Metric = 'Anti-wraparound runs',         Value = todouble(AntiWraparoundRuns),  Tooltip = 'Runs triggered because the table age crossed autovacuum_freeze_max_age (default 200 million transaction IDs). Cost throttling still applies. These runs are normal at scale but should be monitored.',                Order = 3)\r\n| union (summary | project Metric = 'Cancelled runs',               Value = todouble(cancelled),           Tooltip = 'Autovacuum runs cancelled by conflicting locks. Persistent cancellations prevent tables from being cleaned and lead to bloat. Anti-wraparound runs cannot be cancelled this way.',                                Order = 4)\r\n| union (summary | project Metric = 'Total time vacuuming (s)',     Value = TotalSecondsVacuuming,         Tooltip = 'Sum of elapsed time across all autovacuum runs in the selected window. High values indicate either many runs or a few very long ones. Review the per-table breakdown for details.',                                  Order = 5)\r\n| union (summary | project Metric = 'Average run duration (s)',     Value = AvgSecondsVacuuming,           Tooltip = 'Mean elapsed time per autovacuum run. A growing average over time can indicate table bloat or insufficient autovacuum resources.',                                                                                  Order = 6)\r\n| union (summary | project Metric = 'Longest single run (s)',       Value = MaxSecondsVacuuming,           Tooltip = 'Longest single autovacuum run in the selected window. Compare with your maintenance window. A run that exceeds the window may indicate an under-provisioned worker or a very large table.',                          Order = 7)\r\n| union (summary | project Metric = 'Peak blocked tuples',          Value = todouble(PeakBlockedTuples),   Tooltip = 'Highest observed count of dead tuples that vacuum could not remove because an open transaction snapshot might still need them. Persistent values indicate a vacuum blocker.',                                        Order = 8)\r\n| order by Order asc\r\n| project Metric, Value, Tooltip",
        "size": 4,
        "title": "Key autovacuum signals",
        "queryType": 0,
        "resourceType": "microsoft.dbforpostgresql/flexibleservers",
        "crossComponentResources": [
          "{Resource}"
        ],
        "visualization": "tiles",
        "gridSettings": {
          "rowLimit": 1
        },
        "tileSettings": {
          "titleContent": {
            "columnMatch": "Metric",
            "formatter": 1
          },
          "subtitleContent": {
            "columnMatch": "Tooltip",
            "formatter": 1
          },
          "leftContent": {
            "columnMatch": "Value",
            "formatter": 12,
            "formatOptions": {
              "palette": "auto"
            },
            "numberFormat": {
              "unit": 17,
              "options": {
                "style": "decimal",
                "maximumFractionDigits": 2
              }
            }
          },
          "showBorder": true
        }
      },
      "conditionalVisibilities": [
        {
          "parameterName": "tab",
          "comparison": "isEqualTo",
          "value": "vacuumpertablehistory"
        },
        {
          "parameterName": "QualifiedDatabasesCount",
          "comparison": "isEqualTo",
          "value": "Yes"
        }
      ],
      "name": "avpertableKPIStrip"
    },
    {
      "type": 1,
      "content": {
        "json": "#### Top tables\r\nRanked views of vacuum activity, blocking, and duration across the tables in your database.",
        "style": "info"
      },
      "conditionalVisibilities": [
        {
          "parameterName": "tab",
          "comparison": "isEqualTo",
          "value": "vacuumpertablehistory"
        },
        {
          "parameterName": "QualifiedDatabasesCount",
          "comparison": "isEqualTo",
          "value": "Yes"
        }
      ],
      "name": "avpertableTopTablesHeader"
    },
    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "let dbFilter = '{Database}';\r\n{ParsedAutovacuumLogs}\r\n| where dbFilter == 'All' or database == dbFilter\r\n| summarize VacuumRuns = count(), AntiWraparoundRuns = countif(is_antiwraparound) by database_table\r\n| top 10 by VacuumRuns desc\r\n| order by VacuumRuns desc",
        "size": 0,
        "title": "Top 10 tables by vacuum run count",
        "queryType": 0,
        "resourceType": "microsoft.dbforpostgresql/flexibleservers",
        "crossComponentResources": [
          "{Resource}"
        ],
        "visualization": "barchart",
        "chartSettings": {
          "xAxis": "database_table",
          "yAxis": [
            "VacuumRuns",
            "AntiWraparoundRuns"
          ],
          "showLegend": true,
          "seriesLabelSettings": [
            {
              "seriesName": "AntiWraparoundRuns",
              "label": "Anti-wraparound runs",
              "color": "redBright"
            },
            {
              "seriesName": "VacuumRuns",
              "label": "Vacuum runs in top 10",
              "color": "blue"
            }
          ]
        }
      },
      "conditionalVisibilities": [
        {
          "parameterName": "tab",
          "comparison": "isEqualTo",
          "value": "vacuumpertablehistory"
        },
        {
          "parameterName": "QualifiedDatabasesCount",
          "comparison": "isEqualTo",
          "value": "Yes"
        }
      ],
      "customWidth": "33",
      "name": "avhistorybarchart",
      "styleSettings": {
        "showBorder": true
      }
    },
    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "let dbFilter = '{Database}';\r\n{ParsedAutovacuumLogs}\r\n| where dbFilter == 'All' or database == dbFilter\r\n| summarize PeakNonRemovableDeadTuples = max(tuples_dead_not_removed) by database_table\r\n| where PeakNonRemovableDeadTuples > 0\r\n| top 10 by PeakNonRemovableDeadTuples desc\r\n| order by PeakNonRemovableDeadTuples desc",
        "size": 0,
        "title": "Top 10 tables by peak non-removable dead tuples",
        "queryType": 0,
        "resourceType": "microsoft.dbforpostgresql/flexibleservers",
        "crossComponentResources": [
          "{Resource}"
        ],
        "visualization": "barchart",
        "chartSettings": {
          "showLegend": true
        }
      },
      "conditionalVisibilities": [
        {
          "parameterName": "tab",
          "comparison": "isEqualTo",
          "value": "vacuumpertablehistory"
        },
        {
          "parameterName": "QualifiedDatabasesCount",
          "comparison": "isEqualTo",
          "value": "Yes"
        }
      ],
      "customWidth": "33",
      "name": "avtuplesremovehistorybarchart",
      "styleSettings": {
        "showBorder": true
      }
    },
    {
      "type": 3,
      "content": {
        "version": "KqlItem/1.0",
        "query": "let dbFilter = '{Database}';\r\n{ParsedAutovacuumLogs}\r\n| where dbFilter == 'All' or database == dbFilter\r\n| summarize \r\n    TotalVacuumSeconds = round(todouble(sum(elapsed_time)), 2)\r\n    by database_table\r\n| top 10 by TotalVacuumSeconds desc\r\n| project database_table, TotalVacuumSeconds\r\n| order by TotalVacuumSeconds desc",
        "size": 0,
        "title": "Top 10 tables by total time spent vacuuming",
        "queryType": 0,
        "resourceType": "microsoft.dbforpostgresql/flexibleservers",
        "crossComponentResources": [
          "{Resource}"
        ],
        "visualization": "barchart",
        "chartSettings": {
          "group": "database_table",
          "createOtherGroup": 10,
          "showLegend": true,
          "ySettings": {
            "numberFormatSettings": {
              "unit": 24,
              "options": {
                "style": "decimal",
                "useGrouping": true
              }
            }
          }
        }
      },
      "conditionalVisibilities": [
        {
          "parameterName": "tab",
          "comparison": "isEqualTo",
          "value": "vacuumpertablehistory"
        },
        {
          "parameterName": "QualifiedDatabasesCount",
          "comparison": "isEqualTo",
          "value": "Yes"
        }
