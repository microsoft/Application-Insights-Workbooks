          {
            "id": "a7e8f9c1-2b3d-4e5f-6a7b-8c9d0e1f2a3b",
            "version": "KqlParameterItem/1.0",
            "name": "ParsedAutovacuumLogs",
            "type": 1,
            "isHiddenWhenLocked": true,
            "criteriaData": [
              {
                "criteriaContext": {
                  "operator": "Default",
                  "resultValType": "static",
                  "resultVal": "{PostgreSQLLogs} | where TimeGenerated >= todatetime('{GlobalStartTime}') and TimeGenerated <= todatetime('{GlobalEndTime}') | where Message has \"vacuum\" and Message has \"of table\" | where Message matches regex @\"automatic( aggressive)? vacuum( to prevent wraparound)? of table\" | distinct TimeGenerated, Message | extend dbst = extract_all(@\"automatic(?: aggressive)? vacuum(?: to prevent wraparound)? of table \"\"(?P<database>[^.\"\"]+)\\.(?P<schema>[^.]+)\\.(?P<table>[^\"\"]+)\"\"\", Message) | extend dbst = todynamic(substring(tostring(dbst), 1, strlen(tostring(dbst)) - 2)) | extend database = tostring(dbst[0]), schema = tostring(dbst[1]), table = tostring(dbst[2]) | where database !in ('azure_sys', 'azure_maintenance') | extend e1 = extract(@\"elapsed: (\\d+\\.?\\d*)\", 1, Message), e2 = extract(@\"(\\d+\\.?\\d*) s(?:ec)? elapsed\", 1, Message), e3 = extract(@\"(\\d+\\.?\\d*) sec\", 1, Message) | extend elapsed_time = todecimal(case(isnotempty(e1), e1, isnotempty(e2), e2, isnotempty(e3), e3, \"\")) | extend tuples_removed = tolong(extract(\"tuples: (\\\\d+) removed\", 1, Message)), tuples_remain = tolong(extract(\"tuples: \\\\d+ removed, (\\\\d+) remain\", 1, Message)), tuples_dead_not_removed = tolong(extract(\"remain, (\\\\d+) are dead but not yet removable\", 1, Message)), oldest_xmin = tolong(extract(\"oldest xmin: (\\\\d+)\", 1, Message)), index_scans = toint(extract(\"index scans: (\\\\d+)\", 1, Message)), pages_skipped_pins = tolong(extract(\"(\\\\d+) skipped due to pins\", 1, Message)), pages_skipped_frozen = tolong(extract(\"(\\\\d+) skipped frozen\", 1, Message)), frozen_pages = tolong(extract(\"frozen: (\\\\d+) pages\", 1, Message)), wal_bytes = tolong(extract(\"WAL usage: \\\\d+ records, \\\\d+ full page images, (\\\\d+) bytes\", 1, Message)), removable_cutoff_xid_age = tolong(extract(\"removable cutoff: \\\\d+, which was (\\\\d+) XIDs old\", 1, Message)), is_antiwraparound = Message has \"to prevent wraparound\", is_aggressive = Message has \"automatic aggressive\", is_failsafe = Message has \"bypassing nonessential maintenance\" | extend database_table = strcat(database, '.', schema, '.', table), schema_table   = strcat(schema, '.', table) | project TimeGenerated, database, schema, table, database_table,schema_table, tuples_removed, tuples_remain, tuples_dead_not_removed, oldest_xmin, elapsed_time, index_scans, pages_skipped_pins, pages_skipped_frozen, frozen_pages, wal_bytes, removable_cutoff_xid_age, is_antiwraparound, is_aggressive, is_failsafe, Message"
                }
              }
            ]
          }
        ],
        "style": "above",
        "queryType": 1,
        "resourceType": "microsoft.resourcegraph/resources"
